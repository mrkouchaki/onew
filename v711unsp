                top_features = d.groupby("FEATURE")["ANOMALY_RISK_SCORE"].max().sort_values(ascending=False).head(int(getattr(args, "plot_top_features", 14))).index.tolist()
                mat = d[d["FEATURE"].isin(top_features)].pivot_table(index="ECGI_LABEL", columns="FEATURE", values="ANOMALY_RISK_SCORE", aggfunc="max", fill_value=0)
                mat = mat.loc[[x for x in ecgi_summary.head(int(getattr(args, "plot_top_ecgis", 30)))["ECGI_LABEL"].tolist() if x in mat.index]]
                if not mat.empty:
                    fig, ax = plt.subplots(figsize=(max(10, 0.7 * len(mat.columns)), max(7, 0.35 * len(mat.index))))
                    im = ax.imshow(mat.values, aspect="auto")
                    ax.set_xticks(np.arange(len(mat.columns)))
                    ax.set_xticklabels(mat.columns, rotation=45, ha="right")
                    ax.set_yticks(np.arange(len(mat.index)))
                    ax.set_yticklabels([_short(x, 35) for x in mat.index])
                    ax.set_title("V7.1 severity heatmap: top ECGIs x abnormal features")
                    fig.colorbar(im, ax=ax, label="anomaly risk score")
                    fig.tight_layout()
                    p = plot_dir / "03_top_ecgi_feature_heatmap.png"
                    fig.savefig(p, dpi=160, bbox_inches="tight")
                    plt.close(fig)
                    images.append(("Top ECGI-feature heatmap", str(p.relative_to(out_dir))))

        # 4) History story plots.
        stories, pairs = _selected_pairs_for_stories(dataset, int(getattr(args, "plot_story_count", 5)))
        input_file = analysis_info.get("input_file", "")
        hist = pd.DataFrame()
        if input_file and pairs:
            try:
                base.log(f"Querying daily history for {len(pairs):,} ECGI-feature plot pair(s)", indent=1)
                hist = _query_daily_history_for_pairs(Path(input_file), analysis_info, args, pairs)
                hist.to_csv(out_dir / "cesmlc_v71_plot_daily_history_selected.csv", index=False)
            except Exception as exc:
                base.log(f"Could not query daily history for story plots: {exc}", indent=1)
                base.log(traceback.format_exc().splitlines()[-1], indent=2)
        story_rows = []
        if not hist.empty:
            for i, story in enumerate(stories, start=1):
                p = plot_dir / f"04_story_{i:02d}_abnormal_vs_lowrisk.png"
                if _plot_story_comparison(story, hist, p):
                    images.append((f"Story {i}: abnormal vs low-risk regular change", str(p.relative_to(out_dir))))
                    story_rows.append(
                        {
                            "story": i,
                            "abnormal_ecgi": story["abnormal"].get("ECGI"),
                            "abnormal_feature": story["abnormal"].get("FEATURE"),
                            "abnormal_cluster": story["abnormal"].get("PRIMARY_ANOMALY_CLUSTER"),
                            "abnormal_risk": story["abnormal"].get("ANOMALY_RISK_SCORE"),
                            "low_risk_ecgi": story["low_risk"].get("ECGI"),
                            "low_risk_feature": story["low_risk"].get("FEATURE"),
                            "low_risk_cluster": story["low_risk"].get("PRIMARY_ANOMALY_CLUSTER"),
                            "low_risk_risk": story["low_risk"].get("ANOMALY_RISK_SCORE"),
                            "plot_file": str(p.relative_to(out_dir)),
                        }
                    )
            pd.DataFrame(story_rows).to_csv(out_dir / "cesmlc_v71_story_examples.csv", index=False)

            # Multi-feature story plots for up to N ECGIs.
            mcount = int(getattr(args, "plot_ecgi_multifeature_count", 5))
            if mcount > 0:
                abnormal = dataset[dataset.get("ABNORMAL_FEATURE_FLAG", 0) == 1].copy()
                candidate_ecgis = (
                    abnormal.groupby("ECGI").filter(lambda x: x["FEATURE"].nunique() >= 2)["ECGI"].drop_duplicates().head(mcount).tolist()
                    if not abnormal.empty
                    else []
                )
                for j, ecgi in enumerate(candidate_ecgis, start=1):
                    rows = abnormal[abnormal["ECGI"] == ecgi].sort_values("ANOMALY_RISK_SCORE", ascending=False).head(3)
                    p = plot_dir / f"05_multifeature_ecgi_{j:02d}_{_safe_filename(ecgi, 40)}.png"
                    if _plot_multifeature_ecgi(ecgi, rows, hist, p):
                        images.append((f"Multi-feature ECGI story {j}", str(p.relative_to(out_dir))))

        # HTML visual report.
        html_lines = [
            "<!doctype html>",
            "<html><head><meta charset='utf-8'><title>CESMLC V7.1 Visual Report</title>",
            "<style>body{font-family:Arial, sans-serif; margin:24px;} img{max-width:100%; border:1px solid #ddd; margin:8px 0 28px 0;} .card{margin-bottom:36px;} code{background:#f4f4f4; padding:2px 4px;}</style>",
            "</head><body>",
            "<h1>CESMLC V7.1 Visual Report</h1>",
            f"<p>Window: <code>{html.escape(str(analysis_info.get('window_start_date','')))}</code> to <code>{html.escape(str(analysis_info.get('window_end_date','')))}</code></p>",
        ]
        for title, rel in images:
            html_lines.append(f"<div class='card'><h2>{html.escape(title)}</h2><img src='{html.escape(rel)}'></div>")
        html_lines.append("</body></html>")
        (out_dir / "cesmlc_v71_visual_report.html").write_text("\n".join(html_lines), encoding="utf-8")
        base.log(f"Wrote V7.1 visual report: {out_dir / 'cesmlc_v71_visual_report.html'}", indent=1)
    except Exception as exc:
        base.log(f"V7.1 plotting failed but main outputs were written. Error: {exc}", indent=1)
        base.log(traceback.format_exc().splitlines()[-1], indent=2)


# ---------------------------------------------------------------------------
# Output override
# ---------------------------------------------------------------------------


def write_outputs(
    out_dir: Path,
    analysis_info: Dict[str, Any],
    args: argparse.Namespace,
    candidates: pd.DataFrame,
    dataset: pd.DataFrame,
    ecgi_summary: pd.DataFrame,
    issue_summary: pd.DataFrame,
    changes: pd.DataFrame,
    conflicts: pd.DataFrame,
) -> None:
    # First run the original writer so all legacy CSVs continue to exist.
    ORIG_WRITE_OUTPUTS(out_dir, analysis_info, args, candidates, dataset, ecgi_summary, issue_summary, changes, conflicts)

    base.header("PHASE 1H - WRITE V7.1 CLUSTERED REPORTS AND VISUALS")
    out_dir.mkdir(parents=True, exist_ok=True)

    dataset.to_csv(out_dir / "cesmlc_v71_feature_incidents_with_clusters_all.csv", index=False)
    abnormal = dataset[(dataset.get("ABNORMAL_FEATURE_FLAG", 0) == 1)].sort_values("ANOMALY_RISK_SCORE", ascending=False) if not dataset.empty else pd.DataFrame()
    abnormal.to_csv(out_dir / "cesmlc_v71_feature_incidents_reportable_all.csv", index=False)
    abnormal.head(int(getattr(args, "top_n_features", 2000))).to_csv(out_dir / "cesmlc_v71_feature_incidents_reportable_top.csv", index=False)

    if not ecgi_summary.empty:
        ecgi_summary.to_csv(out_dir / "cesmlc_v71_clustered_ecgi_incident_summary_all.csv", index=False)
        ecgi_summary.head(int(getattr(args, "top_n", 300))).to_csv(out_dir / "cesmlc_v71_clustered_ecgi_incident_summary_top.csv", index=False)
        cols = [
            "INCIDENT_RANK",
            "ECGI",
            "ECGI_LABEL",
            "PRIMARY_ANOMALY_CLUSTER",
            "PRIMARY_ABNORMAL_FEATURE",
            "ECGI_ANOMALY_RISK_SCORE",
            "ABNORMAL_FEATURE_COUNT",
            "ABNORMAL_DAYS_TOTAL",
            "ABNORMAL_DAYS_MAX",
            "ABNORMAL_DAYS_AND_AMOUNTS",
            "TOP_FEATURE_INCIDENTS",
            "SERVER_ID",
            "REGION",
            "MARKET",
            "RECOMMENDED_ACTION",
        ]
        ecgi_summary[[c for c in cols if c in ecgi_summary.columns]].to_csv(out_dir / "cesmlc_v71_abnormal_days_amounts_by_ecgi.csv", index=False)
    else:
        pd.DataFrame().to_csv(out_dir / "cesmlc_v71_clustered_ecgi_incident_summary_all.csv", index=False)
        pd.DataFrame().to_csv(out_dir / "cesmlc_v71_abnormal_days_amounts_by_ecgi.csv", index=False)

    # Cluster-feature cross tab.
    if not abnormal.empty:
        cluster_feature = (
            abnormal.groupby(["PRIMARY_ANOMALY_CLUSTER", "PRIMARY_ABNORMAL_FEATURE"], dropna=False)
            .agg(
                ROW_COUNT=("ECGI", "size"),
                ECGI_COUNT=("ECGI", "nunique"),
                AVG_RISK=("ANOMALY_RISK_SCORE", "mean"),
                MAX_RISK=("ANOMALY_RISK_SCORE", "max"),
                ABNORMAL_DAYS=("ABNORMAL_DAYS_COUNT", "sum"),
            )
            .reset_index()
            .sort_values(["MAX_RISK", "ECGI_COUNT"], ascending=False)
        )
        cluster_feature.to_csv(out_dir / "cesmlc_v71_cluster_feature_summary.csv", index=False)
    else:
        pd.DataFrame().to_csv(out_dir / "cesmlc_v71_cluster_feature_summary.csv", index=False)

    write_v71_final_report(out_dir, analysis_info, args, ecgi_summary, dataset)
    make_v71_plots(out_dir, analysis_info, args, dataset, ecgi_summary)

    base.log(f"Open V7.1 final report: {out_dir / 'cesmlc_v71_final_report_top100_by_cluster.md'}", indent=1)
    base.log(f"Open V7.1 visual report: {out_dir / 'cesmlc_v71_visual_report.html'}", indent=1)
    base.log(f"Open V7.1 top CSV: {out_dir / 'cesmlc_v71_clustered_ecgi_incident_summary_top.csv'}", indent=1)


