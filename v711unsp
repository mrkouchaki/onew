def _series_num(df: pd.DataFrame, col: str, default: float = 0.0) -> pd.Series:
    if col in df.columns:
        return base.safe_numeric(df[col], default)
    return pd.Series(default, index=df.index, dtype="float64")


def _series_text(df: pd.DataFrame, col: str, default: str = "") -> pd.Series:
    if col in df.columns:
        return df[col].fillna(default).astype(str)
    return pd.Series(default, index=df.index, dtype="object")


def _clean_feature_list(features: Sequence[Any]) -> List[str]:
    return sorted({base.clean_col_name(x) for x in features if str(x).strip()})


def _safe_float(x: Any, default: float = 0.0) -> float:
    try:
        v = float(x)
        return v if math.isfinite(v) else default
    except Exception:
        return default


def _short(v: Any, n: int = 90) -> str:
    try:
        return base.short_value(v, max_len=n)
    except Exception:
        s = "" if pd.isna(v) else str(v)
        return s if len(s) <= n else s[: n - 3] + "..."


def _safe_filename(s: Any, max_len: int = 120) -> str:
    s = str(s or "")
    s = re.sub(r"[^A-Za-z0-9._-]+", "_", s).strip("_")
    return (s[:max_len] or "item")


def _date_str(x: Any) -> str:
    try:
        dt = pd.to_datetime(x, errors="coerce")
        if pd.isna(dt):
            return ""
        return str(dt.date())
    except Exception:
        return ""


def _feature_family(feature: Any) -> str:
    f = base.clean_col_name(feature)
    if f in {"ANTENNALAT", "ANTENNALON"}:
        return "LOCATION"
    if any(t in f for t in ["ORIENTATION", "OPENING", "AZIMUTH", "BEAM", "HORIZONTALRANGE", "RADIUS"]):
        return "RF_COVERAGE"
    if any(t in f for t in ["ALT", "ALTITUDE", "UNCERT"]):
        return "ALTITUDE"
    if f in {"PHYSICALCELLID", "CELLNAME", "CELLTYPE", "GEOTYPE"} or "CELL" in f:
        return "CELL_IDENTITY"
    if "TECH" in f:
        return "TECHNOLOGY"
    return "OTHER"


def _severity_band_from_risk(x: Any) -> str:
    v = _safe_float(x)
    if v >= 85:
        return "CRITICAL"
    if v >= 70:
        return "HIGH"
    if v >= 50:
        return "MEDIUM"
    if v >= 30:
        return "LOW"
    return "LOW_RISK_OR_INFORMATIONAL"


