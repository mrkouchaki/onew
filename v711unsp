SEED_TO_CLUSTER = {
    "AUDIT_PUSH_NOT_APPLIED": "DB_PUSH_NOT_APPLIED",
    "INVALID_LATEST_SOURCE_VALUE": "INVALID_SOURCE_VALUE",
    "FALLBACK_TO_DEFAULT_VALUE": "DEFAULT_FALLBACK",
    "FLUCTUATING_FALLBACK_TO_DEFAULT": "DEFAULT_FALLBACK_FLUCTUATING",
    "LONG_TERM_FALLBACK_TO_DEFAULT": "DEFAULT_FALLBACK_LONG_TERM",
    "REAL_BACK_AND_FORTH_INSTABILITY": "TOGGLING_BACK_AND_FORTH",
    "HIGH_FREQUENCY_DIFFERENT_VALUES": "HIGH_FREQUENCY_MULTI_VALUE",
    "SAME_DAY_SOURCE_CONFLICT": "SAME_DAY_CONFLICT",
    "PERSISTENT_SOURCE_INSTABILITY": "PERSISTENT_SOURCE_INSTABILITY",
    "LATEST_DAY_SOURCE_CHANGE": "LATEST_DAY_SOURCE_CHANGE",
    "SUPPRESSED_NORMAL_STABLE_SOURCE_CHANGE": "LOW_RISK_REGULAR_CHANGE",
    "SUPPRESSED_BULK_OR_REFRESH_PATTERN": "LOW_RISK_BULK_OR_REFRESH",
    "SUPPRESSED_COORDINATED_MULTI_FIELD_CHANGE": "LOW_RISK_COORDINATED_CHANGE",
    "DB_PUSH_CHECK_CANDIDATE_STABLE_SOURCE": "STABLE_DB_MISMATCH_REVIEW",
    "LOW_INFORMATION_STABLE_SOURCE_HISTORY": "STABLE_DB_MISMATCH_REVIEW",
    "LOW_PRIORITY_SOURCE_HISTORY_SIGNAL": "LOW_PRIORITY_HISTORY_SIGNAL",
}

REPORTABLE_CLUSTERS = {
    "DB_PUSH_NOT_APPLIED",
    "INVALID_SOURCE_VALUE",
    "DEFAULT_FALLBACK",
    "DEFAULT_FALLBACK_FLUCTUATING",
    "DEFAULT_FALLBACK_LONG_TERM",
    "TOGGLING_BACK_AND_FORTH",
    "HIGH_FREQUENCY_MULTI_VALUE",
    "SAME_DAY_CONFLICT",
    "PERSISTENT_SOURCE_INSTABILITY",
    "LATEST_DAY_SOURCE_CHANGE",
    "UNSUPERVISED_OUTLIER_WITH_SIGNATURE",
}


def _map_cluster_from_seed(label: Any) -> str:
    return SEED_TO_CLUSTER.get(str(label), "LOW_PRIORITY_HISTORY_SIGNAL")


def apply_v71_anomaly_fusion(dataset: pd.DataFrame, args: argparse.Namespace) -> pd.DataFrame:
    fm = dataset.copy()
    if fm.empty:
        return fm

    fm["PRIMARY_ABNORMAL_FEATURE"] = _series_text(fm, "FEATURE", "")
    fm["PRIMARY_ANOMALY_CLUSTER"] = _series_text(fm, "SEED_LABEL", "").map(_map_cluster_from_seed)

    rule_problem = _series_num(fm, "IS_REPORTABLE_PROBLEM", 0).astype(int) == 1
    low_risk = fm["PRIMARY_ANOMALY_CLUSTER"].str.startswith("LOW_RISK", na=False)
    hold = fm["PRIMARY_ANOMALY_CLUSTER"].isin(["STABLE_DB_MISMATCH_REVIEW", "LOW_PRIORITY_HISTORY_SIGNAL"])
    isof_top = _series_num(fm, "UNSUPERVISED_ISOF_TOP_FLAG", 0).astype(int) == 1
    changed_enough = (
        (_series_num(fm, "SOURCE_CHANGE_DAYS_COUNT", 0) >= int(getattr(args, "unsupervised_min_changed_days", 2)))
        | (_series_num(fm, "DISTINCT_SOURCE_VALUES_30D", 0) >= int(getattr(args, "unsupervised_min_distinct_values", 2)))
        | (_series_num(fm, "SOURCE_SAME_DAY_CONFLICT_DAYS", 0) > 0)
        | (_series_num(fm, "SOURCE_DB_MISMATCH_DAYS", 0) > 0)
    )
    weak_signature = (
        (_series_num(fm, "SEED_RULE_SCORE", 0) >= float(getattr(args, "unsupervised_min_rule_score", 18.0)))
        | (_series_num(fm, "ABNORMAL_DAYS_COUNT", 0) >= int(getattr(args, "unsupervised_min_changed_days", 2)))
        | (_series_num(fm, "INSTABILITY_EVENT_INDEX", 0) >= 5)
    )
    promote_ml = (
        (not getattr(args, "disable_unsupervised_promotions", False))
        and getattr(args, "enable_isolation_forest", False)
    )
    promoted = (~rule_problem) & isof_top & changed_enough & weak_signature & promote_ml

    fm["UNSUPERVISED_PROMOTED_FLAG"] = promoted.astype(int)
    fm.loc[promoted, "PRIMARY_ANOMALY_CLUSTER"] = "UNSUPERVISED_OUTLIER_WITH_SIGNATURE"

    rule_norm = _series_num(fm, "SEED_RULE_SCORE", 0).clip(lower=0, upper=100)
    ml_norm = _series_num(fm, "UNSUPERVISED_ISOF_PERCENTILE", 0).clip(lower=0, upper=100)
    day_norm = _series_num(fm, "ABNORMAL_DAYS_PERCENT", 0).clip(lower=0, upper=100)
    entropy_norm = (100.0 * _series_num(fm, "VALUE_ENTROPY_PROXY", 0) / np.log1p(10)).clip(lower=0, upper=100)

    risk = 0.66 * rule_norm + 0.22 * ml_norm + 0.08 * day_norm + 0.04 * entropy_norm
    risk += 4.0 * _series_num(fm, "LATEST_SOURCE_INVALID_RANGE_FLAG", 0)
    risk += 4.0 * _series_num(fm, "FALLBACK_TO_DEFAULT_VALUE_FLAG", 0)
    risk += 3.0 * _series_num(fm, "SOURCE_SAME_DAY_CONFLICT_FLAG", 0)
    risk += 3.0 * _series_num(fm, "REAL_BACK_AND_FORTH_FLAG", 0)
    risk += 3.0 * _series_num(fm, "HIGH_FREQUENCY_DIFFERENT_VALUES_FLAG", 0)
    risk += 4.0 * promoted.astype(int)
    risk -= 18.0 * low_risk.astype(int)
    risk -= 10.0 * hold.astype(int)
    risk = risk.clip(lower=0, upper=100)

    # Keep low-risk examples low, but not invisible; they are useful for the comparison plots.
    risk = pd.Series(risk, index=fm.index)
    risk.loc[low_risk & ~promoted] = risk.loc[low_risk & ~promoted].clip(upper=35)
    risk.loc[hold & ~promoted] = risk.loc[hold & ~promoted].clip(upper=45)

    fm["ANOMALY_RISK_SCORE"] = risk.round(3)
    fm["ANOMALY_RISK_PERCENTILE"] = base.percentile_rank(fm["ANOMALY_RISK_SCORE"])
    fm["ANOMALY_RISK_BAND"] = fm["ANOMALY_RISK_SCORE"].map(_severity_band_from_risk)
    fm["LOW_RISK_REGULAR_CHANGE_FLAG"] = low_risk.astype(int)

    abnormal_flag = fm["PRIMARY_ANOMALY_CLUSTER"].isin(REPORTABLE_CLUSTERS) | promoted
    # Do not promote weak latest-day-only observations below the report threshold into the top report by default.
    fm["ABNORMAL_FEATURE_FLAG"] = abnormal_flag.astype(int)
    fm.loc[promoted, "IS_REPORTABLE_PROBLEM"] = 1
    fm.loc[promoted, "NEEDS_MANUAL_REVIEW"] = 1
    fm.loc[promoted, "FINAL_TRAINING_LABEL"] = "UNSUPERVISED_OUTLIER_REVIEW"
    fm.loc[promoted, "TRAINING_WEIGHT"] = np.maximum(_series_num(fm, "TRAINING_WEIGHT", 0).loc[promoted], 0.25)

    fm["MODEL_SIGNATURE_AGREEMENT"] = "LOW_RISK_OR_HOLD"
    fm.loc[rule_problem & isof_top, "MODEL_SIGNATURE_AGREEMENT"] = "RULE_AND_ISOF"
    fm.loc[rule_problem & ~isof_top, "MODEL_SIGNATURE_AGREEMENT"] = "RULE_SIGNATURE"
    fm.loc[promoted, "MODEL_SIGNATURE_AGREEMENT"] = "ISOF_PROMOTED_FOR_REVIEW"
    fm.loc[(~rule_problem) & isof_top & ~promoted, "MODEL_SIGNATURE_AGREEMENT"] = "ISOF_ONLY_NOT_PROMOTED"

    fm["SOURCE_FEATURE_EVIDENCE_SUMMARY_V71"] = (
        fm["PRIMARY_ABNORMAL_FEATURE"].astype(str)
        + " | cluster="
        + fm["PRIMARY_ANOMALY_CLUSTER"].astype(str)
        + " | abnormal="
        + fm["ABNORMAL_DAYS_PRESENTABLE"].astype(str)
        + " | amount="
        + fm["ABNORMAL_AMOUNT_PRESENTABLE"].astype(str)
        + " | rule_score="
        + _series_num(fm, "SEED_RULE_SCORE", 0).round(1).astype(str)
        + " | isof_pct="
        + _series_num(fm, "UNSUPERVISED_ISOF_PERCENTILE", 0).round(1).astype(str)
        + " | risk="
        + fm["ANOMALY_RISK_SCORE"].round(1).astype(str)
    )
    return fm


