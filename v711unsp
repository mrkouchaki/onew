def _md_escape(x: Any) -> str:
    s = "" if pd.isna(x) else str(x)
    s = s.replace("|", "\\|").replace("\n", " ")
    return s


def _md_table(df: pd.DataFrame, cols: List[Tuple[str, str]], max_rows: Optional[int] = None) -> List[str]:
    if df.empty:
        return ["_No rows._", ""]
    d = df.copy()
    if max_rows is not None:
        d = d.head(max_rows)
    headers = [h for _, h in cols]
    lines = ["| " + " | ".join(headers) + " |", "| " + " | ".join(["---"] * len(headers)) + " |"]
    for _, r in d.iterrows():
        vals = [_md_escape(r.get(c, "")) for c, _ in cols]
        lines.append("| " + " | ".join(vals) + " |")
    lines.append("")
    return lines


def write_v71_final_report(out_dir: Path, analysis_info: Dict[str, Any], args: argparse.Namespace, ecgi_summary: pd.DataFrame, dataset: pd.DataFrame) -> None:
    top_n = int(getattr(args, "final_report_top_n", 100))
    cluster_n = int(getattr(args, "cluster_report_top_n", 30))
