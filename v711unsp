def add_v71_engineered_features(dataset: pd.DataFrame) -> pd.DataFrame:
    fm = dataset.copy()
    if fm.empty:
        return fm

    analysis_days = _series_num(fm, "ANALYSIS_DAYS", 30).replace(0, 30).clip(lower=1)
    observed_days = _series_num(fm, "OBSERVED_DAYS_FOR_FEATURE", 0).replace(0, np.nan)
    change_days = _series_num(fm, "SOURCE_CHANGE_DAYS_COUNT", 0)
    change_count = _series_num(fm, "SOURCE_CHANGE_COUNT", 0)
    conflict_days = _series_num(fm, "SOURCE_SAME_DAY_CONFLICT_DAYS", 0)
    db_mismatch_days = _series_num(fm, "SOURCE_DB_MISMATCH_DAYS", 0)
    distinct_values = _series_num(fm, "DISTINCT_SOURCE_VALUES_30D", 0)
    mode_share = _series_num(fm, "MODE_SOURCE_VALUE_SHARE_PERCENT", 100).clip(lower=0, upper=100)
    days_since_last = _series_num(fm, "DAYS_SINCE_LAST_SOURCE_CHANGE", 9999)
    latest_value_days = _series_num(fm, "LATEST_SOURCE_VALUE_DAYS", 0)
    latest_default = _series_num(fm, "LATEST_SOURCE_IS_DEFAULT_FLAG", 0)
    invalid_flag = _series_num(fm, "LATEST_SOURCE_INVALID_RANGE_FLAG", 0)

    fm["ABNORMAL_FEATURE_FAMILY"] = _series_text(fm, "FEATURE", "").map(_feature_family)
    fm["CHANGE_DENSITY"] = (change_days / observed_days).replace([np.inf, -np.inf], np.nan).fillna(0).clip(lower=0, upper=1)
    fm["EVENT_DENSITY"] = (change_count / observed_days).replace([np.inf, -np.inf], np.nan).fillna(0).clip(lower=0)
    fm["VALUE_ENTROPY_PROXY"] = np.log1p(distinct_values.clip(lower=0)) * (1.0 - mode_share / 100.0)
    fm["MODE_IMPURITY_PERCENT"] = (100.0 - mode_share).clip(lower=0, upper=100)
    fm["RECENCY_PRESSURE"] = ((analysis_days - days_since_last.clip(upper=analysis_days)) / analysis_days).clip(lower=0, upper=1)
    fm["INSTABILITY_EVENT_INDEX"] = (
        2.2 * change_days
        + 1.1 * change_count
        + 2.5 * conflict_days
        + 1.4 * db_mismatch_days
        + 1.8 * _series_num(fm, "SOURCE_A_B_A_REVERT_COUNT", 0)
        + 1.8 * _series_num(fm, "SOURCE_REVERSE_TRANSITION_COUNT", 0)
        + 1.2 * distinct_values
    )

    latest_num = pd.to_numeric(_series_text(fm, "LATEST_SOURCE_VALUE", ""), errors="coerce")
    prev_num = pd.to_numeric(_series_text(fm, "PREVIOUS_NONLATEST_SOURCE_VALUE", ""), errors="coerce")
    mode_num = pd.to_numeric(_series_text(fm, "MODE_SOURCE_VALUE", ""), errors="coerce")
    first_num = pd.to_numeric(_series_text(fm, "FIRST_SOURCE_VALUE", ""), errors="coerce")
    db_num = pd.to_numeric(_series_text(fm, "LATEST_DB_VALUE", ""), errors="coerce")

    fm["LATEST_PREVIOUS_NUMERIC_DELTA"] = (latest_num - prev_num).abs().replace([np.inf, -np.inf], np.nan).fillna(0)
    fm["LATEST_MODE_NUMERIC_DELTA"] = (latest_num - mode_num).abs().replace([np.inf, -np.inf], np.nan).fillna(0)
    fm["LATEST_FIRST_NUMERIC_DELTA"] = (latest_num - first_num).abs().replace([np.inf, -np.inf], np.nan).fillna(0)
    fm["SOURCE_DB_NUMERIC_DELTA"] = (latest_num - db_num).abs().replace([np.inf, -np.inf], np.nan).fillna(0)
    fm["ABNORMAL_AMOUNT_NUMERIC"] = fm[
        ["LATEST_PREVIOUS_NUMERIC_DELTA", "LATEST_MODE_NUMERIC_DELTA", "LATEST_FIRST_NUMERIC_DELTA", "SOURCE_DB_NUMERIC_DELTA"]
    ].max(axis=1)

    fallback_duration_days = np.where(latest_default > 0, latest_value_days, 0)
    fm["ABNORMAL_DAYS_COUNT"] = np.maximum.reduce(
        [
            change_days.fillna(0).to_numpy(dtype=float),
            conflict_days.fillna(0).to_numpy(dtype=float),
            db_mismatch_days.fillna(0).to_numpy(dtype=float),
            fallback_duration_days.astype(float),
            np.where(invalid_flag > 0, observed_days.fillna(analysis_days).to_numpy(dtype=float), 0.0),
        ]
    )
    fm["ABNORMAL_DAYS_PERCENT"] = (100.0 * fm["ABNORMAL_DAYS_COUNT"] / analysis_days).replace([np.inf, -np.inf], np.nan).fillna(0).clip(0, 100)
    fm["ABNORMAL_DAYS_PRESENTABLE"] = fm["ABNORMAL_DAYS_COUNT"].round(0).astype(int).astype(str) + "/" + analysis_days.round(0).astype(int).astype(str) + " days"

    numeric_mask = fm["ABNORMAL_AMOUNT_NUMERIC"] > 0
    fm["ABNORMAL_AMOUNT_PRESENTABLE"] = (
        "distinct="
        + distinct_values.round(0).astype(int).astype(str)
        + "; changes="
        + change_count.round(0).astype(int).astype(str)
    )
    fm.loc[numeric_mask, "ABNORMAL_AMOUNT_PRESENTABLE"] = "max Î=" + fm.loc[numeric_mask, "ABNORMAL_AMOUNT_NUMERIC"].map(lambda x: f"{x:.6g}")

    # A compact explainability field that is safe for CSV and markdown.
    fm["FEATURE_ABNORMALITY_BRIEF"] = (
        _series_text(fm, "FEATURE", "")
        + ": "
        + fm["ABNORMAL_DAYS_PRESENTABLE"]
        + ", "
        + fm["ABNORMAL_AMOUNT_PRESENTABLE"]
        + ", score="
        + _series_num(fm, "SEED_RULE_SCORE", 0).round(1).astype(str)
    )
    return fm


def _numeric_ml_columns(fm: pd.DataFrame) -> List[str]:
    exclude_tokens = [
        "LABEL",
        "VALUE",
        "DATE",
        "SUMMARY",
        "ACTION",
        "REASON",
        "SOURCE_FILE",
        "SOURCE_NAME",
        "REFERENCE_COLUMN",
        "REFERENCE_KEY",
        "ECGI",
        "CELLNAME",
        "MARKET",
        "REGION",
        "FEATURE",
        "CLUSTER",
        "PRESENTABLE",
        "BRIEF",
        "TEXT",
        "PATH",
    ]
    numeric_cols: List[str] = []
    for c in fm.columns:
        cu = str(c).upper()
        if any(tok in cu for tok in exclude_tokens):
            continue
        if pd.api.types.is_numeric_dtype(fm[c]):
            numeric_cols.append(c)
        else:
            maybe = pd.to_numeric(fm[c], errors="coerce")
            if len(maybe) and maybe.notna().mean() > 0.98:
                fm[c] = maybe
                numeric_cols.append(c)
    return sorted(set(numeric_cols))


def _parse_contamination(x: Any) -> Any:
    s = str(x).strip().lower()
    if s == "auto":
        return "auto"
    try:
        v = float(s)
        if 0 < v < 0.5:
            return v
    except Exception:
        pass
    return "auto"


def _fit_score_isof(
    fm: pd.DataFrame,
    numeric_cols: List[str],
    args: argparse.Namespace,
    fit_sample: int,
    row_index: Optional[pd.Index] = None,
) -> np.ndarray:
    from sklearn.ensemble import IsolationForest
    from sklearn.impute import SimpleImputer
    from sklearn.preprocessing import RobustScaler

    if row_index is None:
        row_index = fm.index
    sub = fm.loc[row_index, numeric_cols].replace([np.inf, -np.inf], np.nan)
    if len(sub) == 0:
        return np.array([], dtype=float)

    if fit_sample and len(sub) > int(fit_sample):
        fit_df = sub.sample(n=int(fit_sample), random_state=int(getattr(args, "random_state", 42)))
    else:
        fit_df = sub

    imputer = SimpleImputer(strategy="median")
    scaler = RobustScaler(quantile_range=(10, 90))
    X_fit = imputer.fit_transform(fit_df)
    X_fit = scaler.fit_transform(X_fit)

    model = IsolationForest(
        n_estimators=int(getattr(args, "isolation_n_estimators", 200)),
        contamination=_parse_contamination(getattr(args, "isolation_contamination", "auto")),
        random_state=int(getattr(args, "random_state", 42)),
        n_jobs=-1,
        bootstrap=False,
    )
    model.fit(X_fit)

    batch_size = max(1000, int(getattr(args, "isolation_score_batch_size", 250000)))
    scores = np.empty(len(sub), dtype="float64")
    for start in range(0, len(sub), batch_size):
        end = min(start + batch_size, len(sub))
        X = imputer.transform(sub.iloc[start:end])
        X = scaler.transform(X)
        scores[start:end] = -model.score_samples(X)
    return scores


def add_isolation_forest_scores(dataset: pd.DataFrame, args: argparse.Namespace) -> pd.DataFrame:
    fm = dataset.copy()
    fm["UNSUPERVISED_GLOBAL_ISOF_SCORE"] = np.nan
    fm["UNSUPERVISED_GLOBAL_ISOF_PERCENTILE"] = np.nan
    fm["UNSUPERVISED_FEATURE_ISOF_SCORE"] = np.nan
    fm["UNSUPERVISED_FEATURE_ISOF_PERCENTILE"] = np.nan
    fm["UNSUPERVISED_ISOF_SCORE"] = np.nan
    fm["UNSUPERVISED_ISOF_PERCENTILE"] = np.nan
    fm["UNSUPERVISED_ISOF_TOP_FLAG"] = 0

    if not getattr(args, "enable_isolation_forest", False) or fm.empty:
        return fm

    try:
        # Import here so non-ML runs do not require sklearn.
        import sklearn  # noqa: F401
    except Exception as exc:
        base.log(f"IsolationForest skipped because scikit-learn is unavailable: {exc}", indent=1)
        return fm

    numeric_cols = _numeric_ml_columns(fm)
    if len(numeric_cols) < 6 or len(fm) < 50:
        base.log("IsolationForest skipped: not enough numeric features/rows after V7.1 feature engineering.", indent=1)
        return fm

    base.log(
        f"V7.1 IsolationForest global scoring: rows={len(fm):,}, numeric_features={len(numeric_cols):,}, fit_sample={int(getattr(args, 'isolation_fit_sample', 300000)):,}",
        indent=1,
    )
    try:
        global_scores = _fit_score_isof(fm, numeric_cols, args, int(getattr(args, "isolation_fit_sample", 300000)))
        fm["UNSUPERVISED_GLOBAL_ISOF_SCORE"] = global_scores
        fm["UNSUPERVISED_GLOBAL_ISOF_PERCENTILE"] = base.percentile_rank(pd.Series(global_scores, index=fm.index))
    except Exception as exc:
        base.log(f"Global IsolationForest failed; continuing with rules only. Error: {exc}", indent=1)
        base.log(traceback.format_exc().splitlines()[-1], indent=2)

    if not getattr(args, "disable_featurewise_isolation", False) and "FEATURE" in fm.columns:
        min_rows = int(getattr(args, "featurewise_isolation_min_rows", 2000))
        fit_sample = int(getattr(args, "featurewise_isolation_fit_sample", 100000))
        feature_groups = fm.groupby("FEATURE", sort=False).groups
        base.log(f"V7.1 feature-wise IsolationForest enabled for groups with at least {min_rows:,} rows", indent=1)
        feature_done = 0
        for feature, idx in feature_groups.items():
            idx = pd.Index(idx)
            if len(idx) < min_rows:
                continue
            try:
                scores = _fit_score_isof(fm, numeric_cols, args, fit_sample, row_index=idx)
                fm.loc[idx, "UNSUPERVISED_FEATURE_ISOF_SCORE"] = scores
                fm.loc[idx, "UNSUPERVISED_FEATURE_ISOF_PERCENTILE"] = base.percentile_rank(pd.Series(scores, index=idx)).values
                feature_done += 1
            except Exception as exc:
                base.log(f"Feature-wise IsolationForest skipped for {feature}: {exc}", indent=2)
        base.log(f"Feature-wise IsolationForest completed for {feature_done:,} feature group(s)", indent=1)

    global_pct = _series_num(fm, "UNSUPERVISED_GLOBAL_ISOF_PERCENTILE", 0)
    feature_pct = _series_num(fm, "UNSUPERVISED_FEATURE_ISOF_PERCENTILE", 0)
    combined_pct = np.maximum(global_pct.fillna(0).to_numpy(dtype=float), feature_pct.fillna(0).to_numpy(dtype=float))
    fm["UNSUPERVISED_ISOF_PERCENTILE"] = combined_pct
    fm["UNSUPERVISED_ISOF_SCORE"] = combined_pct / 100.0
    top_threshold = float(getattr(args, "isolation_top_percentile", 98.0))
    fm["UNSUPERVISED_ISOF_TOP_FLAG"] = (fm["UNSUPERVISED_ISOF_PERCENTILE"] >= top_threshold).astype(int)

    # Keep original rule score, then add only a controlled ML bump. The final risk score is computed separately.
    fm["SEED_RULE_SCORE_BASE"] = _series_num(fm, "SEED_RULE_SCORE", 0)
    bump = float(getattr(args, "isolation_score_weight", 0.10)) * (fm["UNSUPERVISED_ISOF_PERCENTILE"].fillna(0) / 100.0) * 20.0
    fm["SEED_RULE_SCORE"] = (fm["SEED_RULE_SCORE_BASE"] + bump).clip(lower=0)
    fm["SEED_RULE_PERCENTILE"] = base.percentile_rank(fm["SEED_RULE_SCORE"])
    base.log(f"V7.1 IsolationForest scoring added. Top-flag rows: {int(fm['UNSUPERVISED_ISOF_TOP_FLAG'].sum()):,}", indent=1)
    return fm


