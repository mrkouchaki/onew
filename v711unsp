def _selected_pairs_for_stories(dataset: pd.DataFrame, story_count: int) -> Tuple[List[Dict[str, Any]], List[Tuple[str, str]]]:
    if dataset.empty:
        return [], []
    d = dataset.copy()
    for c in ["ABNORMAL_FEATURE_FLAG", "LOW_RISK_REGULAR_CHANGE_FLAG", "SOURCE_CHANGE_COUNT", "ANOMALY_RISK_SCORE"]:
        if c not in d.columns:
            d[c] = 0
        d[c] = base.safe_numeric(d[c])

    abnormal_pool = d[(d["ABNORMAL_FEATURE_FLAG"] == 1) & (d["SOURCE_CHANGE_COUNT"] > 0)].sort_values("ANOMALY_RISK_SCORE", ascending=False)
    if abnormal_pool.empty:
        abnormal_pool = d[d["ABNORMAL_FEATURE_FLAG"] == 1].sort_values("ANOMALY_RISK_SCORE", ascending=False)
    low_pool_all = d[(d["ABNORMAL_FEATURE_FLAG"] == 0) & (d["SOURCE_CHANGE_COUNT"] > 0)].copy()
    if low_pool_all.empty:
        low_pool_all = d[d["ABNORMAL_FEATURE_FLAG"] == 0].copy()
    low_pool_all = low_pool_all.sort_values("ANOMALY_RISK_SCORE", ascending=True)

    stories: List[Dict[str, Any]] = []
    pairs: List[Tuple[str, str]] = []
    used_abnormal: set = set()
    used_low: set = set()

    for _, ar in abnormal_pool.iterrows():
        if len(stories) >= story_count:
            break
        akey = (str(ar.get("ECGI", "")), str(ar.get("FEATURE", "")))
        if akey in used_abnormal:
            continue
        same_feature = low_pool_all[(low_pool_all["FEATURE"] == ar.get("FEATURE")) & (low_pool_all["ECGI"] != ar.get("ECGI"))]
        if same_feature.empty:
            same_feature = low_pool_all[low_pool_all["ECGI"] != ar.get("ECGI")]
        if same_feature.empty:
            continue
        lr = same_feature.iloc[0]
        lkey = (str(lr.get("ECGI", "")), str(lr.get("FEATURE", "")))
        used_abnormal.add(akey)
        used_low.add(lkey)
        stories.append({"abnormal": ar.to_dict(), "low_risk": lr.to_dict()})
        pairs.append(akey)
        pairs.append(lkey)

    # Multi-feature ECGI story pairs: top ECGIs with several abnormal features.
    top_ecgis = (
        d[d["ABNORMAL_FEATURE_FLAG"] == 1]
        .sort_values("ANOMALY_RISK_SCORE", ascending=False)
        .groupby("ECGI")
        .head(3)
        .groupby("ECGI")
        .filter(lambda x: len(x) >= 2)
        .groupby("ECGI")
        .head(3)
    )
    for _, r in top_ecgis.head(max(0, story_count * 3)).iterrows():
        pairs.append((str(r.get("ECGI", "")), str(r.get("FEATURE", ""))))

    pairs = [(e, f) for e, f in pairs if e and f]
    pairs = list(dict.fromkeys(pairs))
    return stories, pairs


def _query_daily_history_for_pairs(
    input_path: Path,
    analysis_info: Dict[str, Any],
    args: argparse.Namespace,
    pairs: List[Tuple[str, str]],
) -> pd.DataFrame:
    if not pairs:
        return pd.DataFrame(columns=["LOAD_DATE", "ECGI", "FEATURE", "SOURCE_VALUE"])
    header_cols, colmap = base.read_header(input_path)
    date_col = base.first_existing(header_cols, base.DATE_CANDIDATES)
    if not date_col:
        return pd.DataFrame(columns=["LOAD_DATE", "ECGI", "FEATURE", "SOURCE_VALUE"])
    selected_features = _clean_feature_list([f for _, f in pairs])
    selected_features = [f for f in selected_features if f in colmap]
    selected_ecgis = sorted({base.normalize_key_value(e) for e, _ in pairs if base.normalize_key_value(e)})
    if not selected_features or not selected_ecgis:
        return pd.DataFrame(columns=["LOAD_DATE", "ECGI", "FEATURE", "SOURCE_VALUE"])

    con = base.open_duckdb(
        None,
        int(getattr(args, "threads", 1)),
        getattr(args, "memory_limit", "6GB"),
        duckdb_temp_dir=Path(getattr(args, "duckdb_temp_dir", "")) if getattr(args, "duckdb_temp_dir", None) else None,
    )
    try:
        file_sql = base.sql_path(input_path)
        date_expr = base.date_parse_expr(colmap[date_col])
        ecgi_sql = base.ecgi_expr_from_columns(colmap)
        feature_selects = [f"{base.feature_norm_expr(colmap[f], f, int(getattr(args, 'latlon_decimals', 5)))} AS {base.quote_ident(f)}" for f in selected_features]
        ecgi_list_sql = ", ".join(base.sql_string(e) for e in selected_ecgis)
        raw_select = ",\n                ".join([f"{date_expr} AS LOAD_DATE", f"{ecgi_sql} AS ECGI", *feature_selects])
        union_parts = []
        for f in selected_features:
            fq = base.quote_ident(f)
            union_parts.append(f"SELECT LOAD_DATE, ECGI, {base.sql_string(f)} AS FEATURE, {fq} AS SOURCE_VALUE FROM filtered WHERE {fq} IS NOT NULL")
        sql = f"""
        WITH raw AS (
            SELECT
                {raw_select}
            FROM read_csv_auto({file_sql}, HEADER=TRUE, ALL_VARCHAR=TRUE, SAMPLE_SIZE=100000, IGNORE_ERRORS=TRUE)
        ), filtered AS (
            SELECT *
            FROM raw
            WHERE LOAD_DATE BETWEEN DATE {base.sql_string(str(analysis_info.get('window_start_date')))} AND DATE {base.sql_string(str(analysis_info.get('window_end_date')))}
              AND ECGI IN ({ecgi_list_sql})
        )
        {" UNION ALL ".join(union_parts)}
        """
        hist = con.execute(sql).fetchdf()
    finally:
        try:
            con.close()
        except Exception:
            pass
    if hist.empty:
        return hist
    hist.columns = [base.clean_col_name(c) for c in hist.columns]
    hist["LOAD_DATE"] = pd.to_datetime(hist["LOAD_DATE"], errors="coerce")
    hist["ECGI"] = hist["ECGI"].map(base.normalize_key_value)
    hist["FEATURE"] = hist["FEATURE"].map(base.clean_col_name)
    hist["SOURCE_VALUE"] = hist["SOURCE_VALUE"].map(base.normalize_value_text)
    return hist.sort_values(["FEATURE", "ECGI", "LOAD_DATE"]).reset_index(drop=True)


def _plot_value_series(ax: Any, df: pd.DataFrame, label_col: str, title: str) -> None:
    # Common categorical mapping when the values are not mostly numeric.
    values = df["SOURCE_VALUE"].astype(str)
    nums = pd.to_numeric(values, errors="coerce")
    numeric = nums.notna().mean() >= 0.80 if len(nums) else False
    if numeric:
        df = df.copy()
        df["Y"] = nums
        for label, g in df.groupby(label_col):
            ax.step(g["LOAD_DATE"], g["Y"], where="post", marker="o", label=str(label))
        ax.set_ylabel("source value")
    else:
        cats = list(dict.fromkeys(values.tolist()))
        cat_map = {v: i for i, v in enumerate(cats)}
        df = df.copy()
        df["Y"] = df["SOURCE_VALUE"].map(cat_map)
        for label, g in df.groupby(label_col):
            ax.step(g["LOAD_DATE"], g["Y"], where="post", marker="o", label=str(label))
        ax.set_yticks(list(cat_map.values()))
        ax.set_yticklabels([_short(k, 40) for k in cat_map.keys()])
        ax.set_ylabel("categorical value")
    ax.set_title(title)
    ax.grid(True, alpha=0.25)
    ax.legend(fontsize=8)


def _plot_story_comparison(story: Dict[str, Any], hist: pd.DataFrame, out_file: Path) -> bool:
    import matplotlib

    matplotlib.use("Agg")
    import matplotlib.pyplot as plt

    ar = story["abnormal"]
    lr = story["low_risk"]
    a_ecgi = base.normalize_key_value(ar.get("ECGI", ""))
    l_ecgi = base.normalize_key_value(lr.get("ECGI", ""))
    a_feature = base.clean_col_name(ar.get("FEATURE", ""))
    l_feature = base.clean_col_name(lr.get("FEATURE", ""))
    if a_feature != l_feature:
        # The strongest story is same-feature. If unavailable, still plot side-by-side in one chart label.
        feature_filter = [a_feature, l_feature]
    else:
        feature_filter = [a_feature]
    sub = hist[(hist["ECGI"].isin([a_ecgi, l_ecgi])) & (hist["FEATURE"].isin(feature_filter))].copy()
    if sub.empty:
        return False
    sub["SERIES"] = sub.apply(lambda r: f"{'abnormal' if r.ECGI == a_ecgi else 'low-risk'} | {r.ECGI} | {r.FEATURE}", axis=1)

    fig, ax = plt.subplots(figsize=(13, 6))
    title = (
        f"V7.1 comparison story: abnormal vs regular low-risk change\n"
        f"Abnormal: {_short(ar.get('ECGI_LABEL', a_ecgi), 35)} / {a_feature} / {ar.get('PRIMARY_ANOMALY_CLUSTER','')} / risk={_safe_float(ar.get('ANOMALY_RISK_SCORE',0)):.1f}   "
        f"Low-risk: {_short(lr.get('ECGI_LABEL', l_ecgi), 35)} / {l_feature} / {lr.get('PRIMARY_ANOMALY_CLUSTER','')} / risk={_safe_float(lr.get('ANOMALY_RISK_SCORE',0)):.1f}"
    )
    _plot_value_series(ax, sub, "SERIES", title)
    fig.autofmt_xdate()
    fig.tight_layout()
    fig.savefig(out_file, dpi=160, bbox_inches="tight")
    plt.close(fig)
    return True


def _plot_multifeature_ecgi(ecgi: str, rows: pd.DataFrame, hist: pd.DataFrame, out_file: Path) -> bool:
    import matplotlib

    matplotlib.use("Agg")
    import matplotlib.pyplot as plt

    features = rows.sort_values("ANOMALY_RISK_SCORE", ascending=False)["FEATURE"].drop_duplicates().head(3).tolist()
    sub = hist[(hist["ECGI"] == base.normalize_key_value(ecgi)) & (hist["FEATURE"].isin(features))].copy()
    if sub.empty:
        return False
    fig, axes = plt.subplots(len(features), 1, figsize=(13, 3.4 * len(features)), sharex=True)
    if len(features) == 1:
        axes = [axes]
    for ax, feature in zip(axes, features):
        g = sub[sub["FEATURE"] == feature].copy()
        meta = rows[rows["FEATURE"] == feature].sort_values("ANOMALY_RISK_SCORE", ascending=False).head(1)
        cluster = meta["PRIMARY_ANOMALY_CLUSTER"].iloc[0] if not meta.empty and "PRIMARY_ANOMALY_CLUSTER" in meta else ""
        risk = _safe_float(meta["ANOMALY_RISK_SCORE"].iloc[0]) if not meta.empty and "ANOMALY_RISK_SCORE" in meta else 0
        g["SERIES"] = f"{feature} | {cluster} | risk={risk:.1f}"
        _plot_value_series(ax, g, "SERIES", f"{ecgi} - {feature}")
    fig.suptitle(f"V7.1 multi-feature ECGI story: {ecgi}", y=1.02, fontsize=14)
    fig.autofmt_xdate()
    fig.tight_layout()
    fig.savefig(out_file, dpi=160, bbox_inches="tight")
    plt.close(fig)
    return True


