def patch_base_module() -> None:
    base.SCRIPT_VERSION = SCRIPT_VERSION
    base.manifest_hash = manifest_hash
    base.cache_manifest_for_run = cache_manifest_for_run
    base.load_history_cache_if_valid = load_history_cache_if_valid
    base.save_history_cache = save_history_cache
    base.add_isolation_forest_scores = add_isolation_forest_scores
    base.build_training_dataset = build_training_dataset
    base.build_ecgi_summary = build_ecgi_summary
    base.write_outputs = write_outputs
    base.write_manual_markdown = write_manual_markdown
    base.parse_args = parse_args


def main() -> int:
    patch_base_module()
    return base.main()


