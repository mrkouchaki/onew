    csv_path = out_dir / "cesmlc_v71_final_report_top100.csv"

    lines: List[str] = []
    lines.append("# CESMLC V7.1 Final Anomaly Report")
    lines.append("")
    lines.append(f"- **Script version**: `{SCRIPT_VERSION}`")
    lines.append(f"- **Input**: `{analysis_info.get('input_file','')}`")
    lines.append(f"- **Window**: `{analysis_info.get('window_start_date','')}` to `{analysis_info.get('window_end_date','')}`")
    lines.append(f"- **Candidate date**: `{analysis_info.get('candidate_date','')}`")
    lines.append(f"- **Candidate ECGIs**: `{analysis_info.get('latest_db_mismatch_candidate_ecgis','')}`")
    lines.append(f"- **Report threshold**: `{getattr(args, 'min_report_score', '')}`")
    lines.append("")

    if ecgi_summary.empty:
        lines.append("No ECGI incidents passed the V7.1 report threshold.")
        report_path.write_text("\n".join(lines), encoding="utf-8")
        pd.DataFrame().to_csv(csv_path, index=False)
        return

    top100 = ecgi_summary.head(top_n).copy()
    top100.to_csv(csv_path, index=False)

    lines.append("## Executive cluster summary")
    lines.append("")
    cluster_summary = (
        ecgi_summary.groupby("PRIMARY_ANOMALY_CLUSTER", dropna=False)
        .agg(
            ECGI_COUNT=("ECGI", "nunique"),
            AVG_RISK=("ECGI_ANOMALY_RISK_SCORE", "mean"),
            MAX_RISK=("ECGI_ANOMALY_RISK_SCORE", "max"),
            ABNORMAL_FEATURES=("ABNORMAL_FEATURE_COUNT", "sum"),
            ABNORMAL_DAYS=("ABNORMAL_DAYS_TOTAL", "sum"),
        )
        .reset_index()
        .sort_values(["MAX_RISK", "ECGI_COUNT"], ascending=False)
    )
    cluster_summary["AVG_RISK"] = cluster_summary["AVG_RISK"].round(1)
    cluster_summary["MAX_RISK"] = cluster_summary["MAX_RISK"].round(1)
    lines += _md_table(
        cluster_summary,
        [
            ("PRIMARY_ANOMALY_CLUSTER", "primary_anomaly_cluster"),
            ("ECGI_COUNT", "ECGIs"),
            ("ABNORMAL_FEATURES", "abnormal features"),
            ("ABNORMAL_DAYS", "abnormal feature-days"),
            ("AVG_RISK", "avg risk"),
            ("MAX_RISK", "max risk"),
        ],
    )

    lines.append(f"## Top {top_n} overall")
    lines.append("")
    display = top100.copy()
    display["risk"] = display["ECGI_ANOMALY_RISK_SCORE"].round(1)
    lines += _md_table(
        display,
        [
            ("INCIDENT_RANK", "rank"),
            ("ECGI_LABEL", "ECGI"),
            ("PRIMARY_ANOMALY_CLUSTER", "primary_anomaly_cluster"),
            ("PRIMARY_ABNORMAL_FEATURE", "primary_abnormal_feature"),
            ("risk", "risk"),
            ("ABNORMAL_DAYS_AND_AMOUNTS", "abnormal days / amounts"),
            ("MODEL_SIGNATURE_AGREEMENT", "model agreement"),
            ("SERVER_ID", "server"),
            ("MARKET", "market"),
        ],
        max_rows=top_n,
    )

    cluster_order = cluster_summary["PRIMARY_ANOMALY_CLUSTER"].tolist()
    for cluster in cluster_order:
        cdf = ecgi_summary[ecgi_summary["PRIMARY_ANOMALY_CLUSTER"].fillna("") == cluster].sort_values("ECGI_ANOMALY_RISK_SCORE", ascending=False)
        if cdf.empty:
            continue
        lines.append(f"## Top {cluster_n} for primary_anomaly_cluster = `{cluster}`")
        lines.append("")
        feature_summary = (
            cdf.groupby("PRIMARY_ABNORMAL_FEATURE", dropna=False)
            .agg(ECGI_COUNT=("ECGI", "nunique"), MAX_RISK=("ECGI_ANOMALY_RISK_SCORE", "max"), ABNORMAL_DAYS=("ABNORMAL_DAYS_TOTAL", "sum"))
            .reset_index()
            .sort_values(["MAX_RISK", "ECGI_COUNT"], ascending=False)
        )
        feature_summary["MAX_RISK"] = feature_summary["MAX_RISK"].round(1)
        lines.append("**Grouped by primary_abnormal_feature:**")
        lines.append("")
        lines += _md_table(
            feature_summary.head(12),
            [
                ("PRIMARY_ABNORMAL_FEATURE", "primary_abnormal_feature"),
                ("ECGI_COUNT", "ECGIs"),
                ("ABNORMAL_DAYS", "abnormal feature-days"),
                ("MAX_RISK", "max risk"),
            ],
        )
        lines += _md_table(
            cdf.assign(risk=cdf["ECGI_ANOMALY_RISK_SCORE"].round(1)),
            [
                ("INCIDENT_RANK", "overall rank"),
                ("ECGI_LABEL", "ECGI"),
                ("PRIMARY_ABNORMAL_FEATURE", "primary_abnormal_feature"),
                ("risk", "risk"),
                ("ABNORMAL_DAYS_AND_AMOUNTS", "abnormal days / amounts"),
                ("TOP_FEATURE_INCIDENTS", "top feature incidents"),
                ("RECOMMENDED_ACTION", "recommended action"),
            ],
            max_rows=cluster_n,
        )

    report_path.write_text("\n".join(lines), encoding="utf-8")
    base.log(f"Wrote V7.1 final markdown report: {report_path}", indent=1)


