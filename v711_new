def manifest_hash(manifest: Dict[str, Any]) -> str:
    comparable = {k: v for k, v in (manifest or {}).items() if not str(k).startswith("_")}
    raw = json.dumps(comparable, sort_keys=True, default=str).encode("utf-8")
    return hashlib.sha256(raw).hexdigest()[:16]


def default_history_cache_dir(out_dir: Path, args: argparse.Namespace) -> Path:
    raw = getattr(args, "history_cache_dir", None)
    return Path(raw).expanduser() if raw else out_dir / "history_cache"


def clean_feature_list(features: Sequence[Any]) -> List[str]:
    return sorted({clean_col_name(x) for x in features if str(x).strip()})


def cache_manifest_for_run(input_path: Path, features: List[str], analysis_info: Dict[str, Any], args: argparse.Namespace) -> Dict[str, Any]:
    p = Path(input_path)
    stat = p.stat() if p.exists() else None
    return {
        "script_family": "cesmlc_source_history_cache_v2",
        "cache_schema_version": "7.1",
        "input_file": str(p),
        "input_file_name": p.name,
        "input_size_bytes": int(stat.st_size) if stat else None,
        "input_mtime": float(stat.st_mtime) if stat else None,
        "requested_days": int(analysis_info.get("requested_days", getattr(args, "days", 30))),
        "window_start_date": analysis_info.get("window_start_date"),
        "window_end_date": analysis_info.get("window_end_date"),
        "candidate_date": analysis_info.get("candidate_date"),
        "features": clean_feature_list(features),
        "latlon_decimals": int(getattr(args, "latlon_decimals", 5)),
        "enable_db_push_check": bool(getattr(args, "enable_db_push_check", False)),
        "server_id_filter": str(analysis_info.get("server_id_filter", "") or "").upper(),
        "_cache_match_mode": getattr(args, "cache_match_mode", "compatible"),
        "_cache_input_identity": getattr(args, "cache_input_identity", "basename"),
    }


def normalize_manifest_for_compare(m: Dict[str, Any]) -> Dict[str, Any]:
    out = dict(m or {})
    if "features" in out:
        out["features"] = clean_feature_list(out.get("features") or [])
    if "server_id_filter" in out:
        out["server_id_filter"] = str(out.get("server_id_filter") or "").upper()
    if "input_file_name" not in out and out.get("input_file"):
        try:
            out["input_file_name"] = Path(str(out["input_file"])).name
        except Exception:
            out["input_file_name"] = ""
    for c in ["requested_days", "latlon_decimals"]:
        if c in out and out[c] is not None:
            try:
                out[c] = int(out[c])
            except Exception:
                pass
    if "enable_db_push_check" in out:
        out["enable_db_push_check"] = bool(out["enable_db_push_check"])
    return out


def cache_semantic_diffs(saved_manifest: Dict[str, Any], expected_manifest: Dict[str, Any]) -> Tuple[bool, List[Dict[str, Any]], List[str]]:
    saved = normalize_manifest_for_compare(saved_manifest)
    expected = normalize_manifest_for_compare(expected_manifest)
    mode = str(expected.get("_cache_match_mode", "compatible")).lower()
    input_identity = str(expected.get("_cache_input_identity", "basename")).lower()

    ignored: List[str] = []
    diffs: List[Dict[str, Any]] = []
    if mode in {"trust_existing", "trust", "unsafe"}:
        return True, [], ["trusted existing cache by --cache-match-mode trust_existing"]

    core_keys = [
        "window_start_date", "window_end_date", "candidate_date", "features",
        "latlon_decimals", "enable_db_push_check", "server_id_filter",
    ]
    if mode == "strict":
        core_keys.insert(0, "requested_days")
    for k in core_keys:
        if saved.get(k) != expected.get(k):
            diffs.append({"key": k, "cached": saved.get(k), "current": expected.get(k)})

    if mode == "strict":
        for k in ["input_file", "input_size_bytes", "input_mtime"]:
            if saved.get(k) != expected.get(k):
                diffs.append({"key": k, "cached": saved.get(k), "current": expected.get(k)})
    elif mode == "compatible":
        if input_identity == "exact" and saved.get("input_file") != expected.get("input_file"):
            diffs.append({"key": "input_file", "cached": saved.get("input_file"), "current": expected.get("input_file")})
        elif input_identity == "basename" and saved.get("input_file_name") != expected.get("input_file_name"):
            diffs.append({"key": "input_file_name", "cached": saved.get("input_file_name"), "current": expected.get("input_file_name")})
        else:
            if input_identity == "none":
                ignored.append("input_file identity ignored")
        ignored.extend(["input_mtime", "input_size_bytes", "script_family/cache_schema_version"])
    elif mode == "loose":
        ignored.extend(["input_file", "input_file_name", "input_mtime", "input_size_bytes", "requested_days", "script_family/cache_schema_version"])
    else:
        diffs.append({"key": "_cache_match_mode", "cached": "n/a", "current": mode})

    return len(diffs) == 0, diffs, ignored


def write_cache_diag(cache_dir: Path, payload: Dict[str, Any]) -> None:
    try:
        cache_dir.mkdir(parents=True, exist_ok=True)
        (cache_dir / "cache_load_diagnostics_v71.json").write_text(json.dumps(payload, indent=2, default=str), encoding="utf-8")
    except Exception:
        pass


def validate_cache_tables(candidates: pd.DataFrame, hist: pd.DataFrame, changes: pd.DataFrame, conflicts: pd.DataFrame) -> Tuple[bool, List[str]]:
    problems: List[str] = []
    for name, df, cols in [
        ("candidate_ecgis.pkl", candidates, ["ECGI"]),
        ("source_feature_history_metrics.pkl", hist, ["ECGI", "FEATURE", "LATEST_SOURCE_VALUE"]),
        ("source_change_events.pkl", changes, ["ECGI", "FEATURE"]),
        ("source_same_day_conflicts.pkl", conflicts, ["ECGI", "FEATURE"]),
    ]:
        if not isinstance(df, pd.DataFrame):
            problems.append(f"{name} is not a pandas DataFrame")
            continue
        missing = [c for c in cols if c not in df.columns]
        if missing:
            problems.append(f"{name} missing columns: {missing}")
    return len(problems) == 0, problems


def load_history_cache_if_valid(
    cache_dir: Path, expected_manifest: Dict[str, Any], force_rebuild: bool = False
) -> Optional[Tuple[pd.DataFrame, pd.DataFrame, pd.DataFrame, pd.DataFrame]]:
    mode = str(expected_manifest.get("_cache_match_mode", "compatible"))
    if force_rebuild:
        log("History cache rebuild forced by --force-rebuild-history-cache", indent=1)
        write_cache_diag(cache_dir, {"status": "force_rebuild", "expected_manifest": expected_manifest})
        return None

    manifest_path = cache_dir / "history_cache_manifest.json"
    files = [
        cache_dir / "candidate_ecgis.pkl",
        cache_dir / "source_feature_history_metrics.pkl",
        cache_dir / "source_change_events.pkl",
        cache_dir / "source_same_day_conflicts.pkl",
    ]
    diag: Dict[str, Any] = {
        "cache_dir": str(cache_dir),
        "cache_match_mode": mode,
        "expected_hash": manifest_hash(expected_manifest),
        "expected_manifest": expected_manifest,
        "checked_at": time.strftime("%Y-%m-%d %H:%M:%S"),
    }

    missing = [str(p) for p in [manifest_path, *files] if not p.exists()]
    if missing:
        log(f"No reusable history cache yet. Missing {len(missing)} required file(s) in: {cache_dir}", indent=1)
        for p in missing[:8]:
            log(f"missing: {p}", indent=2)
        diag.update({"status": "missing_files", "missing_files": missing})
        write_cache_diag(cache_dir, diag)
        return None

    try:
        payload = json.loads(manifest_path.read_text(encoding="utf-8"))
    except Exception as exc:
        log(f"History cache manifest exists but cannot be read: {exc}", indent=1)
        diag.update({"status": "bad_manifest", "error": str(exc)})
        write_cache_diag(cache_dir, diag)
        return None

    saved_manifest = payload.get("manifest", {}) or {}
    saved_hash = payload.get("manifest_hash")
    expected_hash = manifest_hash(expected_manifest)
    diag.update({"cached_hash": saved_hash, "cached_manifest": saved_manifest})
    exact_hash_match = bool(saved_hash == expected_hash)
    semantic_match, diffs, ignored = cache_semantic_diffs(saved_manifest, expected_manifest)
    diag.update({"exact_hash_match": exact_hash_match, "semantic_match": semantic_match, "diffs": diffs, "ignored_differences": ignored})

    if not exact_hash_match:
        if semantic_match:
            log(f"History cache hash differs but is semantically compatible under --cache-match-mode={mode}; reusing cache.", indent=1)
            if ignored:
                log(f"Ignored cache differences: {', '.join(ignored)}", indent=2)
        else:
            log(f"History cache exists but is not reusable under --cache-match-mode={mode}.", indent=1)
            for d in diffs[:12]:
                log(f"diff {d['key']}: cached={d.get('cached')} current={d.get('current')}", indent=2)
            if any(d.get("key") in {"window_start_date", "window_end_date", "candidate_date", "requested_days"} for d in diffs):
                log("Window/date mismatch: the cache was built for a different history window. Rebuild is normal and prevents missing/incorrect abnormal-day evidence.", indent=2)
            log("Use a matching cache folder/window. Use --cache-match-mode trust_existing only if you intentionally accept stale or incomplete history.", indent=2)
            diag.update({"status": "manifest_mismatch", "explanation": "Cache rejected because semantic identity differs. A 30-day cache is not safely reusable for a 35-day run because abnormal days/plots/evidence would miss the extra days."})
            write_cache_diag(cache_dir, diag)
            return None
    else:
        log(f"History cache hash matches exactly; reusing cache: {cache_dir}", indent=1)

    try:
        candidates = pd.read_pickle(files[0])
        hist = pd.read_pickle(files[1])
        changes = pd.read_pickle(files[2])
        conflicts = pd.read_pickle(files[3])
    except Exception as exc:
        log(f"Could not load history cache pickles; rebuilding. Error: {exc}", indent=1)
        diag.update({"status": "pickle_load_failed", "error": str(exc), "traceback": traceback.format_exc()})
        write_cache_diag(cache_dir, diag)
        return None

    ok, problems = validate_cache_tables(candidates, hist, changes, conflicts)
    if not ok:
        log("History cache tables failed schema validation; rebuilding.", indent=1)
        for p in problems[:8]:
            log(p, indent=2)
        diag.update({"status": "schema_validation_failed", "problems": problems})
        write_cache_diag(cache_dir, diag)
        return None

    log(f"Loaded persistent Phase 1C history cache: {cache_dir}", indent=1)
    log(f"Cached rows: candidates={len(candidates):,}, hist={len(hist):,}, changes={len(changes):,}, conflicts={len(conflicts):,}", indent=1)
    diag.update({"status": "loaded", "rows": {"candidates": len(candidates), "hist": len(hist), "changes": len(changes), "conflicts": len(conflicts)}})
    write_cache_diag(cache_dir, diag)
    return candidates, hist, changes, conflicts


def save_history_cache(cache_dir: Path, manifest: Dict[str, Any], candidates: pd.DataFrame, hist: pd.DataFrame, changes: pd.DataFrame, conflicts: pd.DataFrame) -> None:
    cache_dir.mkdir(parents=True, exist_ok=True)
    mh = manifest_hash(manifest)
    payload = {
        "manifest": {k: v for k, v in manifest.items() if not str(k).startswith("_")},
        "manifest_hash": mh,
        "created_at": time.strftime("%Y-%m-%d %H:%M:%S"),
        "rows": {"candidates": int(len(candidates)), "hist": int(len(hist)), "changes": int(len(changes)), "conflicts": int(len(conflicts))},
        "cache_notes": "V7.1 compatible cache. input_mtime retained for diagnostics but ignored by compatible/loose matching.",
    }
    (cache_dir / "history_cache_manifest.json").write_text(json.dumps(payload, indent=2, default=str), encoding="utf-8")
    (cache_dir / "history_cache_manifest_v71.json").write_text(json.dumps(payload, indent=2, default=str), encoding="utf-8")
    candidates.to_pickle(cache_dir / "candidate_ecgis.pkl")
    hist.to_pickle(cache_dir / "source_feature_history_metrics.pkl")
    changes.to_pickle(cache_dir / "source_change_events.pkl")
    conflicts.to_pickle(cache_dir / "source_same_day_conflicts.pkl")
    log(f"Saved persistent Phase 1C history cache: {cache_dir} (hash={mh})", indent=1)


