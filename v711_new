    p.add_argument("--plot-ecgi-multifeature-count", default=5, type=int)
    p.add_argument("--random-state", default=42, type=int)
    return p.parse_args()


def main() -> int:
    args = parse_args()
    input_path = Path(args.input).expanduser()
    if not input_path.exists():
        raise FileNotFoundError(f"Input file not found: {input_path}")

    out_dir = Path(args.out_dir).expanduser() if args.out_dir else input_path.parent / "cesmlc_v71_standalone_outputs"
    out_dir.mkdir(parents=True, exist_ok=True)
    temp_dir = out_dir / "temp"
    temp_dir.mkdir(parents=True, exist_ok=True)
    duckdb_path = Path(args.duckdb_file).expanduser() if args.duckdb_file else temp_dir / "cesmlc_v71.duckdb"
    duckdb_temp_dir = Path(args.duckdb_temp_dir).expanduser() if args.duckdb_temp_dir else temp_dir / "duckdb_spill"

    header("CESMLC V7.1 STANDALONE HYBRID ANOMALY DETECTOR")
    log(f"Input: {input_path}")
    log(f"Output: {out_dir}")
    log("Candidate gate: latest-day DB_MISMATCH='YES'")
    log("Main evidence: source/current history for candidate ECGIs only")
    log(f"Hybrid model: signature engine + IsolationForest enabled={bool(args.enable_isolation_forest)}")
    log(f"Run settings: days={args.days}, feature_batch_size={args.feature_batch_size}, threads={args.threads}, memory_limit={args.memory_limit}, latlon_decimals={args.latlon_decimals}")

    header_cols, colmap = read_header(input_path)
    date_col = first_existing(header_cols, DATE_CANDIDATES)
    if not date_col:
        raise ValueError(f"No date column found. Tried {DATE_CANDIDATES}. Found: {header_cols}")
    features = detect_features(header_cols, args.include_features, args.exclude_features)
    if not features:
        raise ValueError("No source features selected. Use --include-features with comma-separated column names.")
    missing = [f for f in features if f not in colmap]
    if missing:
        raise ValueError(f"Selected features not found in CSV header: {missing}")
    log(f"Date column: {date_col}")
    log(f"DB_MISMATCH column present: {'DB_MISMATCH' in colmap}")
    log(f"Source features ({len(features)}): {', '.join(features)}")

    rules = load_feature_rules(args.defaults_json)
    con = open_duckdb(duckdb_path, args.threads, args.memory_limit, duckdb_temp_dir=duckdb_temp_dir)
    try:
        analysis_info = create_latest_db_mismatch_candidates(
            con=con,
            input_path=input_path,
            colmap=colmap,
            date_col_clean=date_col,
            days=args.days,
            end_date=args.end_date,
            server_id_filter=args.server_id,
        )
        analysis_info.update({
            "feature_count": int(len(features)),
            "features": ",".join(features),
            "latlon_decimals": int(args.latlon_decimals),
            "enable_db_push_check": bool(args.enable_db_push_check),
            "min_report_score": float(args.min_report_score),
            "min_seed_confidence_for_training": float(args.min_seed_confidence_for_training),
            "reference_compatibility_disabled": bool(args.disable_reference_compatibility),
            "reference_source_dir": args.reference_source_dir or "",
            "long_term_default_days": int(args.long_term_default_days),
            "sitewide_default_feature_threshold": int(args.sitewide_default_feature_threshold),
            "sitewide_default_ratio_threshold": float(args.sitewide_default_ratio_threshold),
            "reuse_history_cache": bool(args.reuse_history_cache),
            "cache_match_mode": args.cache_match_mode,
            "cache_input_identity": args.cache_input_identity,
            "enable_isolation_forest": bool(args.enable_isolation_forest),
        })

        cache_dir = default_history_cache_dir(out_dir, args)
        cache_manifest = cache_manifest_for_run(input_path, features, analysis_info, args)
        cached_tables = None
        if args.reuse_history_cache:
            cached_tables = load_history_cache_if_valid(cache_dir, cache_manifest, force_rebuild=args.force_rebuild_history_cache)
        if cached_tables is not None:
            candidates, hist, changes, conflicts = cached_tables
        else:
            if args.reuse_history_cache:
                log("No valid reusable Phase 1C history cache was found; rebuilding history tables.", indent=1)
            create_candidate_source_history_batched(
                con=con,
                input_path=input_path,
                colmap=colmap,
                date_col_clean=date_col,
                features=features,
                analysis_info=analysis_info,
                latlon_decimals=args.latlon_decimals,
                feature_batch_size=args.feature_batch_size,
                enable_db_push_check=args.enable_db_push_check,
            )
            candidates, hist, changes, conflicts = load_compact_tables(con)
            save_history_cache(cache_dir, cache_manifest, candidates, hist, changes, conflicts)

        dataset = build_training_dataset(candidates, hist, changes, conflicts, rules, analysis_info, args)
        ecgi_summary = build_ecgi_summary(dataset, args.min_report_score)
        issue_summary = build_issue_summary(dataset)

        analysis_info.update({
            "feature_history_metric_rows": int(len(hist)),
            "source_change_event_rows": int(len(changes)),
            "same_day_conflict_rows": int(len(conflicts)),
            "candidate_ecgi_feature_rows": int(len(dataset)),
            "model_ready_training_rows": int(safe_numeric(dataset.get("TRAIN_FOR_MODEL_FLAG", 0)).sum()) if not dataset.empty else 0,
            "reportable_abnormal_feature_rows": int(safe_numeric(dataset.get("ABNORMAL_FEATURE_FLAG", 0)).sum()) if not dataset.empty else 0,
            "reportable_ecgi_incidents": int(len(ecgi_summary)) if not ecgi_summary.empty else 0,
            "low_risk_or_hold_feature_rows": int((safe_numeric(dataset.get("ABNORMAL_FEATURE_FLAG", 0)) == 0).sum()) if not dataset.empty else 0,
        })

        write_outputs(out_dir, analysis_info, args, candidates, dataset, ecgi_summary, issue_summary, changes, conflicts, con, input_path, colmap, date_col)

    finally:
        log("Closing DuckDB connection", indent=1)
        try:
            con.close()
        except Exception:
            pass
        if not args.keep_duckdb:
            log("Removing temporary DuckDB files because --keep-duckdb was not used", indent=1)
            shutil.rmtree(temp_dir, ignore_errors=True)
        else:
            log(f"Keeping temporary DuckDB files in: {temp_dir}", indent=1)

    header("DONE")
    log(f"Total runtime: {elapsed_text()}")
    log(f"Open first: {out_dir / 'cesmlc_v71_final_report_top100_by_cluster.md'}")
    log(f"Open second: {out_dir / 'cesmlc_v71_visual_report.html'}")
    log(f"Open third: {out_dir / 'cesmlc_v71_clustered_ecgi_incident_summary_top.csv'}")
    log(f"Training/labeling side-output: {out_dir / 'cesmlc_v71_model_ready_training_dataset.csv'}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())