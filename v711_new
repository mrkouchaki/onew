        ecgi_summary.to_csv(out_dir / "cesmlc_v71_clustered_ecgi_incident_summary_all.csv", index=False)
        ecgi_summary.head(args.top_n).to_csv(out_dir / "cesmlc_v71_clustered_ecgi_incident_summary_top.csv", index=False)
