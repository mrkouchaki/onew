def build_training_dataset(
    candidates: pd.DataFrame,
    hist: pd.DataFrame,
    changes: pd.DataFrame,
    conflicts: pd.DataFrame,
    rules: Dict[str, Dict[str, Any]],
    analysis_info: Dict[str, Any],
    args: argparse.Namespace,
) -> pd.DataFrame:
    header("PHASE 1D/E/F - CREATE HYBRID SIGNATURE + UNSUPERVISED DATASET")
    if hist.empty:
        raise RuntimeError("No source history metrics were produced for candidate ECGIs.")
    candidate_date = pd.to_datetime(analysis_info["candidate_date"]).normalize()
    change_stats = build_change_stats(changes, candidate_date, int(analysis_info.get("latest_db_mismatch_candidate_ecgis", 0) or 0))
    conflict_stats = build_conflict_stats(conflicts)

    fm = hist.copy()
    if not change_stats.empty:
        fm = fm.merge(change_stats, on=["ECGI", "FEATURE"], how="left")
    if not conflict_stats.empty:
        fm = fm.merge(conflict_stats, on=["ECGI", "FEATURE"], how="left")

    cand_cols = ["ECGI", "LATEST_DB_MISMATCH_RAW_ROWS", "LATEST_CANDIDATE_DATE"]
    for m in META_COLS + CANDIDATE_CONTEXT_COLS:
        mm = clean_col_name(m)
        if mm in candidates.columns and mm not in fm.columns and mm not in cand_cols:
            cand_cols.append(mm)
    fm = fm.merge(candidates[[c for c in cand_cols if c in candidates.columns]], on="ECGI", how="left")
    fm["ECGI_LABEL"] = fm["ECGI"].map(excel_safe_ecgi)
    fm["ANALYSIS_DAYS"] = int(analysis_info.get("requested_days", args.days))
    fm["ANALYSIS_START_DATE"] = analysis_info["window_start_date"]
    fm["ANALYSIS_END_DATE"] = analysis_info["window_end_date"]

    fm = add_signature_and_engineered_features(fm, rules, analysis_info, args)
    fm = attach_reference_compatibility(fm, rules, args)
    fm = add_location_distance_metrics(fm)
    # Re-run a light fallback/source compatibility boost after references exist.
    if "DATA_SOURCE_COMPATIBILITY" in fm.columns:
        fm.loc[(fm["FALLBACK_TO_DEFAULT_VALUE_FLAG"] == 1) & (fm["DATA_SOURCE_COMPATIBILITY"] == "NO"), "SEED_RULE_SCORE"] += 5.0
        fm.loc[(fm["FALLBACK_TO_DEFAULT_VALUE_FLAG"] == 1) & (safe_numeric(fm.get("REFERENCE_VALUE_PRESENT_FLAG", 0)) == 1), "SEED_RULE_SCORE"] += 3.0
    fm = add_isolation_forest_scores(fm, args)
    fm = apply_anomaly_fusion(fm, args)

    log(f"V7.1 feature rows: {len(fm):,}", indent=1)
    log(f"Primary anomaly cluster distribution: {fm['PRIMARY_ANOMALY_CLUSTER'].value_counts().head(20).to_dict()}", indent=1)
    log(f"Reportable abnormal feature rows: {int(fm['ABNORMAL_FEATURE_FLAG'].sum()):,}", indent=1)
    log(f"Rows marked trainable/labeling side-output: {int(fm['TRAIN_FOR_MODEL_FLAG'].sum()):,}", indent=1)
    return fm.sort_values(["ABNORMAL_FEATURE_FLAG", "ANOMALY_RISK_SCORE"], ascending=[False, False]).reset_index(drop=True)


def join_top_feature_briefs(d: pd.DataFrame, n: int = 8) -> str:
    parts = []
    for r in d.sort_values("ANOMALY_RISK_SCORE", ascending=False).head(n).itertuples(index=False):
        feature = getattr(r, "PRIMARY_ABNORMAL_FEATURE", getattr(r, "FEATURE", ""))
        cluster = getattr(r, "PRIMARY_ANOMALY_CLUSTER", "")
        days = getattr(r, "ABNORMAL_DAYS_PRESENTABLE", "")
        amount = getattr(r, "ABNORMAL_AMOUNT_PRESENTABLE", "")
        risk = safe_float(getattr(r, "ANOMALY_RISK_SCORE", 0))
        parts.append(f"{feature} [{cluster}] {days}, {short_value(amount, 80)}, risk={risk:.1f}")
    return "; ".join(parts)


def build_ecgi_summary(dataset: pd.DataFrame, min_report_score: float) -> pd.DataFrame:
    header("PHASE 1G - BUILD ECGI INCIDENT SUMMARY BY CLUSTER")
    if dataset.empty:
        return pd.DataFrame()
    reportable = dataset[(dataset["ABNORMAL_FEATURE_FLAG"] == 1) & (dataset["ANOMALY_RISK_SCORE"] >= float(min_report_score))].copy()
    if reportable.empty:
        log("No reportable ECGI incidents after V7.1 cluster/risk threshold.", indent=1)
        return pd.DataFrame()

    for c in [
        "ABNORMAL_DAYS_COUNT", "ABNORMAL_AMOUNT_NUMERIC", "SOURCE_CHANGE_COUNT", "SOURCE_CHANGE_DAYS_COUNT",
        "UNSUPERVISED_ISOF_TOP_FLAG", "FEATUREWISE_ISOF_TOP_FLAG", "UNSUPERVISED_PROMOTED_FLAG", "LOW_RISK_REGULAR_CHANGE_FLAG",
        "FALLBACK_TO_DEFAULT_VALUE_FLAG", "AUDIT_PUSH_NOT_APPLIED_FLAG", "LATEST_SOURCE_INVALID_RANGE_FLAG",
        "REAL_BACK_AND_FORTH_FLAG", "HIGH_FREQUENCY_DIFFERENT_VALUES_FLAG", "SOURCE_SAME_DAY_CONFLICT_FLAG", "PERSISTENT_SOURCE_INSTABILITY_FLAG",
    ]:
        if c not in reportable.columns:
            reportable[c] = 0
        reportable[c] = safe_numeric(reportable[c])

    reportable = reportable.sort_values(["ECGI", "ANOMALY_RISK_SCORE"], ascending=[True, False])
    top = reportable.groupby("ECGI", as_index=False).head(1).copy()
    top = top.rename(columns={
        "PRIMARY_ABNORMAL_FEATURE": "MAIN_PROBLEM_FEATURE",
        "PRIMARY_ANOMALY_CLUSTER": "PRIMARY_PROBLEM_CLASS",
        "SOURCE_FEATURE_EVIDENCE_SUMMARY_V71": "MAIN_EVIDENCE_SUMMARY",
        "ANOMALY_RISK_SCORE": "MAIN_FEATURE_SEVERITY_SCORE",
        "SOURCE_CHANGE_DAYS_COUNT": "MAIN_FEATURE_CHANGED_DAYS_COUNT",
        "SOURCE_CHANGED_DAYS_PERCENT": "MAIN_FEATURE_CHANGED_DAYS_PERCENT",
        "SOURCE_FIRST_CHANGE_DATE": "MAIN_FEATURE_FIRST_CHANGE_DATE",
        "SOURCE_LAST_CHANGE_DATE": "MAIN_FEATURE_LAST_CHANGE_DATE",
        "SOURCE_LATEST_CHANGE": "MAIN_FEATURE_LATEST_CHANGE",
    })

    agg = reportable.groupby("ECGI", as_index=False).agg(
        REPORTABLE_FEATURE_INCIDENT_COUNT=("FEATURE", "size"),
        ABNORMAL_FEATURE_COUNT=("PRIMARY_ABNORMAL_FEATURE", "nunique"),
        ABNORMAL_DAYS_TOTAL=("ABNORMAL_DAYS_COUNT", "sum"),
        ABNORMAL_DAYS_MAX=("ABNORMAL_DAYS_COUNT", "max"),
        TOTAL_SOURCE_CHANGE_EVENTS=("SOURCE_CHANGE_COUNT", "sum"),
        TOTAL_SOURCE_CHANGE_DAYS_ACROSS_FEATURES=("SOURCE_CHANGE_DAYS_COUNT", "sum"),
        ABNORMAL_AMOUNT_NUMERIC_MAX=("ABNORMAL_AMOUNT_NUMERIC", "max"),
        UNSUPERVISED_TOP_FEATURE_COUNT=("UNSUPERVISED_ISOF_TOP_FLAG", "sum"),
        FEATUREWISE_TOP_FEATURE_COUNT=("FEATUREWISE_ISOF_TOP_FLAG", "sum"),
        UNSUPERVISED_PROMOTED_FEATURE_COUNT=("UNSUPERVISED_PROMOTED_FLAG", "sum"),
        LOW_RISK_REGULAR_CHANGE_FEATURE_COUNT=("LOW_RISK_REGULAR_CHANGE_FLAG", "sum"),
        FALLBACK_TO_DEFAULT_FEATURE_COUNT=("FALLBACK_TO_DEFAULT_VALUE_FLAG", "sum"),
        AUDIT_PUSH_NOT_APPLIED_FEATURE_COUNT=("AUDIT_PUSH_NOT_APPLIED_FLAG", "sum"),
        INVALID_LATEST_SOURCE_VALUE_FEATURE_COUNT=("LATEST_SOURCE_INVALID_RANGE_FLAG", "sum"),
        REAL_BACK_AND_FORTH_FEATURE_COUNT=("REAL_BACK_AND_FORTH_FLAG", "sum"),
        HIGH_FREQUENCY_DIFFERENT_VALUES_FEATURE_COUNT=("HIGH_FREQUENCY_DIFFERENT_VALUES_FLAG", "sum"),
        SAME_DAY_CONFLICT_FEATURE_COUNT=("SOURCE_SAME_DAY_CONFLICT_FLAG", "sum"),
        PERSISTENT_SOURCE_INSTABILITY_FEATURE_COUNT=("PERSISTENT_SOURCE_INSTABILITY_FLAG", "sum"),
        SOURCE_RULE_SCORE_FROM_FEATURES=("SEED_RULE_SCORE", "sum"),
        MAX_FEATURE_SEVERITY_SCORE=("ANOMALY_RISK_SCORE", "max"),
        AVG_FEATURE_RISK_SCORE=("ANOMALY_RISK_SCORE", "mean"),
    )
    top_feats = (
        reportable.sort_values(["ECGI", "ANOMALY_RISK_SCORE"], ascending=[True, False])
        .groupby("ECGI", group_keys=False)
        .apply(lambda d: join_top_feature_briefs(d, n=8))
        .rename("TOP_FEATURE_INCIDENTS")
        .reset_index()
    )
    cluster_count_rows = reportable.groupby(["ECGI", "PRIMARY_ANOMALY_CLUSTER"], as_index=False).size().sort_values(["ECGI", "size"], ascending=[True, False])
    cluster_counts = cluster_count_rows.groupby("ECGI").apply(lambda d: "; ".join(f"{row['PRIMARY_ANOMALY_CLUSTER']}:{int(row['size'])}" for _, row in d.iterrows())).rename("CLUSTER_INCIDENT_COUNTS").reset_index()

    keep_cols = [
        "ECGI", "ECGI_LABEL", "REGION", "MARKETCLUSTER", "MARKET", "SUBMARKET", "SERVER_ID",
        "ANALYSIS_DAYS", "ANALYSIS_START_DATE", "ANALYSIS_END_DATE", "LATEST_DB_MISMATCH_RAW_ROWS",
        "LATEST_CANDIDATE_DATE", "PRIMARY_PROBLEM_CLASS", "MAIN_PROBLEM_FEATURE", "MAIN_FEATURE_SEVERITY_SCORE",
        "MAIN_FEATURE_CHANGED_DAYS_COUNT", "MAIN_FEATURE_CHANGED_DAYS_PERCENT", "MAIN_FEATURE_FIRST_CHANGE_DATE",
        "MAIN_FEATURE_LAST_CHANGE_DATE", "MAIN_FEATURE_LATEST_CHANGE", "MAIN_EVIDENCE_SUMMARY",
        "ABNORMAL_DAYS_PRESENTABLE", "ABNORMAL_AMOUNT_PRESENTABLE", "LOCATION_DISTANCE_PRESENTABLE", "LOCATION_LATEST_PREVIOUS_DISTANCE_M", "LOCATION_LATEST_FIRST_DISTANCE_M", "LOCATION_LATEST_DB_DISTANCE_M", "LOCATION_MAX_DISTANCE_M", "MODEL_SIGNATURE_AGREEMENT",
        "UNSUPERVISED_ISOF_PERCENTILE", "FEATUREWISE_ISOF_PERCENTILE", "LATEST_SOURCE_VALUE",
        "PREVIOUS_NONLATEST_SOURCE_VALUE", "FIRST_SOURCE_VALUE", "LATEST_DB_VALUE", "ANOMALY_RISK_BAND", "RECOMMENDED_ACTION",
    ]
    top_reduced = top[[c for c in keep_cols if c in top.columns]].copy()
    ecgi = agg.merge(top_reduced, on="ECGI", how="left").merge(top_feats, on="ECGI", how="left").merge(cluster_counts, on="ECGI", how="left")
    ecgi["PRIMARY_ANOMALY_CLUSTER"] = ecgi["PRIMARY_PROBLEM_CLASS"]
    ecgi["PRIMARY_ABNORMAL_FEATURE"] = ecgi["MAIN_PROBLEM_FEATURE"]
    risk = (
        ecgi["MAX_FEATURE_SEVERITY_SCORE"].fillna(0)
        + 2.0 * np.sqrt(ecgi["ABNORMAL_FEATURE_COUNT"].fillna(0).clip(lower=0))
        + 0.25 * ecgi["ABNORMAL_DAYS_MAX"].fillna(0).clip(lower=0)
        + 1.5 * (ecgi["UNSUPERVISED_PROMOTED_FEATURE_COUNT"].fillna(0) > 0).astype(int)
    )
    ecgi["ECGI_ANOMALY_RISK_SCORE"] = risk.clip(0, 100).round(3)
    ecgi["SOURCE_RULE_SCORE"] = ecgi["ECGI_ANOMALY_RISK_SCORE"]
    ecgi["SOURCE_RULE_PERCENTILE"] = percentile_rank(ecgi["SOURCE_RULE_SCORE"])
    def _ecgi_days_amounts(r: pd.Series) -> str:
        txt = (
            f"{int(safe_float(r.get('ABNORMAL_DAYS_TOTAL',0)))} abnormal feature-days; "
            f"max {int(safe_float(r.get('ABNORMAL_DAYS_MAX',0)))} days on {r.get('PRIMARY_ABNORMAL_FEATURE','')}; "
            f"amount={r.get('ABNORMAL_AMOUNT_PRESENTABLE','')}"
        )
        loc = str(r.get("LOCATION_DISTANCE_PRESENTABLE", "") or "")
        if loc and loc not in txt:
            txt += f"; distance={loc}"
        return txt

    ecgi["ABNORMAL_DAYS_AND_AMOUNTS"] = ecgi.apply(_ecgi_days_amounts, axis=1)
    ecgi["PLAIN_ENGLISH_SUMMARY"] = ecgi.apply(
        lambda r: (
            f"{r.get('ECGI_LABEL','')} primary_anomaly_cluster={r.get('PRIMARY_ANOMALY_CLUSTER','')} "
            f"on primary_abnormal_feature={r.get('PRIMARY_ABNORMAL_FEATURE','')}. "
            f"It has {int(r.get('ABNORMAL_FEATURE_COUNT',0))} abnormal feature(s), "
            f"{int(r.get('ABNORMAL_DAYS_TOTAL',0))} abnormal feature-day(s), risk={float(r.get('ECGI_ANOMALY_RISK_SCORE',0)):.1f}."
        ),
        axis=1,
    )
    ecgi = ecgi.sort_values("ECGI_ANOMALY_RISK_SCORE", ascending=False).reset_index(drop=True)
    ecgi.insert(0, "INCIDENT_RANK", np.arange(1, len(ecgi) + 1))
    log(f"V7.1 reportable ECGI incidents: {len(ecgi):,}", indent=1)
    return ecgi


def build_issue_summary(dataset: pd.DataFrame) -> pd.DataFrame:
    if dataset.empty:
        return pd.DataFrame()
    rows = []
    for cluster, d in dataset.groupby("PRIMARY_ANOMALY_CLUSTER"):
        rows.append({
            "PRIMARY_ANOMALY_CLUSTER": cluster,
            "ROW_COUNT": int(len(d)),
            "ABNORMAL_FEATURE_ROWS": int(safe_numeric(d.get("ABNORMAL_FEATURE_FLAG", 0)).sum()),
            "UNIQUE_ECGI": int(d["ECGI"].nunique()),
            "UNIQUE_ECGI_FEATURE": int(len(d[["ECGI", "FEATURE"]].drop_duplicates())),
            "TRAIN_FOR_MODEL_ROWS": int(safe_numeric(d.get("TRAIN_FOR_MODEL_FLAG", 0)).sum()),
            "AVG_ANOMALY_RISK_SCORE": float(safe_numeric(d.get("ANOMALY_RISK_SCORE", 0)).mean()),
            "MAX_ANOMALY_RISK_SCORE": float(safe_numeric(d.get("ANOMALY_RISK_SCORE", 0)).max()),
        })
    return pd.DataFrame(rows).sort_values(["ABNORMAL_FEATURE_ROWS", "ROW_COUNT"], ascending=False).reset_index(drop=True)


def build_manual_review_template(dataset: pd.DataFrame, top_n: int, random_n: int, random_state: int) -> pd.DataFrame:
    if dataset.empty:
        return pd.DataFrame()
    cols = [
        "ECGI", "ECGI_LABEL", "FEATURE", "PRIMARY_ANOMALY_CLUSTER", "PRIMARY_ABNORMAL_FEATURE",
        "MODEL_SIGNATURE_AGREEMENT", "ANOMALY_RISK_SCORE", "ANOMALY_RISK_BAND", "SEED_LABEL_CONFIDENCE",
        "SERVER_ID", "REGION", "MARKET", "LATEST_SOURCE_VALUE", "PREVIOUS_NONLATEST_SOURCE_VALUE", "LATEST_DB_VALUE",
        "ABNORMAL_DAYS_PRESENTABLE", "ABNORMAL_AMOUNT_PRESENTABLE", "LOCATION_DISTANCE_PRESENTABLE", "LOCATION_MAX_DISTANCE_M", "DATA_SOURCE_COMPATIBILITY", "DATA_SOURCE_MATCH_STATUS",
        "REFERENCE_SOURCE_NAME", "REFERENCE_COLUMN", "REFERENCE_VALUE", "FALLBACK_DURATION_CLUSTER",
        "UNSUPERVISED_ISOF_PERCENTILE", "FEATUREWISE_ISOF_PERCENTILE", "UNSUPERVISED_PROMOTED_FLAG",
        "SOURCE_CHANGE_DAYS_COUNT", "SOURCE_CHANGE_COUNT", "DISTINCT_SOURCE_VALUES_30D", "SOURCE_A_B_A_REVERT_COUNT",
        "SOURCE_REVERSE_TRANSITION_COUNT", "SOURCE_SAME_DAY_CONFLICT_DAYS", "MAX_CANDIDATE_BULK_CHANGE_RATIO",
        "SOURCE_FEATURE_EVIDENCE_SUMMARY_V71", "RECOMMENDED_ACTION", "MANUAL_LABEL", "MANUAL_LABEL_NOTES",
    ]
    top = dataset.sort_values("ANOMALY_RISK_SCORE", ascending=False).head(top_n).copy()
    pool = dataset[~dataset.index.isin(top.index)].copy()
    if len(pool) > 0 and random_n > 0:
        sample = pool.sample(n=min(random_n, len(pool)), random_state=random_state)
        out = pd.concat([top, sample], ignore_index=True)
    else:
        out = top
    return out[[c for c in cols if c in out.columns]].copy()


