def haversine_distance_m(lat1: Any, lon1: Any, lat2: Any, lon2: Any) -> float:
    """Great-circle distance in meters between two latitude/longitude points."""
    try:
        a_lat = float(lat1); a_lon = float(lon1); b_lat = float(lat2); b_lon = float(lon2)
        if not all(math.isfinite(x) for x in [a_lat, a_lon, b_lat, b_lon]):
            return float("nan")
        if abs(a_lat) > 90 or abs(b_lat) > 90 or abs(a_lon) > 180 or abs(b_lon) > 180:
            return float("nan")
        r = 6371008.8
        phi1, phi2 = math.radians(a_lat), math.radians(b_lat)
        dphi = math.radians(b_lat - a_lat)
        dlambda = math.radians(b_lon - a_lon)
        h = math.sin(dphi / 2.0) ** 2 + math.cos(phi1) * math.cos(phi2) * math.sin(dlambda / 2.0) ** 2
        return float(2.0 * r * math.asin(min(1.0, math.sqrt(h))))
    except Exception:
        return float("nan")


def _fmt_distance(meters: Any) -> str:
    try:
        m = float(meters)
        if not math.isfinite(m):
            return "n/a"
        if m >= 1000:
            return f"{m/1000.0:.3f} km ({m:.0f} m)"
        return f"{m:.1f} m"
    except Exception:
        return "n/a"


def add_location_distance_metrics(fm: pd.DataFrame) -> pd.DataFrame:
    """Attach ECGI-level lat/lon movement distance to ANTENNALAT/ANTENNALON rows.

    Source-history metrics are feature-level aggregates, so this distance is review evidence using
    latest, previous-nonlatest, first observed, and DB lat/lon values for the same ECGI when available.
    """
    if fm.empty or "FEATURE" not in fm.columns or "ECGI" not in fm.columns:
        return fm
    out = fm.copy()
    for c in [
        "LOCATION_LATEST_PREVIOUS_DISTANCE_M", "LOCATION_LATEST_FIRST_DISTANCE_M",
        "LOCATION_LATEST_DB_DISTANCE_M", "LOCATION_MAX_DISTANCE_M",
    ]:
        if c not in out.columns:
            out[c] = np.nan
    if "LOCATION_DISTANCE_PRESENTABLE" not in out.columns:
        out["LOCATION_DISTANCE_PRESENTABLE"] = ""

    needed = {"LATEST_SOURCE_VALUE", "PREVIOUS_NONLATEST_SOURCE_VALUE", "FIRST_SOURCE_VALUE"}
    if not needed.issubset(set(out.columns)):
        return out
    if "LATEST_DB_VALUE" not in out.columns:
        out["LATEST_DB_VALUE"] = ""

    small = out[out["FEATURE"].isin(["ANTENNALAT", "ANTENNALON"])][[
        "ECGI", "FEATURE", "LATEST_SOURCE_VALUE", "PREVIOUS_NONLATEST_SOURCE_VALUE", "FIRST_SOURCE_VALUE", "LATEST_DB_VALUE"
    ]].copy()
    if small.empty:
        return out
    lat = small[small["FEATURE"] == "ANTENNALAT"].drop_duplicates("ECGI").set_index("ECGI")
    lon = small[small["FEATURE"] == "ANTENNALON"].drop_duplicates("ECGI").set_index("ECGI")
    common = sorted(set(lat.index).intersection(set(lon.index)))
    if not common:
        return out

    records = []
    for ecgi in common:
        latest_lat = safe_float(lat.at[ecgi, "LATEST_SOURCE_VALUE"], np.nan)
        latest_lon = safe_float(lon.at[ecgi, "LATEST_SOURCE_VALUE"], np.nan)
        prev_lat = safe_float(lat.at[ecgi, "PREVIOUS_NONLATEST_SOURCE_VALUE"], np.nan)
        prev_lon = safe_float(lon.at[ecgi, "PREVIOUS_NONLATEST_SOURCE_VALUE"], np.nan)
        first_lat = safe_float(lat.at[ecgi, "FIRST_SOURCE_VALUE"], np.nan)
        first_lon = safe_float(lon.at[ecgi, "FIRST_SOURCE_VALUE"], np.nan)
        db_lat = safe_float(lat.at[ecgi, "LATEST_DB_VALUE"], np.nan)
        db_lon = safe_float(lon.at[ecgi, "LATEST_DB_VALUE"], np.nan)
        d_prev = haversine_distance_m(prev_lat, prev_lon, latest_lat, latest_lon)
        d_first = haversine_distance_m(first_lat, first_lon, latest_lat, latest_lon)
        d_db = haversine_distance_m(db_lat, db_lon, latest_lat, latest_lon)
        d_vals = [x for x in [d_prev, d_first, d_db] if math.isfinite(x)]
        d_max = max(d_vals) if d_vals else float("nan")
        pieces = [
            f"location move latest-vs-prev={_fmt_distance(d_prev)}",
            f"latest-vs-first={_fmt_distance(d_first)}",
        ]
        if math.isfinite(d_db):
            pieces.append(f"latest-vs-DB={_fmt_distance(d_db)}")
        pieces.append(f"latest(lat,lon)=({latest_lat:.6f},{latest_lon:.6f})")
        if math.isfinite(prev_lat) and math.isfinite(prev_lon):
            pieces.append(f"prev(lat,lon)=({prev_lat:.6f},{prev_lon:.6f})")
        if math.isfinite(db_lat) and math.isfinite(db_lon):
            pieces.append(f"db(lat,lon)=({db_lat:.6f},{db_lon:.6f})")
        records.append({
            "ECGI": ecgi,
            "LOCATION_LATEST_PREVIOUS_DISTANCE_M_NEW": d_prev,
            "LOCATION_LATEST_FIRST_DISTANCE_M_NEW": d_first,
            "LOCATION_LATEST_DB_DISTANCE_M_NEW": d_db,
            "LOCATION_MAX_DISTANCE_M_NEW": d_max,
            "LOCATION_DISTANCE_PRESENTABLE_NEW": "; ".join(pieces),
        })
    dist = pd.DataFrame(records)
    out = out.merge(dist, on="ECGI", how="left")
    loc_rows = out["FEATURE"].isin(["ANTENNALAT", "ANTENNALON"])
    for c in [
        "LOCATION_LATEST_PREVIOUS_DISTANCE_M", "LOCATION_LATEST_FIRST_DISTANCE_M",
        "LOCATION_LATEST_DB_DISTANCE_M", "LOCATION_MAX_DISTANCE_M", "LOCATION_DISTANCE_PRESENTABLE",
    ]:
        nc = f"{c}_NEW"
        if nc in out.columns:
            out.loc[loc_rows, c] = out.loc[loc_rows, nc]
            out = out.drop(columns=[nc])
    return out

def abnormal_days_presentable(row: pd.Series) -> Tuple[int, str]:
    pieces = []
    change_days = int(safe_float(row.get("SOURCE_CHANGE_DAYS_COUNT", 0)))
    conflict_days = int(safe_float(row.get("SOURCE_SAME_DAY_CONFLICT_DAYS", 0)))
    db_days = int(safe_float(row.get("SOURCE_DB_MISMATCH_DAYS", 0)))
    fallback_days = int(safe_float(row.get("LATEST_SOURCE_VALUE_DAYS", 0))) if int(safe_float(row.get("FALLBACK_TO_DEFAULT_VALUE_FLAG", 0))) == 1 else 0
    invalid_days = int(safe_float(row.get("LATEST_SOURCE_VALUE_DAYS", 0))) if int(safe_float(row.get("LATEST_SOURCE_INVALID_RANGE_FLAG", 0))) == 1 else 0
    total = max(change_days, conflict_days, db_days, fallback_days, invalid_days)
    if change_days:
        pieces.append(f"changed {change_days}d")
    if conflict_days:
        pieces.append(f"same-day conflict {conflict_days}d")
    if db_days:
        pieces.append(f"source-vs-DB mismatch {db_days}d")
    if fallback_days:
        pieces.append(f"default/fallback {fallback_days}d")
    if invalid_days:
        pieces.append(f"invalid latest persisted {invalid_days}d")
    if not pieces:
        pieces.append("no material source-change days")
    return int(total), "; ".join(pieces)


def abnormal_amount_presentable(row: pd.Series) -> str:
    feature = str(row.get("FEATURE", ""))
    loc_text = str(row.get("LOCATION_DISTANCE_PRESENTABLE", "") or "")
    amount_num = row.get("NUMERIC_ABNORMAL_AMOUNT", np.nan)
    base_numeric = ""
    try:
        if pd.notna(amount_num) and np.isfinite(float(amount_num)):
            base_numeric = (
                f"numeric delta max={float(amount_num):.6g}; "
                f"latest={short_value(row.get('LATEST_SOURCE_VALUE',''))}; "
                f"prev={short_value(row.get('PREVIOUS_NONLATEST_SOURCE_VALUE',''))}"
            )
    except Exception:
        base_numeric = ""
    if feature in {"ANTENNALAT", "ANTENNALON"} and loc_text:
        return loc_text + (f"; {base_numeric}" if base_numeric else "")
    if base_numeric:
        return base_numeric
    return (
        f"distinct values={int(safe_float(row.get('DISTINCT_SOURCE_VALUES_30D',0)))}; "
        f"events={int(safe_float(row.get('SOURCE_CHANGE_COUNT',0)))}; "
        f"latest={short_value(row.get('LATEST_SOURCE_VALUE',''))}; prev={short_value(row.get('PREVIOUS_NONLATEST_SOURCE_VALUE',''))}; feature={feature}"
    )


def apply_anomaly_fusion(fm: pd.DataFrame, args: argparse.Namespace) -> pd.DataFrame:
    if fm.empty:
        return fm
    fm = fm.copy()
    global_pct = series_num(fm, "UNSUPERVISED_ISOF_PERCENTILE", 50).fillna(50)
    feat_pct = series_num(fm, "FEATUREWISE_ISOF_PERCENTILE", 50).fillna(50)
    rule_score = series_num(fm, "SEED_RULE_SCORE", 0)
    rule_pct = percentile_rank(rule_score)
    weak_support = (
        (series_num(fm, "SOURCE_CHANGE_DAYS_COUNT", 0) > 0)
        | (series_num(fm, "SOURCE_CHANGE_COUNT", 0) > 0)
        | (series_num(fm, "DISTINCT_SOURCE_VALUES_30D", 0) > 1)
        | (series_num(fm, "SOURCE_SAME_DAY_CONFLICT_DAYS", 0) > 0)
        | (series_num(fm, "SOURCE_DB_MISMATCH_DAYS", 0) > 0)
        | (rule_score >= float(args.unsupervised_min_rule_score_support))
    )
    unsup_top = (global_pct >= float(args.isolation_top_percentile)) | (feat_pct >= float(args.featurewise_isolation_top_percentile))
    fm["UNSUPERVISED_PROMOTED_FLAG"] = (unsup_top & weak_support & (series_num(fm, "HAS_PROBLEM_SIGNATURE_FLAG", 0) == 0)).astype(int)
    fm["LOW_RISK_REGULAR_CHANGE_FLAG"] = (
        (series_num(fm, "SOURCE_CHANGE_COUNT", 0).between(1, 1))
        & (series_num(fm, "DISTINCT_SOURCE_VALUES_30D", 0) <= 2)
        & (series_num(fm, "DAYS_SINCE_LAST_SOURCE_CHANGE", 9999) >= int(args.stable_change_suppress_days))
        & (series_num(fm, "HAS_PROBLEM_SIGNATURE_FLAG", 0) == 0)
        & (~unsup_top)
    ).astype(int)

    unsup_component = np.maximum(global_pct.fillna(50), feat_pct.fillna(50))
    risk = (
        0.68 * rule_score.clip(0, 100)
        + 0.20 * (unsup_component / 100.0 * 100.0)
        + 0.08 * rule_pct.fillna(50)
        + 0.04 * np.minimum(100.0, series_num(fm, "INSTABILITY_EVENT_INDEX", 0) * 3.0)
    )
    risk += np.where(fm["UNSUPERVISED_PROMOTED_FLAG"] == 1, float(args.unsupervised_promotion_boost), 0.0)
    risk += np.where(series_num(fm, "LATEST_SOURCE_INVALID_RANGE_FLAG", 0) == 1, 6.0, 0.0)
    risk += np.where(series_num(fm, "SITE_WIDE_LONG_TERM_DEFAULT_FALLBACK_SUSPECT_FLAG", 0) == 1, 6.0, 0.0)
    risk -= np.where(fm["LOW_RISK_REGULAR_CHANGE_FLAG"] == 1, 25.0, 0.0)
    fm["ANOMALY_RISK_SCORE"] = pd.Series(risk, index=fm.index).clip(0, 100).round(3)
    fm["ANOMALY_RISK_PERCENTILE"] = percentile_rank(fm["ANOMALY_RISK_SCORE"])
    fm["ANOMALY_RISK_BAND"] = fm["ANOMALY_RISK_SCORE"].map(severity_band_from_risk)

    def cluster(r: pd.Series) -> str:
        if int(safe_float(r.get("AUDIT_PUSH_NOT_APPLIED_FLAG", 0))) == 1:
            return "AUDIT_PUSH_NOT_APPLIED"
        if int(safe_float(r.get("LATEST_SOURCE_INVALID_RANGE_FLAG", 0))) == 1:
            return "INVALID_LATEST_SOURCE_VALUE"
        if int(safe_float(r.get("LONG_TERM_DEFAULT_FALLBACK_FLAG", 0))) == 1:
            return "LONG_TERM_FALLBACK_TO_DEFAULT"
        if int(safe_float(r.get("FLUCTUATING_DEFAULT_FALLBACK_FLAG", 0))) == 1:
            return "FLUCTUATING_FALLBACK_TO_DEFAULT"
        if int(safe_float(r.get("REAL_BACK_AND_FORTH_FLAG", 0))) == 1:
            return "REAL_BACK_AND_FORTH_INSTABILITY"
        if int(safe_float(r.get("HIGH_FREQUENCY_DIFFERENT_VALUES_FLAG", 0))) == 1:
            return "HIGH_FREQUENCY_DIFFERENT_VALUES"
        if int(safe_float(r.get("SOURCE_SAME_DAY_CONFLICT_FLAG", 0))) == 1:
            return "SAME_DAY_SOURCE_CONFLICT"
        if int(safe_float(r.get("PERSISTENT_SOURCE_INSTABILITY_FLAG", 0))) == 1:
            return "PERSISTENT_SOURCE_INSTABILITY"
        if int(safe_float(r.get("UNSUPERVISED_PROMOTED_FLAG", 0))) == 1:
            return "UNSUPERVISED_OUTLIER_WITH_WEAK_SIGNATURE"
        if int(safe_float(r.get("FEATUREWISE_ISOF_TOP_FLAG", 0))) == 1 and int(safe_float(r.get("LOW_RISK_REGULAR_CHANGE_FLAG", 0))) == 0:
            return "UNSUPERVISED_FEATURE_OUTLIER"
        if int(safe_float(r.get("LATEST_DAY_SOURCE_CHANGE_FLAG", 0))) == 1:
            return "LATEST_DAY_SOURCE_CHANGE"
        if int(safe_float(r.get("LOW_RISK_REGULAR_CHANGE_FLAG", 0))) == 1:
            return "LOW_RISK_REGULAR_CHANGE"
        if int(safe_float(r.get("BULK_OR_REFRESH_SUPPRESSOR_FLAG", 0))) == 1:
            return "SUPPRESSED_BULK_OR_REFRESH_PATTERN"
        if int(safe_float(r.get("COORDINATED_MULTI_FIELD_SUPPRESSOR_FLAG", 0))) == 1:
            return "SUPPRESSED_COORDINATED_MULTI_FIELD_CHANGE"
        if int(safe_float(r.get("LOW_INFORMATION_STABLE_SOURCE_HISTORY_FLAG", 0))) == 1:
            return "STABLE_SOURCE_HISTORY"
        return "LOW_PRIORITY_SOURCE_HISTORY_SIGNAL"

    fm["PRIMARY_ANOMALY_CLUSTER"] = fm.apply(cluster, axis=1)
    fm["PRIMARY_ABNORMAL_FEATURE"] = fm["FEATURE"]
    fm["PRIMARY_ABNORMAL_FEATURE_FAMILY"] = fm["FEATURE"].map(feature_family)
    fm["ABNORMAL_FEATURE_FLAG"] = (
        (fm["PRIMARY_ANOMALY_CLUSTER"].isin(PROBLEM_LABELS))
        & (fm["ANOMALY_RISK_SCORE"] >= float(args.min_report_score))
    ).astype(int)
    # Always report high-confidence rule signatures even if score threshold is conservative.
    fm.loc[series_num(fm, "HAS_PROBLEM_SIGNATURE_FLAG", 0) == 1, "ABNORMAL_FEATURE_FLAG"] = 1
    fm.loc[fm["PRIMARY_ANOMALY_CLUSTER"].isin({"LOW_RISK_REGULAR_CHANGE", "STABLE_SOURCE_HISTORY", "LOW_PRIORITY_SOURCE_HISTORY_SIGNAL"}), "ABNORMAL_FEATURE_FLAG"] = 0

    agreement = []
    for _, r in fm.iterrows():
        has_rule = int(safe_float(r.get("HAS_PROBLEM_SIGNATURE_FLAG", 0))) == 1
        has_iso = (safe_float(r.get("UNSUPERVISED_ISOF_PERCENTILE", 0)) >= float(args.isolation_top_percentile)) or (safe_float(r.get("FEATUREWISE_ISOF_PERCENTILE", 0)) >= float(args.featurewise_isolation_top_percentile))
        promoted = int(safe_float(r.get("UNSUPERVISED_PROMOTED_FLAG", 0))) == 1
        low = int(safe_float(r.get("LOW_RISK_REGULAR_CHANGE_FLAG", 0))) == 1
        if has_rule and has_iso:
            agreement.append("RULE_AND_ISOF")
        elif has_rule:
            agreement.append("RULE_SIGNATURE_ONLY")
        elif promoted:
            agreement.append("ISOF_PROMOTED_FOR_REVIEW")
        elif has_iso:
            agreement.append("ISOF_ONLY_LOW_EVIDENCE")
        elif low:
            agreement.append("LOW_RISK_REGULAR_CHANGE")
        else:
            agreement.append("LOW_RISK_OR_HOLD")
    fm["MODEL_SIGNATURE_AGREEMENT"] = agreement

    days_info = fm.apply(abnormal_days_presentable, axis=1)
    fm["ABNORMAL_DAYS_COUNT"] = [x[0] for x in days_info]
    fm["ABNORMAL_DAYS_PRESENTABLE"] = [x[1] for x in days_info]
    fm["ABNORMAL_AMOUNT_PRESENTABLE"] = fm.apply(abnormal_amount_presentable, axis=1)
    fm["SOURCE_FEATURE_EVIDENCE_SUMMARY_V71"] = fm.apply(
        lambda r: (
            f"cluster={r.get('PRIMARY_ANOMALY_CLUSTER','')}; feature={r.get('PRIMARY_ABNORMAL_FEATURE','')}; "
            f"risk={float(r.get('ANOMALY_RISK_SCORE',0)):.1f}; {r.get('ABNORMAL_DAYS_PRESENTABLE','')}; "
            f"amount={short_value(r.get('ABNORMAL_AMOUNT_PRESENTABLE',''), 120)}; "
            f"global_isof_pct={safe_float(r.get('UNSUPERVISED_ISOF_PERCENTILE', np.nan), np.nan):.1f}; "
            f"feature_isof_pct={safe_float(r.get('FEATUREWISE_ISOF_PERCENTILE', np.nan), np.nan):.1f}; "
            f"agreement={r.get('MODEL_SIGNATURE_AGREEMENT','')}."
        ),
        axis=1,
    )
    fm["SEED_LABEL"] = fm["PRIMARY_ANOMALY_CLUSTER"]
    conf_weight = fm["SEED_LABEL"].map(label_confidence_and_weight)
    fm["SEED_LABEL_CONFIDENCE"] = [cw[0] for cw in conf_weight]
    fm["TRAINING_WEIGHT"] = [cw[1] for cw in conf_weight]
    fm["IS_REPORTABLE_PROBLEM"] = fm["ABNORMAL_FEATURE_FLAG"]
    fm["TRAIN_FOR_MODEL_FLAG"] = ((fm["SEED_LABEL_CONFIDENCE"] >= float(args.min_seed_confidence_for_training)) & (fm["TRAINING_WEIGHT"] > 0) & (fm["ABNORMAL_FEATURE_FLAG"] == 1)).astype(int)
    fm["FINAL_TRAINING_LABEL"] = fm["PRIMARY_ANOMALY_CLUSTER"]
    fm["RECOMMENDED_ACTION"] = fm["PRIMARY_ANOMALY_CLUSTER"].map(recommended_action).fillna("Manual review recommended.")
    return fm


