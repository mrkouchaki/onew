def query_daily_history_for_pairs(
    con,
    input_path: Path,
    colmap: Dict[str, str],
    date_col_clean: str,
    pairs: List[Tuple[str, str]],
    analysis_info: Dict[str, Any],
    latlon_decimals: int,
) -> pd.DataFrame:
    if not pairs:
        return pd.DataFrame(columns=["ECGI", "FEATURE", "LOAD_DATE", "SOURCE_VALUE", "SOURCE_UNIQUE_COUNT"])
    rows = []
    file_sql = sql_path(input_path)
    date_expr = date_parse_expr(colmap[date_col_clean])
    ecgi_sql = ecgi_expr_from_columns(colmap)
    min_date_sql = analysis_info["window_start_date"]
    max_date_sql = analysis_info["window_end_date"]
    by_feature: Dict[str, List[str]] = {}
    for ecgi, feature in pairs:
        by_feature.setdefault(clean_col_name(feature), []).append(normalize_key_value(ecgi))
    for feature, ecgis in by_feature.items():
        if feature not in colmap:
            continue
        val_expr = feature_norm_expr(colmap[feature], feature, latlon_decimals)
        ecgi_list = ", ".join(sql_string(e) for e in sorted(set(ecgis)) if e)
        if not ecgi_list:
            continue
        sql = f"""
        WITH raw AS (
            SELECT {date_expr} AS LOAD_DATE,
                   {ecgi_sql} AS ECGI,
                   {val_expr} AS SOURCE_VALUE
            FROM read_csv_auto({file_sql}, HEADER=TRUE, ALL_VARCHAR=TRUE, SAMPLE_SIZE=100000, IGNORE_ERRORS=TRUE)
        )
        SELECT ECGI,
               {sql_string(feature)} AS FEATURE,
               LOAD_DATE,
               MIN(SOURCE_VALUE) FILTER (WHERE SOURCE_VALUE IS NOT NULL) AS SOURCE_VALUE,
               COUNT(DISTINCT SOURCE_VALUE) FILTER (WHERE SOURCE_VALUE IS NOT NULL) AS SOURCE_UNIQUE_COUNT
        FROM raw
        WHERE LOAD_DATE BETWEEN DATE {sql_string(min_date_sql)} AND DATE {sql_string(max_date_sql)}
          AND ECGI IN ({ecgi_list})
        GROUP BY ECGI, LOAD_DATE
        ORDER BY ECGI, LOAD_DATE
        """
        try:
            rows.append(con.execute(sql).fetchdf())
        except Exception as exc:
            log(f"Could not query daily history for feature {feature}: {exc}", indent=2)
    if not rows:
        return pd.DataFrame(columns=["ECGI", "FEATURE", "LOAD_DATE", "SOURCE_VALUE", "SOURCE_UNIQUE_COUNT"])
    out = pd.concat(rows, ignore_index=True)
    out.columns = [clean_col_name(c) for c in out.columns]
    out["ECGI"] = out["ECGI"].map(normalize_key_value)
    out["FEATURE"] = out["FEATURE"].map(clean_col_name)
    out["LOAD_DATE"] = pd.to_datetime(out["LOAD_DATE"], errors="coerce").dt.normalize()
    out["SOURCE_VALUE"] = out["SOURCE_VALUE"].map(normalize_value_text)
    return out


def encode_plot_values(s: pd.Series) -> Tuple[pd.Series, str]:
    num = pd.to_numeric(s, errors="coerce")
    if num.notna().sum() >= max(2, int(0.6 * len(s.dropna()))):
        return num, "numeric"
    vals = [v for v in s.dropna().astype(str).unique().tolist() if v]
    mapping = {v: i for i, v in enumerate(vals, start=1)}
    return s.map(mapping).astype(float), "encoded: " + ", ".join(f"{k}={v}" for k, v in list(mapping.items())[:8])


