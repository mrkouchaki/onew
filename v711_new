        if lr.empty:
            continue
        stories.append((ar, lr.iloc[0]))
        used_features.add(feature)
        if len(stories) >= int(args.plot_story_count):
            break
    if len(stories) < int(args.plot_story_count):
        for _, ar in abnormal.iterrows():
            if len(stories) >= int(args.plot_story_count):
                break
            lr = lowrisk[lowrisk["ECGI"] != ar["ECGI"]]
            if lr.empty:
                continue
            stories.append((ar, lr.iloc[0]))

    pairs: List[Tuple[str, str]] = []
    for ar, lr in stories:
        pairs.append((ar["ECGI"], ar["FEATURE"]))
        pairs.append((lr["ECGI"], lr["FEATURE"]))
    hist = query_daily_history_for_pairs(con, input_path, colmap, date_col_clean, pairs, analysis_info, int(args.latlon_decimals))
    if hist.empty:
        return made

    for i, (ar, lr) in enumerate(stories, start=1):
        feature = ar["FEATURE"]
        da = hist[(hist["ECGI"] == ar["ECGI"]) & (hist["FEATURE"] == feature)].copy()
        dl = hist[(hist["ECGI"] == lr["ECGI"]) & (hist["FEATURE"] == lr["FEATURE"])].copy()
        if da.empty or dl.empty:
            continue
        # If low-risk feature differs, still plot both encoded/numeric on their own axis label.
        all_vals = pd.concat([da["SOURCE_VALUE"], dl["SOURCE_VALUE"]], ignore_index=True)
        encoded_all, note = encode_plot_values(all_vals)
        da["PLOT_VALUE"] = encoded_all.iloc[: len(da)].values
        dl["PLOT_VALUE"] = encoded_all.iloc[len(da) :].values
        fig = plt.figure(figsize=(12, 5))
        plt.plot(da["LOAD_DATE"], da["PLOT_VALUE"], marker="o", label=f"ABNORMAL {ar.get('ECGI_LABEL','')} {feature}")
        plt.plot(dl["LOAD_DATE"], dl["PLOT_VALUE"], marker="o", label=f"LOW-RISK {lr.get('ECGI_LABEL','')} {lr.get('FEATURE','')}")
        plt.title(
            f"Story {i}: abnormal vs regular low-risk change\n"
            f"Abnormal cluster={ar.get('PRIMARY_ANOMALY_CLUSTER','')}, risk={safe_float(ar.get('ANOMALY_RISK_SCORE',0)):.1f}; "
            f"Low-risk cluster={lr.get('PRIMARY_ANOMALY_CLUSTER','')}, risk={safe_float(lr.get('ANOMALY_RISK_SCORE',0)):.1f}"
        )
        plt.xlabel("Load date")
        plt.ylabel("Source value" if note == "numeric" else "Encoded source value")
        plt.xticks(rotation=45, ha="right")
        plt.legend(fontsize=8)
        if note != "numeric":
            plt.figtext(0.01, 0.01, note[:220], fontsize=8, ha="left")
        plt.tight_layout(rect=(0, 0.04, 1, 1))
        p = plot_dir / f"04_story_{i:02d}_abnormal_vs_lowrisk_{safe_filename(feature)}.png"
        fig.savefig(p, dpi=150)
        plt.close(fig)
        made.append(str(p))

    # Multi-feature ECGI examples.
    multi = abnormal.groupby("ECGI").filter(lambda d: d["FEATURE"].nunique() >= 2)
    for j, (ecgi, d) in enumerate(multi.groupby("ECGI"), start=1):
        if j > int(args.plot_ecgi_multifeature_count):
            break
        feats = d.sort_values("ANOMALY_RISK_SCORE", ascending=False)["FEATURE"].drop_duplicates().head(3).tolist()
        pairs2 = [(ecgi, f) for f in feats]
        h2 = query_daily_history_for_pairs(con, input_path, colmap, date_col_clean, pairs2, analysis_info, int(args.latlon_decimals))
        if h2.empty:
            continue
        fig = plt.figure(figsize=(12, 5))
        notes = []
        for f in feats:
            sub = h2[(h2["ECGI"] == ecgi) & (h2["FEATURE"] == f)].copy()
            if sub.empty:
                continue
            vals, note = encode_plot_values(sub["SOURCE_VALUE"])
            # Normalize so different numeric feature scales fit on one plot.
            if vals.notna().sum() > 1 and vals.max() != vals.min():
                y = (vals - vals.min()) / (vals.max() - vals.min())
            else:
                y = vals
            plt.plot(sub["LOAD_DATE"], y, marker="o", label=f)
            if note != "numeric":
                notes.append(f"{f}: {note}")
        ecgi_label = d.iloc[0].get("ECGI_LABEL", ecgi)
        plt.title(f"Multi-feature abnormal history for {ecgi_label} â top abnormal features normalized")
        plt.xlabel("Load date")
        plt.ylabel("Normalized/encoded value")
        plt.xticks(rotation=45, ha="right")
        plt.legend(fontsize=8)
        if notes:
            plt.figtext(0.01, 0.01, " | ".join(notes)[:240], fontsize=8, ha="left")
        plt.tight_layout(rect=(0, 0.04, 1, 1))
        p = plot_dir / f"05_multifeature_ecgi_{j:02d}_{safe_filename(ecgi)}.png"
        fig.savefig(p, dpi=150)
        plt.close(fig)
        made.append(str(p))
    return made


def write_visual_html_report(out_dir: Path, plot_paths: List[str]) -> None:
    rels = []
    for p in plot_paths:
        try:
            rels.append(Path(p).relative_to(out_dir).as_posix())
        except Exception:
            rels.append(str(p))
    lines = [
        "<!doctype html>",
        "<html><head><meta charset='utf-8'><title>CESMLC V7.1 Visual Report</title>",
        "<style>body{font-family:Arial, sans-serif;margin:24px;} img{max-width:100%;border:1px solid #ddd;margin:12px 0;} .card{margin-bottom:28px;} code{background:#eee;padding:2px 4px;}</style>",
        "</head><body>",
        "<h1>CESMLC V7.1 Visual Report</h1>",
        "<p>Plots generated by the standalone hybrid signature + IsolationForest anomaly detector.</p>",
    ]
    if not rels:
        lines.append("<p>No plots were generated. Check matplotlib installation and whether the data had enough changed/abnormal examples.</p>")
    for rel in rels:
        lines.append(f"<div class='card'><h2>{html.escape(Path(rel).name)}</h2><img src='{html.escape(rel)}'></div>")
    lines.append("</body></html>")
    (out_dir / "cesmlc_v71_visual_report.html").write_text("\n".join(lines), encoding="utf-8")


