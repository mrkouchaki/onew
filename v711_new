def create_latest_db_mismatch_candidates(
    con,
    input_path: Path,
    colmap: Dict[str, str],
    date_col_clean: str,
    days: int,
    end_date: Optional[str],
    server_id_filter: Optional[str],
) -> Dict[str, Any]:
    header("PHASE 1A - LATEST-DAY DB_MISMATCH CANDIDATE EXTRACTION")
    if "DB_MISMATCH" not in colmap:
        raise ValueError("DB_MISMATCH column is required for candidate gating.")

    file_sql = sql_path(input_path)
    date_expr = date_parse_expr(colmap[date_col_clean])
    ecgi_expr = ecgi_expr_from_columns(colmap)
    db_mismatch_expr = compact_norm_expr(quote_ident(colmap["DB_MISMATCH"]))

    meta_selects = []
    for m in META_COLS:
        if m in colmap:
            meta_selects.append(f"{compact_norm_expr(quote_ident(colmap[m]))} AS {quote_ident(m)}")
        else:
            meta_selects.append(f"NULL AS {quote_ident(m)}")

    context_selects = []
    context_cols = []
    for c in CANDIDATE_CONTEXT_COLS:
        cc = clean_col_name(c)
        if cc in colmap and cc not in set(META_COLS + ["ECGI", "DB_MISMATCH"]):
            if cc not in context_cols:
                context_cols.append(cc)
                context_selects.append(f"{compact_norm_expr(quote_ident(colmap[cc]))} AS {quote_ident(cc)}")

    stats_sql = f"""
    WITH raw AS (
        SELECT {date_expr} AS LOAD_DATE
        FROM read_csv_auto({file_sql}, HEADER=TRUE, ALL_VARCHAR=TRUE, SAMPLE_SIZE=100000, IGNORE_ERRORS=TRUE)
    )
    SELECT MIN(LOAD_DATE) AS MIN_LOAD_DATE,
           MAX(LOAD_DATE) AS MAX_LOAD_DATE,
           COUNT(DISTINCT LOAD_DATE) AS DISTINCT_LOAD_DAYS
    FROM raw
    WHERE LOAD_DATE IS NOT NULL
    """
    stats = con.execute(stats_sql).fetchdf()
    if stats.empty or pd.isna(stats.loc[0, "MAX_LOAD_DATE"]):
        raise RuntimeError("Could not parse valid LOAD_DATE values from input CSV.")

    raw_min_date = pd.to_datetime(stats.loc[0, "MIN_LOAD_DATE"]).normalize()
    raw_max_date = pd.to_datetime(stats.loc[0, "MAX_LOAD_DATE"]).normalize()
    max_date = pd.to_datetime(end_date).normalize() if end_date else raw_max_date
    min_date = max_date - pd.Timedelta(days=int(days) - 1)

    log(f"Detected raw date range: {raw_min_date.date()} to {raw_max_date.date()}; distinct load days={int(stats.loc[0, 'DISTINCT_LOAD_DAYS'])}", indent=1)
    log(f"Analysis window selected: {min_date.date()} to {max_date.date()} ({days} requested days)", indent=1)
    log(f"Latest candidate date: {max_date.date()}", indent=1)
    if context_cols:
        log(f"Latest candidate context columns retained for reference matching: {', '.join(context_cols)}", indent=1)

    server_filter_sql = ""
    if server_id_filter:
        server_filter_sql = f"AND SERVER_ID = {sql_string(server_id_filter.strip().upper())}"

    raw_select_parts = [
        f"{date_expr} AS LOAD_DATE",
        f"{ecgi_expr} AS ECGI",
        *meta_selects,
        *context_selects,
        f"{db_mismatch_expr} AS DB_MISMATCH",
    ]
    raw_select_sql = ",\n            ".join(raw_select_parts)

    final_context_selects = [f"ANY_VALUE({quote_ident(c)}) AS {quote_ident(c)}" for c in context_cols]
    final_select_parts = [
        "ECGI",
        "ANY_VALUE(REGION) AS REGION",
        "ANY_VALUE(MARKETCLUSTER) AS MARKETCLUSTER",
        "ANY_VALUE(MARKET) AS MARKET",
        "ANY_VALUE(SUBMARKET) AS SUBMARKET",
        "ANY_VALUE(SERVER_ID) AS SERVER_ID",
        *final_context_selects,
        "COUNT(*) AS LATEST_DB_MISMATCH_RAW_ROWS",
        f"DATE {sql_string(str(max_date.date()))} AS LATEST_CANDIDATE_DATE",
    ]
    final_select_sql = ",\n        ".join(final_select_parts)

    con.execute("DROP TABLE IF EXISTS candidate_ecgis")
    candidate_sql = f"""
    CREATE TABLE candidate_ecgis AS
    WITH raw AS (
        SELECT
            {raw_select_sql}
        FROM read_csv_auto({file_sql}, HEADER=TRUE, ALL_VARCHAR=TRUE, SAMPLE_SIZE=100000, IGNORE_ERRORS=TRUE)
    ), latest_mismatch_rows AS (
        SELECT *
        FROM raw
        WHERE LOAD_DATE = DATE {sql_string(str(max_date.date()))}
          AND DB_MISMATCH = 'YES'
          AND ECGI IS NOT NULL AND ECGI <> ''
          {server_filter_sql}
    )
    SELECT
        {final_select_sql}
    FROM latest_mismatch_rows
    GROUP BY ECGI
    """
    con.execute(candidate_sql)

    raw_latest_stats_sql = f"""
    WITH raw AS (
        SELECT
            {date_expr} AS LOAD_DATE,
            {ecgi_expr} AS ECGI,
            {', '.join(meta_selects)},
            {db_mismatch_expr} AS DB_MISMATCH
        FROM read_csv_auto({file_sql}, HEADER=TRUE, ALL_VARCHAR=TRUE, SAMPLE_SIZE=100000, IGNORE_ERRORS=TRUE)
    )
    SELECT
        COUNT(*) AS LATEST_RAW_ROWS,
        SUM(CASE WHEN DB_MISMATCH = 'YES' THEN 1 ELSE 0 END) AS LATEST_DB_MISMATCH_YES_ROWS,
        COUNT(DISTINCT ECGI) FILTER (WHERE DB_MISMATCH = 'YES') AS LATEST_DB_MISMATCH_YES_ECGIS
    FROM raw
    WHERE LOAD_DATE = DATE {sql_string(str(max_date.date()))}
      {server_filter_sql}
    """
    raw_latest_stats = con.execute(raw_latest_stats_sql).fetchdf().iloc[0].to_dict()
    candidate_count = int(con.execute("SELECT COUNT(*) FROM candidate_ecgis").fetchone()[0] or 0)
    log(f"Latest-day raw rows scanned: {int(raw_latest_stats.get('LATEST_RAW_ROWS') or 0):,}", indent=1)
    log(f"Latest-day DB_MISMATCH='YES' raw rows: {int(raw_latest_stats.get('LATEST_DB_MISMATCH_YES_ROWS') or 0):,}", indent=1)
    log(f"Distinct candidate ECGIs: {candidate_count:,}", indent=1)

    if candidate_count == 0:
        raise RuntimeError(f"No candidate ECGIs found for LOAD_DATE={max_date.date()} with DB_MISMATCH='YES'.")

    return {
        "script_version": SCRIPT_VERSION,
        "input_file": str(input_path),
        "requested_days": int(days),
        "window_start_date": str(min_date.date()),
        "window_end_date": str(max_date.date()),
        "candidate_date": str(max_date.date()),
        "raw_min_load_date": str(raw_min_date.date()),
        "raw_max_load_date": str(raw_max_date.date()),
        "raw_distinct_load_days": int(stats.loc[0, "DISTINCT_LOAD_DAYS"]),
        "server_id_filter": server_id_filter or "",
        "latest_raw_rows": int(raw_latest_stats.get("LATEST_RAW_ROWS") or 0),
        "latest_db_mismatch_yes_rows": int(raw_latest_stats.get("LATEST_DB_MISMATCH_YES_ROWS") or 0),
        "latest_db_mismatch_candidate_ecgis": candidate_count,
        "candidate_context_columns": ",".join(context_cols),
        "ranking_mode": "hybrid signature engine + global/feature-wise IsolationForest + cluster fusion",
    }


def create_event_tables(con) -> None:
    con.execute("DROP TABLE IF EXISTS source_change_events")
    con.execute(
        """
        CREATE TABLE source_change_events (
            ECGI VARCHAR,
            FEATURE VARCHAR,
            LOAD_DATE DATE,
            PREVIOUS_LOAD_DATE DATE,
            PREVIOUS_SOURCE_VALUE VARCHAR,
            CURRENT_SOURCE_VALUE VARCHAR,
            RAW_ROWS_PER_ECGI_DATE BIGINT,
            SOURCE_VALUES_UNIQUE_COUNT BIGINT,
            REGION VARCHAR,
            MARKETCLUSTER VARCHAR,
            MARKET VARCHAR,
            SUBMARKET VARCHAR,
            SERVER_ID VARCHAR,
            A_B_A_REVERT_FLAG INTEGER
        )
        """
    )
    con.execute("DROP TABLE IF EXISTS source_same_day_conflicts")
    con.execute(
        """
        CREATE TABLE source_same_day_conflicts (
            ECGI VARCHAR,
            FEATURE VARCHAR,
            LOAD_DATE DATE,
            REPRESENTATIVE_SOURCE_VALUE VARCHAR,
            SOURCE_VALUES_UNIQUE_COUNT BIGINT,
            RAW_ROWS_PER_ECGI_DATE BIGINT,
            REGION VARCHAR,
            MARKETCLUSTER VARCHAR,
            MARKET VARCHAR,
            SUBMARKET VARCHAR,
            SERVER_ID VARCHAR
        )
        """
    )
    con.execute("DROP TABLE IF EXISTS source_feature_history_metrics")
    con.execute(
        """
        CREATE TABLE source_feature_history_metrics (
            ECGI VARCHAR,
            FEATURE VARCHAR,
            REGION VARCHAR,
            MARKETCLUSTER VARCHAR,
            MARKET VARCHAR,
            SUBMARKET VARCHAR,
            SERVER_ID VARCHAR,
            OBSERVED_DAYS_FOR_FEATURE BIGINT,
            FIRST_OBSERVED_DATE DATE,
            LAST_OBSERVED_DATE DATE,
            FIRST_SOURCE_VALUE VARCHAR,
            LATEST_SOURCE_VALUE VARCHAR,
            PREVIOUS_NONLATEST_SOURCE_VALUE VARCHAR,
            DISTINCT_SOURCE_VALUES_30D BIGINT,
            MODE_SOURCE_VALUE VARCHAR,
            MODE_SOURCE_VALUE_DAYS BIGINT,
            MODE_SOURCE_VALUE_SHARE_PERCENT DOUBLE,
            LATEST_SOURCE_VALUE_DAYS BIGINT,
            LATEST_SOURCE_VALUE_FIRST_SEEN_DATE DATE,
            LATEST_SOURCE_VALUE_LAST_SEEN_DATE DATE,
            RAW_ROWS_FOR_FEATURE BIGINT,
            DB_CHECK_AVAILABLE_FLAG INTEGER,
            FIRST_DB_VALUE VARCHAR,
            LATEST_DB_VALUE VARCHAR,
            PREVIOUS_NONLATEST_DB_VALUE VARCHAR,
            DISTINCT_DB_VALUES_30D BIGINT,
            LATEST_DB_VALUE_DAYS BIGINT,
            DB_VALUE_PRESENT_DAYS BIGINT,
            SOURCE_DB_MISMATCH_DAYS BIGINT,
            LATEST_SOURCE_DB_MISMATCH_FLAG INTEGER
        )
        """
    )


def insert_history_metrics_for_feature(con, feature: str, has_db_value: bool) -> None:
    val = quote_ident(feature + "__VALUE")
    db_val = quote_ident(feature + "__DB_VALUE") if has_db_value else "CAST(NULL AS VARCHAR)"
    fsql = sql_string(feature)

    insert_sql = f"""
    INSERT INTO source_feature_history_metrics
    WITH daily AS (
        SELECT
            ECGI,
            LOAD_DATE,
            {val} AS SOURCE_VALUE,
            {db_val} AS DB_VALUE,
            RAW_ROWS_PER_ECGI_DATE,
            REGION,
            MARKETCLUSTER,
            MARKET,
            SUBMARKET,
            SERVER_ID
        FROM feature_daily_batch
        WHERE {val} IS NOT NULL
    ), agg AS (
        SELECT
            ECGI,
            ANY_VALUE(REGION) AS REGION,
            ANY_VALUE(MARKETCLUSTER) AS MARKETCLUSTER,
            ANY_VALUE(MARKET) AS MARKET,
            ANY_VALUE(SUBMARKET) AS SUBMARKET,
            ANY_VALUE(SERVER_ID) AS SERVER_ID,
            COUNT(*) AS OBSERVED_DAYS_FOR_FEATURE,
            MIN(LOAD_DATE) AS FIRST_OBSERVED_DATE,
            MAX(LOAD_DATE) AS LAST_OBSERVED_DATE,
            COUNT(DISTINCT SOURCE_VALUE) AS DISTINCT_SOURCE_VALUES_30D,
            SUM(RAW_ROWS_PER_ECGI_DATE) AS RAW_ROWS_FOR_FEATURE,
            COUNT(*) FILTER (WHERE DB_VALUE IS NOT NULL) AS DB_VALUE_PRESENT_DAYS,
            COUNT(DISTINCT DB_VALUE) FILTER (WHERE DB_VALUE IS NOT NULL) AS DISTINCT_DB_VALUES_30D,
            SUM(CASE WHEN SOURCE_VALUE IS NOT NULL AND DB_VALUE IS NOT NULL AND SOURCE_VALUE <> DB_VALUE THEN 1 ELSE 0 END) AS SOURCE_DB_MISMATCH_DAYS
        FROM daily
        GROUP BY ECGI
    ), first_value AS (
        SELECT ECGI, SOURCE_VALUE AS FIRST_SOURCE_VALUE, DB_VALUE AS FIRST_DB_VALUE
        FROM (
            SELECT ECGI, SOURCE_VALUE, DB_VALUE, LOAD_DATE,
                   ROW_NUMBER() OVER (PARTITION BY ECGI ORDER BY LOAD_DATE ASC, SOURCE_VALUE ASC) AS rn
            FROM daily
        ) x
        WHERE rn = 1
    ), latest_value AS (
        SELECT ECGI, SOURCE_VALUE AS LATEST_SOURCE_VALUE, DB_VALUE AS LATEST_DB_VALUE
        FROM (
            SELECT ECGI, SOURCE_VALUE, DB_VALUE, LOAD_DATE,
                   ROW_NUMBER() OVER (PARTITION BY ECGI ORDER BY LOAD_DATE DESC, SOURCE_VALUE ASC) AS rn
            FROM daily
        ) x
        WHERE rn = 1
    ), previous_nonlatest AS (
        SELECT ECGI, SOURCE_VALUE AS PREVIOUS_NONLATEST_SOURCE_VALUE
        FROM (
            SELECT d.ECGI, d.SOURCE_VALUE, d.LOAD_DATE,
                   ROW_NUMBER() OVER (PARTITION BY d.ECGI ORDER BY d.LOAD_DATE DESC, d.SOURCE_VALUE ASC) AS rn
            FROM daily d
            JOIN latest_value l ON d.ECGI = l.ECGI
            WHERE d.SOURCE_VALUE <> l.LATEST_SOURCE_VALUE
        ) x
        WHERE rn = 1
    ), previous_nonlatest_db AS (
        SELECT ECGI, DB_VALUE AS PREVIOUS_NONLATEST_DB_VALUE
        FROM (
            SELECT d.ECGI, d.DB_VALUE, d.LOAD_DATE,
                   ROW_NUMBER() OVER (PARTITION BY d.ECGI ORDER BY d.LOAD_DATE DESC, d.DB_VALUE ASC) AS rn
            FROM daily d
            JOIN latest_value l ON d.ECGI = l.ECGI
            WHERE d.DB_VALUE IS NOT NULL AND l.LATEST_DB_VALUE IS NOT NULL AND d.DB_VALUE <> l.LATEST_DB_VALUE
        ) x
        WHERE rn = 1
    ), source_value_counts AS (
        SELECT
            ECGI,
            SOURCE_VALUE,
            COUNT(*) AS VALUE_DAYS,
            MIN(LOAD_DATE) AS VALUE_FIRST_SEEN_DATE,
            MAX(LOAD_DATE) AS VALUE_LAST_SEEN_DATE
        FROM daily
        GROUP BY ECGI, SOURCE_VALUE
    ), mode_value AS (
        SELECT ECGI,
               SOURCE_VALUE AS MODE_SOURCE_VALUE,
               VALUE_DAYS AS MODE_SOURCE_VALUE_DAYS
        FROM (
            SELECT ECGI, SOURCE_VALUE, VALUE_DAYS,
                   ROW_NUMBER() OVER (PARTITION BY ECGI ORDER BY VALUE_DAYS DESC, SOURCE_VALUE ASC) AS rn
            FROM source_value_counts
        ) x
        WHERE rn = 1
    ), latest_counts AS (
        SELECT
            v.ECGI,
            v.VALUE_DAYS AS LATEST_SOURCE_VALUE_DAYS,
            v.VALUE_FIRST_SEEN_DATE AS LATEST_SOURCE_VALUE_FIRST_SEEN_DATE,
            v.VALUE_LAST_SEEN_DATE AS LATEST_SOURCE_VALUE_LAST_SEEN_DATE
        FROM source_value_counts v
        JOIN latest_value l ON v.ECGI = l.ECGI AND v.SOURCE_VALUE = l.LATEST_SOURCE_VALUE
    ), db_value_counts AS (
        SELECT ECGI, DB_VALUE, COUNT(*) AS DB_VALUE_DAYS
        FROM daily
        WHERE DB_VALUE IS NOT NULL
        GROUP BY ECGI, DB_VALUE
    ), latest_db_counts AS (
        SELECT v.ECGI, v.DB_VALUE_DAYS AS LATEST_DB_VALUE_DAYS
        FROM db_value_counts v
        JOIN latest_value l ON v.ECGI = l.ECGI AND v.DB_VALUE = l.LATEST_DB_VALUE
    )
    SELECT
        a.ECGI,
        {fsql} AS FEATURE,
        a.REGION,
        a.MARKETCLUSTER,
        a.MARKET,
        a.SUBMARKET,
        a.SERVER_ID,
        a.OBSERVED_DAYS_FOR_FEATURE,
        a.FIRST_OBSERVED_DATE,
        a.LAST_OBSERVED_DATE,
        f.FIRST_SOURCE_VALUE,
        l.LATEST_SOURCE_VALUE,
        p.PREVIOUS_NONLATEST_SOURCE_VALUE,
        a.DISTINCT_SOURCE_VALUES_30D,
        m.MODE_SOURCE_VALUE,
        m.MODE_SOURCE_VALUE_DAYS,
        100.0 * COALESCE(m.MODE_SOURCE_VALUE_DAYS, 0) / NULLIF(a.OBSERVED_DAYS_FOR_FEATURE, 0) AS MODE_SOURCE_VALUE_SHARE_PERCENT,
        lc.LATEST_SOURCE_VALUE_DAYS,
        lc.LATEST_SOURCE_VALUE_FIRST_SEEN_DATE,
        lc.LATEST_SOURCE_VALUE_LAST_SEEN_DATE,
        a.RAW_ROWS_FOR_FEATURE,
        CASE WHEN {1 if has_db_value else 0} = 1 AND COALESCE(a.DB_VALUE_PRESENT_DAYS, 0) > 0 THEN 1 ELSE 0 END AS DB_CHECK_AVAILABLE_FLAG,
        f.FIRST_DB_VALUE,
        l.LATEST_DB_VALUE,
        pdb.PREVIOUS_NONLATEST_DB_VALUE,
        COALESCE(a.DISTINCT_DB_VALUES_30D, 0) AS DISTINCT_DB_VALUES_30D,
        COALESCE(ldc.LATEST_DB_VALUE_DAYS, 0) AS LATEST_DB_VALUE_DAYS,
        COALESCE(a.DB_VALUE_PRESENT_DAYS, 0) AS DB_VALUE_PRESENT_DAYS,
        COALESCE(a.SOURCE_DB_MISMATCH_DAYS, 0) AS SOURCE_DB_MISMATCH_DAYS,
        CASE WHEN l.LATEST_SOURCE_VALUE IS NOT NULL AND l.LATEST_DB_VALUE IS NOT NULL AND l.LATEST_SOURCE_VALUE <> l.LATEST_DB_VALUE THEN 1 ELSE 0 END AS LATEST_SOURCE_DB_MISMATCH_FLAG
    FROM agg a
    LEFT JOIN first_value f ON a.ECGI = f.ECGI
    LEFT JOIN latest_value l ON a.ECGI = l.ECGI
    LEFT JOIN previous_nonlatest p ON a.ECGI = p.ECGI
    LEFT JOIN previous_nonlatest_db pdb ON a.ECGI = pdb.ECGI
    LEFT JOIN mode_value m ON a.ECGI = m.ECGI
    LEFT JOIN latest_counts lc ON a.ECGI = lc.ECGI
    LEFT JOIN latest_db_counts ldc ON a.ECGI = ldc.ECGI
    """
    con.execute(insert_sql)


def create_candidate_source_history_batched(
    con,
    input_path: Path,
    colmap: Dict[str, str],
    date_col_clean: str,
    features: List[str],
    analysis_info: Dict[str, Any],
    latlon_decimals: int,
    feature_batch_size: int,
    enable_db_push_check: bool,
) -> None:
    header("PHASE 1C - BUILD SOURCE HISTORY FOR CANDIDATE ECGIS")
    log("Only latest-day DB_MISMATCH candidate ECGIs are pulled into the history scan.", indent=1)
    if enable_db_push_check:
        log("Narrow FEATURE_DB history is enabled only for AUDIT_PUSH_NOT_APPLIED logic.", indent=1)
    else:
        log("FEATURE_DB columns are not used. Stable-source rows are retained for optional DB-push review.", indent=1)

    file_sql = sql_path(input_path)
    date_expr = date_parse_expr(colmap[date_col_clean])
    ecgi_sql = ecgi_expr_from_columns(colmap)
    min_date_sql = analysis_info["window_start_date"]
    max_date_sql = analysis_info["window_end_date"]

    create_event_tables(con)

    meta_selects = []
    for m in META_COLS:
        if m in colmap:
            meta_selects.append(f"{compact_norm_expr(quote_ident(colmap[m]))} AS {quote_ident(m)}")
        else:
            meta_selects.append(f"NULL AS {quote_ident(m)}")

    batches = chunks_list(features, feature_batch_size)
    log(f"Processing {len(features)} feature(s) in {len(batches)} batch(es); feature_batch_size={feature_batch_size}", indent=1)

    total_daily_rows = 0
    db_cols_available: List[str] = []
    for batch_no, batch in enumerate(batches, start=1):
        log(f"Feature batch {batch_no}/{len(batches)}: {', '.join(batch)}", indent=1)
        batch_start = time.time()

        feature_selects = []
        for f in batch:
            feature_selects.append(f"{feature_norm_expr(colmap[f], f, latlon_decimals)} AS {quote_ident(f)}")
            db_clean = f"{f}_DB"
            if enable_db_push_check and db_clean in colmap:
                feature_selects.append(f"{feature_norm_expr(colmap[db_clean], f, latlon_decimals)} AS {quote_ident(f + '_DB')}")
                db_cols_available.append(f)
        raw_cte_select = ",\n                ".join([f"{date_expr} AS LOAD_DATE", f"{ecgi_sql} AS ECGI", *meta_selects, *feature_selects])

        agg_parts = [
            "ANY_VALUE(REGION) AS REGION",
            "ANY_VALUE(MARKETCLUSTER) AS MARKETCLUSTER",
            "ANY_VALUE(MARKET) AS MARKET",
            "ANY_VALUE(SUBMARKET) AS SUBMARKET",
            "ANY_VALUE(SERVER_ID) AS SERVER_ID",
            "COUNT(*) AS RAW_ROWS_PER_ECGI_DATE",
        ]
        for f in batch:
            fq = quote_ident(f)
            agg_parts.append(f"MIN({fq}) FILTER (WHERE {fq} IS NOT NULL) AS {quote_ident(f + '__VALUE')}")
            agg_parts.append(f"COUNT(DISTINCT {fq}) FILTER (WHERE {fq} IS NOT NULL) AS {quote_ident(f + '__UNIQUE_COUNT')}")
            db_clean = f"{f}_DB"
            if enable_db_push_check and db_clean in colmap:
                dbq = quote_ident(db_clean)
                agg_parts.append(f"MIN({dbq}) FILTER (WHERE {dbq} IS NOT NULL) AS {quote_ident(f + '__DB_VALUE')}")
                agg_parts.append(f"COUNT(DISTINCT {dbq}) FILTER (WHERE {dbq} IS NOT NULL) AS {quote_ident(f + '__DB_UNIQUE_COUNT')}")
            else:
                agg_parts.append(f"CAST(NULL AS VARCHAR) AS {quote_ident(f + '__DB_VALUE')}")
                agg_parts.append(f"CAST(0 AS BIGINT) AS {quote_ident(f + '__DB_UNIQUE_COUNT')}")
        agg_sql = ",\n            ".join(agg_parts)

        con.execute("DROP TABLE IF EXISTS feature_daily_batch")
        create_batch_sql = f"""
        CREATE TEMPORARY TABLE feature_daily_batch AS
        WITH raw AS (
            SELECT
                {raw_cte_select}
            FROM read_csv_auto({file_sql}, HEADER=TRUE, ALL_VARCHAR=TRUE, SAMPLE_SIZE=100000, IGNORE_ERRORS=TRUE)
        ), filtered AS (
            SELECT r.*
            FROM raw r
            JOIN candidate_ecgis c ON r.ECGI = c.ECGI
            WHERE r.LOAD_DATE BETWEEN DATE {sql_string(min_date_sql)} AND DATE {sql_string(max_date_sql)}
              AND r.ECGI IS NOT NULL AND r.ECGI <> ''
        )
        SELECT
            LOAD_DATE,
            ECGI,
            {agg_sql}
        FROM filtered
        GROUP BY LOAD_DATE, ECGI
        """
        con.execute(create_batch_sql)
        daily_rows = int(con.execute("SELECT COUNT(*) FROM feature_daily_batch").fetchone()[0] or 0)
        total_daily_rows += daily_rows
        log(f"Candidate ECGI/day rows in batch: {daily_rows:,}", indent=2)

        for f in batch:
            log(f"Extracting source history metrics/events for {f}", indent=2)
            val = quote_ident(f + "__VALUE")
            uniq = quote_ident(f + "__UNIQUE_COUNT")
            fsql = sql_string(f)
            has_db_value = bool(enable_db_push_check and f"{f}_DB" in colmap)
            insert_history_metrics_for_feature(con, f, has_db_value=has_db_value)

            change_sql = f"""
            INSERT INTO source_change_events
            SELECT
                ECGI,
                {fsql} AS FEATURE,
                LOAD_DATE,
                PREVIOUS_LOAD_DATE,
                PREVIOUS_SOURCE_VALUE,
                CURRENT_SOURCE_VALUE,
                RAW_ROWS_PER_ECGI_DATE,
                SOURCE_VALUES_UNIQUE_COUNT,
                REGION,
                MARKETCLUSTER,
                MARKET,
                SUBMARKET,
                SERVER_ID,
                CASE
                    WHEN TWO_OBS_BACK_SOURCE_VALUE IS NOT NULL
                     AND CURRENT_SOURCE_VALUE = TWO_OBS_BACK_SOURCE_VALUE
                     AND CURRENT_SOURCE_VALUE <> PREVIOUS_SOURCE_VALUE
                    THEN 1 ELSE 0
                END AS A_B_A_REVERT_FLAG
            FROM (
                SELECT
                    ECGI,
                    LOAD_DATE,
                    LAG(LOAD_DATE) OVER (PARTITION BY ECGI ORDER BY LOAD_DATE) AS PREVIOUS_LOAD_DATE,
                    LAG({val}) OVER (PARTITION BY ECGI ORDER BY LOAD_DATE) AS PREVIOUS_SOURCE_VALUE,
                    LAG({val}, 2) OVER (PARTITION BY ECGI ORDER BY LOAD_DATE) AS TWO_OBS_BACK_SOURCE_VALUE,
                    {val} AS CURRENT_SOURCE_VALUE,
                    RAW_ROWS_PER_ECGI_DATE,
                    {uniq} AS SOURCE_VALUES_UNIQUE_COUNT,
                    REGION,
                    MARKETCLUSTER,
                    MARKET,
                    SUBMARKET,
                    SERVER_ID
                FROM feature_daily_batch
                WHERE {val} IS NOT NULL
            ) x
            WHERE PREVIOUS_SOURCE_VALUE IS NOT NULL
              AND CURRENT_SOURCE_VALUE <> PREVIOUS_SOURCE_VALUE
            """
            con.execute(change_sql)

            conflict_sql = f"""
            INSERT INTO source_same_day_conflicts
            SELECT
                ECGI,
                {fsql} AS FEATURE,
                LOAD_DATE,
                {val} AS REPRESENTATIVE_SOURCE_VALUE,
                {uniq} AS SOURCE_VALUES_UNIQUE_COUNT,
                RAW_ROWS_PER_ECGI_DATE,
                REGION,
                MARKETCLUSTER,
                MARKET,
                SUBMARKET,
                SERVER_ID
            FROM feature_daily_batch
            WHERE COALESCE({uniq}, 0) > 1
            """
            con.execute(conflict_sql)

        changes_count = int(con.execute("SELECT COUNT(*) FROM source_change_events").fetchone()[0] or 0)
        conflicts_count = int(con.execute("SELECT COUNT(*) FROM source_same_day_conflicts").fetchone()[0] or 0)
        hist_count = int(con.execute("SELECT COUNT(*) FROM source_feature_history_metrics").fetchone()[0] or 0)
        con.execute("DROP TABLE IF EXISTS feature_daily_batch")
        log(f"Batch complete in {time.time() - batch_start:.1f}s; cumulative changes={changes_count:,}; conflicts={conflicts_count:,}; feature-history rows={hist_count:,}", indent=1)

    log(f"Total candidate ECGI/day rows processed across batches: {total_daily_rows:,}", indent=1)
    if enable_db_push_check:
        log(f"FEATURE_DB columns available for narrow push check: {len(set(db_cols_available)):,} ({', '.join(sorted(set(db_cols_available)))})", indent=1)


def load_compact_tables(con) -> Tuple[pd.DataFrame, pd.DataFrame, pd.DataFrame, pd.DataFrame]:
    header("PHASE 1D - LOAD COMPACT HISTORY TABLES")
    candidates = con.execute("SELECT * FROM candidate_ecgis").fetchdf()
    hist = con.execute("SELECT * FROM source_feature_history_metrics").fetchdf()
    changes = con.execute("SELECT * FROM source_change_events").fetchdf()
    conflicts = con.execute("SELECT * FROM source_same_day_conflicts").fetchdf()

    for df in [candidates, hist, changes, conflicts]:
        df.columns = [clean_col_name(c) for c in df.columns]
        for c in [
            "LOAD_DATE", "PREVIOUS_LOAD_DATE", "FIRST_OBSERVED_DATE", "LAST_OBSERVED_DATE",
            "LATEST_SOURCE_VALUE_FIRST_SEEN_DATE", "LATEST_SOURCE_VALUE_LAST_SEEN_DATE",
            "LATEST_CANDIDATE_DATE",
        ]:
            if c in df.columns:
                df[c] = pd.to_datetime(df[c], errors="coerce").dt.normalize()
        if "ECGI" in df.columns:
            df["ECGI"] = df["ECGI"].map(normalize_key_value)
        if "FEATURE" in df.columns:
            df["FEATURE"] = df["FEATURE"].map(clean_col_name)

    value_cols = [
        "FIRST_SOURCE_VALUE", "LATEST_SOURCE_VALUE", "PREVIOUS_NONLATEST_SOURCE_VALUE", "MODE_SOURCE_VALUE",
        "FIRST_DB_VALUE", "LATEST_DB_VALUE", "PREVIOUS_NONLATEST_DB_VALUE",
        "PREVIOUS_SOURCE_VALUE", "CURRENT_SOURCE_VALUE", "REPRESENTATIVE_SOURCE_VALUE",
    ]
    for c in value_cols:
        for df in [hist, changes, conflicts]:
            if c in df.columns:
                df[c] = df[c].map(normalize_value_text)

    log(f"Candidate ECGIs: {len(candidates):,}", indent=1)
    log(f"Feature-history metric rows: {len(hist):,}", indent=1)
    log(f"Source-change event rows: {len(changes):,}", indent=1)
    log(f"Same-day conflict rows: {len(conflicts):,}", indent=1)
    return candidates, hist, changes, conflicts


