def elapsed_text() -> str:
    seconds = int(time.time() - RUN_START_TIME)
    h, rem = divmod(seconds, 3600)
    m, s = divmod(rem, 60)
    return f"{h:02d}:{m:02d}:{s:02d}"


def log(message: str, indent: int = 0) -> None:
    prefix = "  " * max(0, int(indent))
    print(f"[{time.strftime('%H:%M:%S')} | +{elapsed_text()}] {prefix}{message}", flush=True)


def header(title: str) -> None:
    print("\n" + "=" * 110, flush=True)
    log(title)
    print("=" * 110, flush=True)


def clean_col_name(c: object) -> str:
    return str(c).strip().strip('"').upper()


def normalize_key_value(x: object) -> str:
    if pd.isna(x):
        return ""
    s = str(x).strip().strip('"')
    if s.upper() in NULL_STRINGS:
        return ""
    s = re.sub(r"\.0$", "", s)
    s = re.sub(r"\s+", "", s)
    return s.upper()


def normalize_value_text(x: object) -> str:
    if pd.isna(x):
        return ""
    s = str(x).strip().strip('"')
    if s.upper() in NULL_STRINGS:
        return ""
    try:
        f = float(s)
        if math.isfinite(f):
            if abs(f - round(f)) < 1e-12:
                return str(int(round(f)))
            return f"{f:.10f}".rstrip("0").rstrip(".").upper()
    except Exception:
        pass
    s = re.sub(r"\s+", "", s)
    return s.upper()


def excel_safe_ecgi(ecgi: object) -> str:
    s = normalize_key_value(ecgi)
    return f"ECGI_{s}" if s else ""


def short_value(v: object, max_len: int = 80) -> str:
    if pd.isna(v):
        return "<missing>"
    s = str(v)
    return s if len(s) <= max_len else s[: max_len - 3] + "..."


def transition_text(prev_value: object, current_value: object) -> str:
    return f"{short_value(prev_value)} -> {short_value(current_value)}"


def safe_numeric(series: Any, default: float = 0.0) -> pd.Series:
    if isinstance(series, pd.Series):
        idx = series.index
        s = series
    else:
        idx = None
        s = pd.Series(series)
    out = pd.to_numeric(s, errors="coerce").replace([np.inf, -np.inf], np.nan).fillna(default)
    if idx is not None:
        out.index = idx
    return out


def percentile_rank(series: pd.Series) -> pd.Series:
    s = safe_numeric(series)
    if len(s) == 0:
        return s
    if s.nunique(dropna=False) <= 1:
        return pd.Series(np.ones(len(s)) * 50.0, index=s.index)
    return s.rank(method="average", pct=True) * 100.0


def first_existing(cols: Iterable[str], candidates: Iterable[str]) -> Optional[str]:
    cset = set(cols)
    for c in candidates:
        if c in cset:
            return c
    return None


def is_id_like_col(col: str) -> bool:
    c = clean_col_name(col)
    return c in ID_LIKE_EXACT or c.endswith("_ID") or c.endswith("ID") or "CELLID" in c


def is_numeric_config_col(col: str) -> bool:
    c = clean_col_name(col)
    if is_id_like_col(c):
        return False
    return any(term in c for term in NUMERIC_CONFIG_TERMS)


def quote_ident(name: str) -> str:
    return '"' + str(name).replace('"', '""') + '"'


def sql_string(value: str) -> str:
    return "'" + str(value).replace("'", "''") + "'"


def sql_path(path: Path) -> str:
    return sql_string(str(path).replace("\\", "/"))


def chunks_list(items: List[str], size: int) -> List[List[str]]:
    size = max(1, int(size))
    return [items[i : i + size] for i in range(0, len(items), size)]


def series_text(df: pd.DataFrame, col: str, default: str = "") -> pd.Series:
    if col in df.columns:
        return df[col].fillna(default).astype(str)
    return pd.Series(default, index=df.index, dtype="object")


def series_num(df: pd.DataFrame, col: str, default: float = 0.0) -> pd.Series:
    if col in df.columns:
        return safe_numeric(df[col], default)
    return pd.Series(default, index=df.index, dtype="float64")


def safe_float(x: Any, default: float = 0.0) -> float:
    try:
        v = float(x)
        return v if math.isfinite(v) else default
    except Exception:
        return default


def safe_filename(s: Any, max_len: int = 120) -> str:
    s = str(s or "")
    s = re.sub(r"[^A-Za-z0-9._-]+", "_", s).strip("_")
    return (s[:max_len] or "item")


def date_str(x: Any) -> str:
    dt = pd.to_datetime(x, errors="coerce")
    if pd.isna(dt):
        return ""
    return str(dt.date())


def feature_family(feature: Any) -> str:
    f = clean_col_name(feature)
    if f in {"ANTENNALAT", "ANTENNALON"}:
        return "LOCATION"
    if any(t in f for t in ["ORIENTATION", "OPENING", "AZIMUTH", "BEAM", "HORIZONTALRANGE", "RADIUS"]):
        return "RF_COVERAGE"
    if any(t in f for t in ["ALT", "ALTITUDE", "UNCERT"]):
        return "ALTITUDE"
    if f in {"PHYSICALCELLID", "CELLNAME", "CELLTYPE", "GEOTYPE"} or "CELL" in f:
        return "CELL_IDENTITY"
    if "TECH" in f:
        return "TECHNOLOGY"
    return "OTHER"


def severity_band_from_risk(x: Any) -> str:
    v = safe_float(x)
    if v >= 85:
        return "CRITICAL"
    if v >= 70:
        return "HIGH"
    if v >= 50:
        return "MEDIUM"
    if v >= 30:
        return "LOW"
    return "LOW_RISK_OR_INFORMATIONAL"


