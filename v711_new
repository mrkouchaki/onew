def parse_args() -> argparse.Namespace:
    p = argparse.ArgumentParser(description="CESMLC V7.1 standalone hybrid signature + IsolationForest anomaly detector.")
    p.add_argument("--input", required=True, type=str, help="Raw CESMLC CSV input.")
    p.add_argument("--days", default=35, type=int, help="Analysis window length ending at --end-date or max LOAD_DATE.")
    p.add_argument("--end-date", default=None, type=str, help="Optional candidate/latest date YYYY-MM-DD. Default: max parsed LOAD_DATE.")
    p.add_argument("--out-dir", default=None, type=str, help="Output folder.")
    p.add_argument("--server-id", default=None, type=str, help="Optional SERVER_ID filter for latest-day candidate extraction.")
    p.add_argument("--include-features", default=",".join(DEFAULT_FEATURES), type=str, help="Comma-separated source/current feature columns to analyze.")
    p.add_argument("--exclude-features", default=None, type=str, help="Comma-separated features to exclude.")
    p.add_argument("--defaults-json", default=None, type=str, help="Optional JSON overriding default values, valid ranges, criticality weights.")

    p.add_argument("--reference-source-dir", default=None, type=str, help="Folder containing optional RAN reference CSVs.")
    p.add_argument("--atoll-master-4g", default=None, type=str, help="Optional path to atoll_master_4g.csv.")
    p.add_argument("--ericsson-5g-master-data", default=None, type=str, help="Optional path to ericsson_5g_master_data.csv.")
    p.add_argument("--cssng-data-addition", default=None, type=str, help="Optional path to cssng_data_addition.csv.")
    p.add_argument("--atoll-cells5g", default=None, type=str, help="Optional path to atoll_cells5g.csv.")
    p.add_argument("--reference-mapping-json", default=None, type=str, help="Optional JSON mapping CESMLC feature names to reference-source column candidates.")
    p.add_argument("--disable-reference-compatibility", action="store_true", help="Skip RAN reference-source compatibility.")
    p.add_argument("--reference-numeric-tolerance", default=0.00005, type=float, help="Default numeric tolerance for reference matching.")

    p.add_argument("--enable-db-push-check", action="store_true", help="Use FEATURE_DB columns only for narrow AUDIT_PUSH_NOT_APPLIED seed/check.")
    p.add_argument("--push-source-stable-days", default=2, type=int)
    p.add_argument("--push-mismatch-days", default=2, type=int)

    p.add_argument("--latlon-decimals", default=5, type=int)
