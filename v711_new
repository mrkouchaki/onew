def import_duckdb():
    try:
        import duckdb  # type: ignore
        return duckdb
    except Exception as exc:
        raise RuntimeError(
            "DuckDB is required for large CESMLC CSV processing. Install once with:\n"
            "  python -m pip install duckdb\n"
            f"Original import error: {exc}"
        ) from exc


def open_duckdb(temp_db_path: Optional[Path], threads: int, memory_limit: Optional[str], duckdb_temp_dir: Optional[Path] = None):
    log("Opening DuckDB connection")
    duckdb = import_duckdb()
    if temp_db_path:
        temp_db_path.parent.mkdir(parents=True, exist_ok=True)
        log(f"DuckDB database file: {temp_db_path}", indent=1)
        con = duckdb.connect(str(temp_db_path))
    else:
        log("DuckDB database: in-memory", indent=1)
        con = duckdb.connect()
    try:
        con.execute("SET preserve_insertion_order=false")
    except Exception:
        pass
    if duckdb_temp_dir:
        duckdb_temp_dir.mkdir(parents=True, exist_ok=True)
        log(f"DuckDB spill/temp directory: {duckdb_temp_dir}", indent=1)
        try:
            con.execute(f"SET temp_directory={sql_string(str(duckdb_temp_dir))}")
        except Exception as exc:
            log(f"Warning: could not set DuckDB temp_directory: {exc}", indent=1)
    if threads and threads > 0:
        con.execute(f"PRAGMA threads={int(threads)}")
    if memory_limit:
        con.execute(f"PRAGMA memory_limit={sql_string(memory_limit)}")
    log(f"DuckDB settings: threads={threads}, memory_limit={memory_limit or 'default'}", indent=1)
    return con


def base_norm_expr(sql_expr: str) -> str:
    cleaned = f"UPPER(REGEXP_REPLACE(TRIM(CAST({sql_expr} AS VARCHAR)), '\\\\.0$', ''))"
    null_list = ", ".join(sql_string(x) for x in sorted(NULL_STRINGS))
    return f"CASE WHEN {sql_expr} IS NULL THEN NULL WHEN {cleaned} IN ({null_list}) THEN NULL ELSE {cleaned} END"


def compact_norm_expr(sql_expr: str) -> str:
    base = base_norm_expr(sql_expr)
    return f"CASE WHEN {base} IS NULL THEN NULL ELSE REGEXP_REPLACE({base}, '\\s+', '') END"


def feature_norm_expr(original_col: str, feature: str, latlon_decimals: int) -> str:
    q = quote_ident(original_col)
    base = compact_norm_expr(q)
    if is_numeric_config_col(feature):
        decimals = latlon_decimals if any(t in clean_col_name(feature) for t in ["LAT", "LON", "LONG"]) else 4
        return (
            f"CASE WHEN {base} IS NULL THEN NULL "
            f"WHEN TRY_CAST({base} AS DOUBLE) IS NOT NULL "
            f"THEN CAST(ROUND(TRY_CAST({base} AS DOUBLE), {int(decimals)}) AS VARCHAR) "
            f"ELSE {base} END"
        )
    return base


def date_parse_expr(original_col: str) -> str:
    q = quote_ident(original_col)
    trimmed = f"TRIM(CAST({q} AS VARCHAR))"
    return (
        "CAST(COALESCE("
        f"TRY_STRPTIME({trimmed}, '%Y-%m-%d %H:%M:%S'),"
        f"TRY_STRPTIME({trimmed}, '%Y-%m-%d'),"
        f"TRY_STRPTIME({trimmed}, '%m/%d/%Y %H:%M:%S'),"
        f"TRY_STRPTIME({trimmed}, '%m/%d/%Y'),"
        f"TRY_STRPTIME({trimmed}, '%d-%b-%y'),"
        f"TRY_STRPTIME({trimmed}, '%d-%b-%Y')"
        ") AS DATE)"
    )


def ecgi_expr_from_columns(colmap: Dict[str, str]) -> str:
    if "ECGI" in colmap:
        return compact_norm_expr(quote_ident(colmap["ECGI"]))
    required = ["MCC", "MNC", "CID"]
    if all(c in colmap for c in required):
        return (
            f"COALESCE({compact_norm_expr(quote_ident(colmap['MCC']))}, '') || '-' || "
            f"COALESCE({compact_norm_expr(quote_ident(colmap['MNC']))}, '') || '-' || "
            f"COALESCE({compact_norm_expr(quote_ident(colmap['CID']))}, '')"
        )
    raise ValueError("Input has no ECGI column and cannot build ECGI from MCC/MNC/CID.")


def read_header(input_path: Path) -> Tuple[List[str], Dict[str, str]]:
    log(f"Reading CSV header: {input_path}")
    header_df = pd.read_csv(input_path, nrows=0)
    original_cols = list(header_df.columns)
    log(f"Header columns detected: {len(original_cols):,}", indent=1)
    colmap = {clean_col_name(c): c for c in original_cols}
    return [clean_col_name(c) for c in original_cols], colmap


def detect_features(header_cols_clean: List[str], include_features: Optional[str], exclude_features: Optional[str]) -> List[str]:
    cols = set(header_cols_clean)
    if include_features:
        wanted = [clean_col_name(x) for x in include_features.split(",") if x.strip()]
    else:
        wanted = [f for f in DEFAULT_FEATURES if f in cols]
        skip = set(DATE_CANDIDATES + META_COLS + ["ECGI", "USID", "ON_AIR", "LAST_DB_MISMATCH", "DB_MISMATCH", "DELTA", "DELTA_STATUS_COLOR"])
        for c in header_cols_clean:
            if c.endswith("_DB") or c in wanted or c in skip:
                continue
            if is_numeric_config_col(c) or "NEIGHBOR" in c or c in {"CELLNAME", "CELLTYPE", "GEOTYPE"}:
                wanted.append(c)
    exclude = {clean_col_name(x) for x in exclude_features.split(",") if x.strip()} if exclude_features else set()
    return [f for f in wanted if f in cols and not f.endswith("_DB") and f not in exclude]


def load_feature_rules(defaults_json: Optional[str]) -> Dict[str, Dict[str, Any]]:
    rules = json.loads(json.dumps(BUILTIN_FEATURE_RULES))
    if defaults_json:
        p = Path(defaults_json).expanduser()
        if not p.exists():
            raise FileNotFoundError(f"--defaults-json file not found: {p}")
        extra = json.loads(p.read_text(encoding="utf-8"))
        # Accept either {feature:{rules}} or a wrapper object.
        if isinstance(extra, dict) and "feature_rules" in extra and isinstance(extra["feature_rules"], dict):
            extra = extra["feature_rules"]
        for k, v in (extra or {}).items():
            fk = clean_col_name(k)
            if not isinstance(v, dict):
                # Not a rules entry; ignore gracefully. This prevents a mapping JSON from destroying defaults.
                continue
            current = rules.get(fk, {})
            current.update(v or {})
            rules[fk] = current
    for _, cfg in rules.items():
        vals = cfg.get("default_values", []) or []
        cfg["default_values_norm"] = sorted({normalize_value_text(x) for x in vals if normalize_value_text(x)})
    return rules


def get_feature_weight(feature: str, rules: Dict[str, Dict[str, Any]]) -> float:
    return float(rules.get(clean_col_name(feature), {}).get("criticality_weight", 5.0))


def value_is_default(feature: str, value: object, rules: Dict[str, Dict[str, Any]]) -> int:
    f = clean_col_name(feature)
    v = normalize_value_text(value)
    defaults = set(rules.get(f, {}).get("default_values_norm", []))
    return int(bool(v and v in defaults))


def value_is_invalid(feature: str, value: object, rules: Dict[str, Dict[str, Any]]) -> int:
    f = clean_col_name(feature)
    cfg = rules.get(f, {})
    if "valid_min" not in cfg and "valid_max" not in cfg:
        return 0
    v = normalize_value_text(value)
    if not v:
        return 0
    try:
        x = float(v)
    except Exception:
        return 0
    if "valid_min" in cfg and x < float(cfg["valid_min"]):
        return 1
    if "valid_max" in cfg and x > float(cfg["valid_max"]):
        return 1
    return 0

