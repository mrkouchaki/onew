    write_final_markdown_report(out_dir, ecgi_summary, dataset, args)
    plot_paths = []
    plot_paths.extend(make_basic_plots(out_dir, ecgi_summary, dataset, args))
    plot_paths.extend(make_story_plots(con, input_path, colmap, date_col_clean, analysis_info, dataset, out_dir, args))
    write_visual_html_report(out_dir, plot_paths)

    log(f"All candidate ECGI-feature rows: {len(dataset):,}", indent=1)
    log(f"Reportable abnormal feature rows: {int(safe_numeric(dataset.get('ABNORMAL_FEATURE_FLAG', 0)).sum()) if not dataset.empty else 0:,}", indent=1)
    log(f"Reportable ECGI incidents: {len(ecgi_summary):,}", indent=1)
    log(f"Plots generated: {len(plot_paths):,}", indent=1)


