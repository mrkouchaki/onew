def label_confidence_and_weight(label: str) -> Tuple[float, float]:
    x = str(label)
    mapping = {
        "AUDIT_PUSH_NOT_APPLIED": (0.90, 1.00),
        "INVALID_LATEST_SOURCE_VALUE": (0.95, 1.00),
        "FLUCTUATING_FALLBACK_TO_DEFAULT": (0.88, 0.88),
        "LONG_TERM_FALLBACK_TO_DEFAULT": (0.94, 1.00),
        "FALLBACK_TO_DEFAULT_VALUE": (0.80, 0.80),
        "REAL_BACK_AND_FORTH_INSTABILITY": (0.88, 0.90),
        "HIGH_FREQUENCY_DIFFERENT_VALUES": (0.86, 0.88),
        "SAME_DAY_SOURCE_CONFLICT": (0.92, 0.95),
        "PERSISTENT_SOURCE_INSTABILITY": (0.68, 0.65),
        "LATEST_DAY_SOURCE_CHANGE": (0.55, 0.50),
        "UNSUPERVISED_OUTLIER_WITH_WEAK_SIGNATURE": (0.60, 0.45),
        "UNSUPERVISED_FEATURE_OUTLIER": (0.55, 0.35),
        "LOW_RISK_REGULAR_CHANGE": (0.90, 0.60),
        "SUPPRESSED_NORMAL_STABLE_SOURCE_CHANGE": (0.90, 0.75),
        "SUPPRESSED_BULK_OR_REFRESH_PATTERN": (0.86, 0.70),
        "SUPPRESSED_COORDINATED_MULTI_FIELD_CHANGE": (0.78, 0.65),
        "DB_PUSH_CHECK_CANDIDATE_STABLE_SOURCE": (0.35, 0.00),
        "LOW_INFORMATION_STABLE_SOURCE_HISTORY": (0.45, 0.00),
