    return mapping.get(x, (0.50, 0.30))


def recommended_action(label: str) -> str:
    p = str(label or "").upper()
    if p == "AUDIT_PUSH_NOT_APPLIED":
        return "Check server/DB application path: source is stable but latest source and DB values remain different."
    if p == "FLUCTUATING_FALLBACK_TO_DEFAULT":
        return "Review short/intermittent default fallback; compare latest CESMLC value with RAN source-of-truth."
    if p == "LONG_TERM_FALLBACK_TO_DEFAULT":
        return "Review long/default site-wide fallback; validate site swap, rebuild, location/technology change, or missing source-data feed."
    if p == "FALLBACK_TO_DEFAULT_VALUE":
        return "Investigate why source fell back to a known default; validate upstream defaulting logic."
    if p == "INVALID_LATEST_SOURCE_VALUE":
        return "Validate latest source value against RAN parameter requirements; correct out-of-range value if confirmed."
    if p == "REAL_BACK_AND_FORTH_INSTABILITY":
        return "Investigate repeated reversion/toggling in source system; check competing loads or automation overwrites."
    if p == "HIGH_FREQUENCY_DIFFERENT_VALUES":
        return "Investigate high-frequency multi-value changes; check unstable source feed, repeated imports, or conflicting updates."
    if p == "SAME_DAY_SOURCE_CONFLICT":
        return "Investigate multiple same-day source values for same ECGI/feature; check duplicate feed rows or inconsistent joins."
    if p == "PERSISTENT_SOURCE_INSTABILITY":
        return "Review persistent source instability and determine whether it is planned network activity or unresolved data-quality issue."
    if p == "LATEST_DAY_SOURCE_CHANGE":
        return "Review latest-day source change in context of current DB_MISMATCH candidate."
    if p.startswith("UNSUPERVISED"):
        return "Unsupervised model found outlier behavior; inspect history plot and rule evidence before action."
    if p == "LOW_RISK_REGULAR_CHANGE" or p.startswith("SUPPRESSED"):
        return "Likely normal/stable/bulk/coordinated behavior; keep for audit trace but do not prioritize."
    if p == "DB_PUSH_CHECK_CANDIDATE_STABLE_SOURCE":
        return "Source history is stable; if current DB_MISMATCH matters, run narrow source-vs-DB push check or manual review."
    return "Manual review recommended."


def add_signature_and_engineered_features(fm: pd.DataFrame, rules: Dict[str, Dict[str, Any]], analysis_info: Dict[str, Any], args: argparse.Namespace) -> pd.DataFrame:
    if fm.empty:
        return fm
    fm = fm.copy()

    numeric_defaults = {
        "OBSERVED_DAYS_FOR_FEATURE": 0,
        "DISTINCT_SOURCE_VALUES_30D": 0,
        "MODE_SOURCE_VALUE_DAYS": 0,
        "MODE_SOURCE_VALUE_SHARE_PERCENT": 100,
        "LATEST_SOURCE_VALUE_DAYS": 0,
        "RAW_ROWS_FOR_FEATURE": 0,
        "DB_CHECK_AVAILABLE_FLAG": 0,
        "DISTINCT_DB_VALUES_30D": 0,
        "LATEST_DB_VALUE_DAYS": 0,
        "DB_VALUE_PRESENT_DAYS": 0,
        "SOURCE_DB_MISMATCH_DAYS": 0,
        "LATEST_SOURCE_DB_MISMATCH_FLAG": 0,
        "SOURCE_CHANGE_COUNT": 0,
        "SOURCE_CHANGE_DAYS_COUNT": 0,
        "SOURCE_A_B_A_REVERT_COUNT": 0,
        "SOURCE_REVERSE_TRANSITION_COUNT": 0,
        "RAW_ROWS_SUPPORTING_SOURCE_CHANGES": 0,
        "DISTINCT_PREVIOUS_SOURCE_VALUES_COUNT": 0,
        "DISTINCT_CURRENT_SOURCE_VALUES_COUNT": 0,
        "UNIQUE_TRANSITION_EDGE_COUNT": 0,
        "MAX_REPEATED_TRANSITION_EDGE_COUNT": 0,
        "SOURCE_SAME_DAY_CONFLICT_ROWS": 0,
        "SOURCE_SAME_DAY_CONFLICT_DAYS": 0,
        "MAX_SAME_DAY_UNIQUE_SOURCE_VALUES": 0,
        "LATEST_DAY_SOURCE_CHANGE_FLAG": 0,
        "MAX_CANDIDATE_BULK_CHANGE_RATIO": 0,
        "MAX_CHANGED_ECGIS_FEATURE_DAY": 0,
        "MULTI_FIELD_SAME_DAY_CHANGE_COUNT": 0,
    }
    for c, default in numeric_defaults.items():
        if c not in fm.columns:
            fm[c] = default
        fm[c] = safe_numeric(fm[c], default)

    for c in [
        "FIRST_OBSERVED_DATE", "LAST_OBSERVED_DATE", "SOURCE_FIRST_CHANGE_DATE", "SOURCE_LAST_CHANGE_DATE",
        "LATEST_SOURCE_CHANGE_DATE", "SOURCE_FIRST_CONFLICT_DATE", "SOURCE_LAST_CONFLICT_DATE",
        "LATEST_SOURCE_VALUE_FIRST_SEEN_DATE", "LATEST_SOURCE_VALUE_LAST_SEEN_DATE",
    ]:
        if c not in fm.columns:
            fm[c] = pd.NaT
        fm[c] = pd.to_datetime(fm[c], errors="coerce").dt.normalize()

    for c in ["SOURCE_LATEST_CHANGE", "LATEST_PREVIOUS_SOURCE_VALUE", "LATEST_CURRENT_SOURCE_VALUE"]:
        if c not in fm.columns:
            fm[c] = ""

    candidate_date = pd.to_datetime(analysis_info["candidate_date"]).normalize()
    requested_days = max(1, int(analysis_info.get("requested_days", getattr(args, "days", 30))))

    fm["LATEST_SOURCE_IS_DEFAULT_FLAG"] = fm.apply(lambda r: value_is_default(r["FEATURE"], r.get("LATEST_SOURCE_VALUE", ""), rules), axis=1)
    fm["PREVIOUS_NONLATEST_SOURCE_IS_DEFAULT_FLAG"] = fm.apply(lambda r: value_is_default(r["FEATURE"], r.get("PREVIOUS_NONLATEST_SOURCE_VALUE", ""), rules), axis=1)
    fm["FIRST_SOURCE_IS_DEFAULT_FLAG"] = fm.apply(lambda r: value_is_default(r["FEATURE"], r.get("FIRST_SOURCE_VALUE", ""), rules), axis=1)
    fm["LATEST_DB_IS_DEFAULT_FLAG"] = fm.apply(lambda r: value_is_default(r["FEATURE"], r.get("LATEST_DB_VALUE", ""), rules), axis=1)
    fm["LATEST_SOURCE_INVALID_RANGE_FLAG"] = fm.apply(lambda r: value_is_invalid(r["FEATURE"], r.get("LATEST_SOURCE_VALUE", ""), rules), axis=1)
    fm["FEATURE_CRITICALITY_WEIGHT"] = fm["FEATURE"].map(lambda f: get_feature_weight(f, rules))

    fm["SOURCE_CHANGED_DAYS_PERCENT"] = 100.0 * fm["SOURCE_CHANGE_DAYS_COUNT"] / requested_days
    fm["DAYS_SINCE_LAST_SOURCE_CHANGE"] = (candidate_date - pd.to_datetime(fm["SOURCE_LAST_CHANGE_DATE"], errors="coerce").dt.normalize()).dt.days
    fm["DAYS_SINCE_LAST_SOURCE_CHANGE"] = fm["DAYS_SINCE_LAST_SOURCE_CHANGE"].fillna(9999).clip(lower=0)
    fm["SOURCE_SAME_DAY_CONFLICT_FLAG"] = (fm["SOURCE_SAME_DAY_CONFLICT_DAYS"] > 0).astype(int)
    fm["PERSISTENT_SOURCE_INSTABILITY_FLAG"] = (fm["SOURCE_CHANGE_DAYS_COUNT"] >= int(args.persistent_days)).astype(int)
    fm["REAL_BACK_AND_FORTH_FLAG"] = (
        (fm["SOURCE_A_B_A_REVERT_COUNT"] >= int(args.min_aba_for_backforth))
        | (fm["SOURCE_REVERSE_TRANSITION_COUNT"] >= int(args.min_reverses_for_backforth))
        | ((fm["SOURCE_CHANGE_COUNT"] >= 4) & (fm["DISTINCT_SOURCE_VALUES_30D"] <= 3) & (fm["SOURCE_CHANGE_DAYS_COUNT"] >= 3))
    ).astype(int)
    fm["HIGH_FREQUENCY_DIFFERENT_VALUES_FLAG"] = (
        (fm["SOURCE_CHANGE_DAYS_COUNT"] >= int(args.high_frequency_days))
        & (fm["DISTINCT_SOURCE_VALUES_30D"] >= int(args.high_frequency_distinct_values))
        & (fm["MODE_SOURCE_VALUE_SHARE_PERCENT"] < float(args.high_frequency_max_mode_share))
    ).astype(int)
    fm["LATEST_FALLBACK_TO_DEFAULT_VALUE_FLAG"] = (
        (fm["LATEST_SOURCE_IS_DEFAULT_FLAG"] == 1)
        & (fm["PREVIOUS_NONLATEST_SOURCE_VALUE"].fillna("").astype(str) != "")
        & (fm["PREVIOUS_NONLATEST_SOURCE_IS_DEFAULT_FLAG"] == 0)
        & (fm["LATEST_SOURCE_VALUE_DAYS"] >= int(args.default_min_days))
    ).astype(int)
    fm["HISTORICAL_DEFAULT_FALLBACK_EPISODE_FLAG"] = (
        (fm["LATEST_SOURCE_IS_DEFAULT_FLAG"] == 0)
        & (fm["PREVIOUS_NONLATEST_SOURCE_IS_DEFAULT_FLAG"] == 1)
        & (fm["SOURCE_CHANGE_COUNT"] >= 2)
    ).astype(int)
    fm["FALLBACK_TO_DEFAULT_VALUE_FLAG"] = ((fm["LATEST_FALLBACK_TO_DEFAULT_VALUE_FLAG"] == 1) | (fm["HISTORICAL_DEFAULT_FALLBACK_EPISODE_FLAG"] == 1)).astype(int)

    # Fallback duration classification.
    latest_first = pd.to_datetime(fm["LATEST_SOURCE_VALUE_FIRST_SEEN_DATE"], errors="coerce")
    latest_days_calendar = (candidate_date - latest_first.dt.normalize()).dt.days + 1
    latest_days_calendar = latest_days_calendar.fillna(0).clip(lower=0)
    default_duration = np.maximum(fm["LATEST_SOURCE_VALUE_DAYS"], latest_days_calendar)
    long_term = (fm["FALLBACK_TO_DEFAULT_VALUE_FLAG"] == 1) & (default_duration >= int(args.long_term_default_days))
    ecgi_default_counts = fm.groupby("ECGI", as_index=False).agg(
        ECGI_ANALYZED_FEATURE_ROWS=("FEATURE", "size"),
        ECGI_DEFAULT_FALLBACK_FEATURE_COUNT=("FALLBACK_TO_DEFAULT_VALUE_FLAG", "sum"),
    )
    ecgi_default_counts["ECGI_DEFAULT_FALLBACK_FEATURE_RATIO"] = ecgi_default_counts["ECGI_DEFAULT_FALLBACK_FEATURE_COUNT"] / np.maximum(ecgi_default_counts["ECGI_ANALYZED_FEATURE_ROWS"], 1)
    fm = fm.merge(ecgi_default_counts[["ECGI", "ECGI_DEFAULT_FALLBACK_FEATURE_COUNT", "ECGI_DEFAULT_FALLBACK_FEATURE_RATIO"]], on="ECGI", how="left")
    sitewide = (fm["FALLBACK_TO_DEFAULT_VALUE_FLAG"] == 1) & (
        (fm["ECGI_DEFAULT_FALLBACK_FEATURE_COUNT"] >= int(args.sitewide_default_feature_threshold))
        | (fm["ECGI_DEFAULT_FALLBACK_FEATURE_RATIO"] >= float(args.sitewide_default_ratio_threshold))
    )
    long_term = long_term | sitewide
    fm["LONG_TERM_DEFAULT_FALLBACK_FLAG"] = long_term.astype(int)
    fm["FLUCTUATING_DEFAULT_FALLBACK_FLAG"] = ((fm["FALLBACK_TO_DEFAULT_VALUE_FLAG"] == 1) & ~long_term).astype(int)
    fm["SITE_WIDE_LONG_TERM_DEFAULT_FALLBACK_SUSPECT_FLAG"] = sitewide.astype(int)
    fm["FALLBACK_DURATION_CLUSTER"] = ""
    fm.loc[long_term, "FALLBACK_DURATION_CLUSTER"] = "LONG_TERM_OR_SITE_WIDE"
    fm.loc[(fm["FALLBACK_TO_DEFAULT_VALUE_FLAG"] == 1) & ~long_term, "FALLBACK_DURATION_CLUSTER"] = "FLUCTUATING_OR_SHORT_TERM"

    fm["AUDIT_PUSH_NOT_APPLIED_FLAG"] = 0
    if args.enable_db_push_check:
        fm["AUDIT_PUSH_NOT_APPLIED_FLAG"] = (
            (fm["DB_CHECK_AVAILABLE_FLAG"] == 1)
            & (fm["LATEST_SOURCE_DB_MISMATCH_FLAG"] == 1)
            & (fm["LATEST_SOURCE_VALUE_DAYS"] >= int(args.push_source_stable_days))
            & (fm["SOURCE_DB_MISMATCH_DAYS"] >= int(args.push_mismatch_days))
            & (
                (fm["LATEST_DB_IS_DEFAULT_FLAG"] == 1)
                | (
                    fm["PREVIOUS_NONLATEST_SOURCE_VALUE"].fillna("").astype(str).ne("")
                    & fm["LATEST_DB_VALUE"].fillna("").astype(str).eq(fm["PREVIOUS_NONLATEST_SOURCE_VALUE"].fillna("").astype(str))
                )
                | (fm["DISTINCT_DB_VALUES_30D"] <= 1)
            )
        ).astype(int)

    fm["BULK_OR_REFRESH_SUPPRESSOR_FLAG"] = (
        (fm["MAX_CANDIDATE_BULK_CHANGE_RATIO"] >= float(args.bulk_change_ratio_threshold))
        & (fm["FALLBACK_TO_DEFAULT_VALUE_FLAG"] == 0)
        & (fm["LATEST_SOURCE_INVALID_RANGE_FLAG"] == 0)
        & (fm["REAL_BACK_AND_FORTH_FLAG"] == 0)
        & (fm["HIGH_FREQUENCY_DIFFERENT_VALUES_FLAG"] == 0)
        & (fm["SOURCE_SAME_DAY_CONFLICT_FLAG"] == 0)
        & (fm["AUDIT_PUSH_NOT_APPLIED_FLAG"] == 0)
    ).astype(int)
    fm["NORMAL_STABLE_SOURCE_CHANGE_SUPPRESSOR_FLAG"] = (
        (fm["SOURCE_CHANGE_COUNT"] == 1)
        & (fm["DISTINCT_SOURCE_VALUES_30D"] <= 2)
        & (fm["DAYS_SINCE_LAST_SOURCE_CHANGE"] >= int(args.stable_change_suppress_days))
        & (fm["FALLBACK_TO_DEFAULT_VALUE_FLAG"] == 0)
        & (fm["LATEST_SOURCE_INVALID_RANGE_FLAG"] == 0)
        & (fm["SOURCE_SAME_DAY_CONFLICT_FLAG"] == 0)
        & (fm["AUDIT_PUSH_NOT_APPLIED_FLAG"] == 0)
    ).astype(int)
    fm["COORDINATED_MULTI_FIELD_SUPPRESSOR_FLAG"] = (
        (fm["MULTI_FIELD_SAME_DAY_CHANGE_COUNT"] >= int(args.coordinated_feature_threshold))
        & (fm["DAYS_SINCE_LAST_SOURCE_CHANGE"] >= int(args.stable_change_suppress_days))
        & (fm["FALLBACK_TO_DEFAULT_VALUE_FLAG"] == 0)
        & (fm["LATEST_SOURCE_INVALID_RANGE_FLAG"] == 0)
        & (fm["REAL_BACK_AND_FORTH_FLAG"] == 0)
        & (fm["HIGH_FREQUENCY_DIFFERENT_VALUES_FLAG"] == 0)
        & (fm["SOURCE_SAME_DAY_CONFLICT_FLAG"] == 0)
        & (fm["AUDIT_PUSH_NOT_APPLIED_FLAG"] == 0)
    ).astype(int)
    fm["LOW_INFORMATION_STABLE_SOURCE_HISTORY_FLAG"] = (
        (fm["SOURCE_CHANGE_COUNT"] == 0)
        & (fm["SOURCE_SAME_DAY_CONFLICT_FLAG"] == 0)
        & (fm["FALLBACK_TO_DEFAULT_VALUE_FLAG"] == 0)
        & (fm["LATEST_SOURCE_INVALID_RANGE_FLAG"] == 0)
        & (fm["AUDIT_PUSH_NOT_APPLIED_FLAG"] == 0)
    ).astype(int)
    fm["DB_PUSH_CHECK_CANDIDATE_FLAG"] = (
        (fm["LOW_INFORMATION_STABLE_SOURCE_HISTORY_FLAG"] == 1)
        | ((fm["SOURCE_CHANGE_COUNT"] <= 1) & (fm["LATEST_SOURCE_VALUE_DAYS"] >= int(args.push_source_stable_days)))
    ).astype(int)

    # Engineered metrics for unsupervised learning and presentation.
    observed_days = fm["OBSERVED_DAYS_FOR_FEATURE"].replace(0, np.nan)
    mode_share = fm["MODE_SOURCE_VALUE_SHARE_PERCENT"].clip(0, 100)
    fm["ABNORMAL_FEATURE_FAMILY"] = fm["FEATURE"].map(feature_family)
    fm["CHANGE_DENSITY"] = (fm["SOURCE_CHANGE_DAYS_COUNT"] / observed_days).replace([np.inf, -np.inf], np.nan).fillna(0).clip(0, 1)
    fm["EVENT_DENSITY"] = (fm["SOURCE_CHANGE_COUNT"] / observed_days).replace([np.inf, -np.inf], np.nan).fillna(0)
    fm["VALUE_ENTROPY_PROXY"] = np.log1p(fm["DISTINCT_SOURCE_VALUES_30D"].clip(lower=0)) * (1.0 - mode_share / 100.0)
    fm["MODE_IMPURITY_PERCENT"] = (100.0 - mode_share).clip(0, 100)
    fm["RECENCY_PRESSURE"] = ((requested_days - fm["DAYS_SINCE_LAST_SOURCE_CHANGE"].clip(upper=requested_days)) / requested_days).clip(0, 1)
    fm["INSTABILITY_EVENT_INDEX"] = (
        2.2 * fm["SOURCE_CHANGE_DAYS_COUNT"]
        + 1.1 * fm["SOURCE_CHANGE_COUNT"]
        + 2.5 * fm["SOURCE_SAME_DAY_CONFLICT_DAYS"]
        + 1.4 * fm["SOURCE_DB_MISMATCH_DAYS"]
        + 1.8 * fm["SOURCE_A_B_A_REVERT_COUNT"]
        + 1.8 * fm["SOURCE_REVERSE_TRANSITION_COUNT"]
        + 1.2 * fm["DISTINCT_SOURCE_VALUES_30D"]
    )
    latest_num = pd.to_numeric(series_text(fm, "LATEST_SOURCE_VALUE", ""), errors="coerce")
    prev_num = pd.to_numeric(series_text(fm, "PREVIOUS_NONLATEST_SOURCE_VALUE", ""), errors="coerce")
    first_num = pd.to_numeric(series_text(fm, "FIRST_SOURCE_VALUE", ""), errors="coerce")
    db_num = pd.to_numeric(series_text(fm, "LATEST_DB_VALUE", ""), errors="coerce")
    fm["LATEST_PREVIOUS_ABS_DELTA"] = (latest_num - prev_num).abs()
    fm["LATEST_FIRST_ABS_DELTA"] = (latest_num - first_num).abs()
    fm["LATEST_DB_ABS_DELTA"] = (latest_num - db_num).abs()
    fm["NUMERIC_ABNORMAL_AMOUNT"] = fm[["LATEST_PREVIOUS_ABS_DELTA", "LATEST_FIRST_ABS_DELTA", "LATEST_DB_ABS_DELTA"]].max(axis=1, skipna=True)
    fm["NUMERIC_ABNORMAL_AMOUNT"] = fm["NUMERIC_ABNORMAL_AMOUNT"].replace([np.inf, -np.inf], np.nan)
    fm["CATEGORICAL_ABNORMAL_AMOUNT"] = np.maximum.reduce([
        fm["DISTINCT_SOURCE_VALUES_30D"].fillna(0).values,
        fm["SOURCE_CHANGE_COUNT"].fillna(0).values,
        fm["SOURCE_SAME_DAY_CONFLICT_DAYS"].fillna(0).values,
    ])
    fm["ABNORMAL_AMOUNT_NUMERIC"] = fm["NUMERIC_ABNORMAL_AMOUNT"].fillna(fm["CATEGORICAL_ABNORMAL_AMOUNT"])

    has_problem_signature = (
        (fm["AUDIT_PUSH_NOT_APPLIED_FLAG"] == 1)
        | (fm["FALLBACK_TO_DEFAULT_VALUE_FLAG"] == 1)
        | (fm["LATEST_SOURCE_INVALID_RANGE_FLAG"] == 1)
        | (fm["REAL_BACK_AND_FORTH_FLAG"] == 1)
        | (fm["HIGH_FREQUENCY_DIFFERENT_VALUES_FLAG"] == 1)
        | (fm["SOURCE_SAME_DAY_CONFLICT_FLAG"] == 1)
        | (fm["PERSISTENT_SOURCE_INSTABILITY_FLAG"] == 1)
        | (fm["LATEST_DAY_SOURCE_CHANGE_FLAG"] == 1)
    )
    fm["HAS_PROBLEM_SIGNATURE_FLAG"] = has_problem_signature.astype(int)

    score = pd.Series(np.zeros(len(fm)), index=fm.index, dtype=float)
    score += 47.0 * fm["AUDIT_PUSH_NOT_APPLIED_FLAG"]
    score += 42.0 * fm["LONG_TERM_DEFAULT_FALLBACK_FLAG"]
    score += 34.0 * fm["FLUCTUATING_DEFAULT_FALLBACK_FLAG"]
    score += 34.0 * fm["LATEST_SOURCE_INVALID_RANGE_FLAG"]
    score += 32.0 * fm["REAL_BACK_AND_FORTH_FLAG"]
    score += 31.0 * fm["HIGH_FREQUENCY_DIFFERENT_VALUES_FLAG"]
    score += 24.0 * fm["SOURCE_SAME_DAY_CONFLICT_FLAG"]
    score += 13.0 * fm["PERSISTENT_SOURCE_INSTABILITY_FLAG"]
    score += 7.0 * fm["LATEST_DAY_SOURCE_CHANGE_FLAG"]
    score += np.minimum(15.0, 1.5 * fm["SOURCE_CHANGE_DAYS_COUNT"])
    score += np.minimum(11.0, 0.75 * fm["SOURCE_CHANGE_COUNT"])
    score += np.minimum(9.0, 2.0 * np.maximum(fm["DISTINCT_SOURCE_VALUES_30D"] - 1, 0))
    score += np.minimum(7.0, fm["INSTABILITY_EVENT_INDEX"] * 0.2)
    score += np.where(has_problem_signature, fm["FEATURE_CRITICALITY_WEIGHT"], 0.20 * fm["FEATURE_CRITICALITY_WEIGHT"])
    score += np.minimum(5.0, np.log1p(fm["RAW_ROWS_FOR_FEATURE"].clip(lower=0)))
    no_problem = ~has_problem_signature
    score -= np.where(no_problem & (fm["NORMAL_STABLE_SOURCE_CHANGE_SUPPRESSOR_FLAG"] == 1), 25.0, 0.0)
    score -= np.where(no_problem & (fm["BULK_OR_REFRESH_SUPPRESSOR_FLAG"] == 1), 25.0, 0.0)
    score -= np.where(no_problem & (fm["COORDINATED_MULTI_FIELD_SUPPRESSOR_FLAG"] == 1), 18.0, 0.0)
    score -= np.where(no_problem & (fm["LOW_INFORMATION_STABLE_SOURCE_HISTORY_FLAG"] == 1), 15.0, 0.0)
    fm["SIGNATURE_RULE_SCORE"] = score.clip(lower=0)
    fm["SEED_RULE_SCORE"] = fm["SIGNATURE_RULE_SCORE"]
    fm["SEED_RULE_PERCENTILE"] = percentile_rank(fm["SEED_RULE_SCORE"])

    def initial_cluster(r: pd.Series) -> str:
        if int(r.get("AUDIT_PUSH_NOT_APPLIED_FLAG", 0)) == 1:
            return "AUDIT_PUSH_NOT_APPLIED"
        if int(r.get("LATEST_SOURCE_INVALID_RANGE_FLAG", 0)) == 1:
            return "INVALID_LATEST_SOURCE_VALUE"
        if int(r.get("LONG_TERM_DEFAULT_FALLBACK_FLAG", 0)) == 1:
            return "LONG_TERM_FALLBACK_TO_DEFAULT"
        if int(r.get("FLUCTUATING_DEFAULT_FALLBACK_FLAG", 0)) == 1:
            return "FLUCTUATING_FALLBACK_TO_DEFAULT"
        if int(r.get("REAL_BACK_AND_FORTH_FLAG", 0)) == 1:
            return "REAL_BACK_AND_FORTH_INSTABILITY"
        if int(r.get("HIGH_FREQUENCY_DIFFERENT_VALUES_FLAG", 0)) == 1:
            return "HIGH_FREQUENCY_DIFFERENT_VALUES"
        if int(r.get("SOURCE_SAME_DAY_CONFLICT_FLAG", 0)) == 1:
            return "SAME_DAY_SOURCE_CONFLICT"
        if int(r.get("PERSISTENT_SOURCE_INSTABILITY_FLAG", 0)) == 1:
            return "PERSISTENT_SOURCE_INSTABILITY"
        if int(r.get("LATEST_DAY_SOURCE_CHANGE_FLAG", 0)) == 1:
            return "LATEST_DAY_SOURCE_CHANGE"
        if int(r.get("NORMAL_STABLE_SOURCE_CHANGE_SUPPRESSOR_FLAG", 0)) == 1:
            return "LOW_RISK_REGULAR_CHANGE"
        if int(r.get("BULK_OR_REFRESH_SUPPRESSOR_FLAG", 0)) == 1:
            return "SUPPRESSED_BULK_OR_REFRESH_PATTERN"
        if int(r.get("COORDINATED_MULTI_FIELD_SUPPRESSOR_FLAG", 0)) == 1:
            return "SUPPRESSED_COORDINATED_MULTI_FIELD_CHANGE"
        if int(r.get("DB_PUSH_CHECK_CANDIDATE_FLAG", 0)) == 1:
            return "DB_PUSH_CHECK_CANDIDATE_STABLE_SOURCE"
        if int(r.get("LOW_INFORMATION_STABLE_SOURCE_HISTORY_FLAG", 0)) == 1:
            return "LOW_INFORMATION_STABLE_SOURCE_HISTORY"
        return "LOW_PRIORITY_SOURCE_HISTORY_SIGNAL"

    fm["SEED_LABEL"] = fm.apply(initial_cluster, axis=1)
    conf_weight = fm["SEED_LABEL"].map(label_confidence_and_weight)
    fm["SEED_LABEL_CONFIDENCE"] = [cw[0] for cw in conf_weight]
    fm["TRAINING_WEIGHT"] = [cw[1] for cw in conf_weight]
    fm["IS_REPORTABLE_PROBLEM"] = fm["SEED_LABEL"].isin(PROBLEM_LABELS).astype(int)
    fm["IS_SUPPRESSED_NORMAL"] = fm["SEED_LABEL"].isin(SUPPRESSOR_LABELS).astype(int)
    fm["NEEDS_MANUAL_REVIEW"] = fm["SEED_LABEL"].isin(HOLD_LABELS).astype(int)
    fm["TRAIN_FOR_MODEL_FLAG"] = ((fm["SEED_LABEL_CONFIDENCE"] >= float(args.min_seed_confidence_for_training)) & (fm["TRAINING_WEIGHT"] > 0) & (~fm["SEED_LABEL"].isin(HOLD_LABELS))).astype(int)
    fm["FINAL_TRAINING_LABEL"] = fm["SEED_LABEL"]
    fm["MANUAL_LABEL"] = ""
    fm["MANUAL_LABEL_NOTES"] = ""
    fm["SEVERITY_BAND"] = fm["SEED_RULE_SCORE"].map(severity_band_from_risk)
    fm["RECOMMENDED_ACTION"] = fm["SEED_LABEL"].map(recommended_action).fillna("Manual review recommended.")
    fm["SOURCE_FEATURE_EVIDENCE_SUMMARY"] = fm.apply(
        lambda r: (
            f"{r['FEATURE']} latest={short_value(r.get('LATEST_SOURCE_VALUE',''))}; "
            f"changes={int(r.get('SOURCE_CHANGE_DAYS_COUNT',0))}/{requested_days} days; "
            f"events={int(r.get('SOURCE_CHANGE_COUNT',0))}; distinct={int(r.get('DISTINCT_SOURCE_VALUES_30D',0))}; "
            f"signature={r.get('SEED_LABEL','')}; rule_score={float(r.get('SEED_RULE_SCORE',0)):.1f}."
        ),
        axis=1,
    )
    return fm


