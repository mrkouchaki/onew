def choose_isof_numeric_columns(fm: pd.DataFrame) -> List[str]:
    preferred = [
        "OBSERVED_DAYS_FOR_FEATURE", "DISTINCT_SOURCE_VALUES_30D", "MODE_SOURCE_VALUE_SHARE_PERCENT",
        "LATEST_SOURCE_VALUE_DAYS", "RAW_ROWS_FOR_FEATURE", "SOURCE_DB_MISMATCH_DAYS", "LATEST_SOURCE_DB_MISMATCH_FLAG",
        "SOURCE_CHANGE_COUNT", "SOURCE_CHANGE_DAYS_COUNT", "SOURCE_A_B_A_REVERT_COUNT", "SOURCE_REVERSE_TRANSITION_COUNT",
        "UNIQUE_TRANSITION_EDGE_COUNT", "MAX_REPEATED_TRANSITION_EDGE_COUNT", "SOURCE_SAME_DAY_CONFLICT_DAYS",
        "MAX_SAME_DAY_UNIQUE_SOURCE_VALUES", "LATEST_DAY_SOURCE_CHANGE_FLAG", "MAX_CANDIDATE_BULK_CHANGE_RATIO",
        "MULTI_FIELD_SAME_DAY_CHANGE_COUNT", "DAYS_SINCE_LAST_SOURCE_CHANGE", "LATEST_SOURCE_IS_DEFAULT_FLAG",
        "PREVIOUS_NONLATEST_SOURCE_IS_DEFAULT_FLAG", "LATEST_SOURCE_INVALID_RANGE_FLAG", "FEATURE_CRITICALITY_WEIGHT",
        "LONG_TERM_DEFAULT_FALLBACK_FLAG", "FLUCTUATING_DEFAULT_FALLBACK_FLAG", "SITE_WIDE_LONG_TERM_DEFAULT_FALLBACK_SUSPECT_FLAG",
        "CHANGE_DENSITY", "EVENT_DENSITY", "VALUE_ENTROPY_PROXY", "MODE_IMPURITY_PERCENT", "RECENCY_PRESSURE",
        "INSTABILITY_EVENT_INDEX", "NUMERIC_ABNORMAL_AMOUNT", "CATEGORICAL_ABNORMAL_AMOUNT", "ABNORMAL_AMOUNT_NUMERIC",
        "SIGNATURE_RULE_SCORE", "SEED_RULE_SCORE", "LOCATION_LATEST_PREVIOUS_DISTANCE_M", "LOCATION_LATEST_FIRST_DISTANCE_M", "LOCATION_LATEST_DB_DISTANCE_M", "LOCATION_MAX_DISTANCE_M",
    ]
    cols = [c for c in preferred if c in fm.columns]
    # Allow any robust numeric columns not text/labels, but keep list bounded.
    exclude_patterns = ["VALUE", "DATE", "SUMMARY", "ACTION", "REASON", "FILE", "NAME", "ECGI", "LABEL", "CLUSTER", "FEATURE"]
    for c in fm.columns:
        if c in cols:
            continue
        if any(p in c for p in exclude_patterns):
            continue
        if pd.api.types.is_numeric_dtype(fm[c]):
            cols.append(c)
    return sorted(set(cols))


def _fit_isof_and_score_chunks(
    fm: pd.DataFrame,
    numeric_cols: List[str],
    fit_sample: int,
    n_estimators: int,
    random_state: int,
    chunk_size: int,
) -> Optional[np.ndarray]:
    try:
        from sklearn.ensemble import IsolationForest
        from sklearn.impute import SimpleImputer
        from sklearn.preprocessing import RobustScaler
    except Exception as exc:
        log(f"IsolationForest skipped because sklearn is unavailable: {exc}", indent=1)
        return None

    if len(fm) < 20 or len(numeric_cols) < 5:
        return None
    Xdf = fm[numeric_cols].replace([np.inf, -np.inf], np.nan)
    if len(Xdf) > fit_sample > 0:
        fit_df = Xdf.sample(n=fit_sample, random_state=random_state)
    else:
        fit_df = Xdf
    imputer = SimpleImputer(strategy="median")
    scaler = RobustScaler()
    X_fit = imputer.fit_transform(fit_df)
    X_fit = scaler.fit_transform(X_fit)
    model = IsolationForest(n_estimators=int(n_estimators), contamination="auto", random_state=int(random_state), n_jobs=-1)
    model.fit(X_fit)

    scores = np.empty(len(fm), dtype="float64")
    chunk_size = max(10000, int(chunk_size))
    for start in range(0, len(fm), chunk_size):
        end = min(len(fm), start + chunk_size)
        X_chunk = imputer.transform(Xdf.iloc[start:end])
        X_chunk = scaler.transform(X_chunk)
        scores[start:end] = -model.score_samples(X_chunk)
    return scores


def add_isolation_forest_scores(dataset: pd.DataFrame, args: argparse.Namespace) -> pd.DataFrame:
    fm = dataset.copy()
    fm["UNSUPERVISED_ISOF_SCORE"] = np.nan
    fm["UNSUPERVISED_ISOF_PERCENTILE"] = np.nan
    fm["UNSUPERVISED_ISOF_TOP_FLAG"] = 0
    fm["FEATUREWISE_ISOF_SCORE"] = np.nan
    fm["FEATUREWISE_ISOF_PERCENTILE"] = np.nan
    fm["FEATUREWISE_ISOF_TOP_FLAG"] = 0
    if not getattr(args, "enable_isolation_forest", False):
        log("IsolationForest disabled. Signature engine still runs.", indent=1)
        return fm

    numeric_cols = choose_isof_numeric_columns(fm)
    if len(numeric_cols) < 5 or len(fm) < 50:
        log("IsolationForest skipped: not enough numeric features/rows.", indent=1)
        return fm

    log(f"Fitting GLOBAL IsolationForest on up to {int(args.isolation_fit_sample):,} sampled rows and {len(numeric_cols):,} engineered numeric features", indent=1)
    global_scores = _fit_isof_and_score_chunks(
        fm=fm,
        numeric_cols=numeric_cols,
        fit_sample=int(args.isolation_fit_sample),
        n_estimators=int(args.isolation_n_estimators),
        random_state=int(args.random_state),
        chunk_size=int(args.isolation_score_chunk_size),
    )
    if global_scores is not None:
        fm["UNSUPERVISED_ISOF_SCORE"] = global_scores
        fm["UNSUPERVISED_ISOF_PERCENTILE"] = percentile_rank(pd.Series(global_scores, index=fm.index))
        fm["UNSUPERVISED_ISOF_TOP_FLAG"] = (fm["UNSUPERVISED_ISOF_PERCENTILE"] >= float(args.isolation_top_percentile)).astype(int)
        log(f"Global IsolationForest top-flag rows: {int(fm['UNSUPERVISED_ISOF_TOP_FLAG'].sum()):,}", indent=1)

    if getattr(args, "enable_featurewise_isolation", True):
        min_rows = int(args.featurewise_isolation_min_rows)
        feature_cols = [c for c in numeric_cols if c not in {"FEATURE_CRITICALITY_WEIGHT"}]
        log(f"Fitting feature-wise IsolationForest for features with >= {min_rows:,} rows", indent=1)
        for feature, idx in fm.groupby("FEATURE").groups.items():
            idx_list = list(idx)
            if len(idx_list) < min_rows or len(feature_cols) < 5:
                continue
            sub = fm.loc[idx_list, feature_cols]
            scores = _fit_isof_and_score_chunks(
                fm=sub,
                numeric_cols=feature_cols,
                fit_sample=int(args.featurewise_isolation_fit_sample),
                n_estimators=int(args.featurewise_isolation_n_estimators),
                random_state=int(args.random_state),
                chunk_size=int(args.isolation_score_chunk_size),
            )
            if scores is None:
                continue
            fm.loc[idx_list, "FEATUREWISE_ISOF_SCORE"] = scores
            fm.loc[idx_list, "FEATUREWISE_ISOF_PERCENTILE"] = percentile_rank(pd.Series(scores, index=idx_list)).values
            fm.loc[idx_list, "FEATUREWISE_ISOF_TOP_FLAG"] = (fm.loc[idx_list, "FEATUREWISE_ISOF_PERCENTILE"] >= float(args.featurewise_isolation_top_percentile)).astype(int)
        log(f"Feature-wise IsolationForest top-flag rows: {int(safe_numeric(fm['FEATUREWISE_ISOF_TOP_FLAG']).sum()):,}", indent=1)
    return fm


