            "ECGI_ANOMALY_RISK_SCORE", "ABNORMAL_FEATURE_COUNT", "ABNORMAL_DAYS_TOTAL", "ABNORMAL_DAYS_MAX",
            "ABNORMAL_DAYS_AND_AMOUNTS", "LOCATION_DISTANCE_PRESENTABLE", "LOCATION_LATEST_PREVIOUS_DISTANCE_M", "LOCATION_LATEST_FIRST_DISTANCE_M", "LOCATION_LATEST_DB_DISTANCE_M", "LOCATION_MAX_DISTANCE_M",
            "TOP_FEATURE_INCIDENTS", "MODEL_SIGNATURE_AGREEMENT", "SERVER_ID", "MARKET",
        ]
        ecgi_summary[[c for c in amount_cols if c in ecgi_summary.columns]].to_csv(out_dir / "cesmlc_v71_abnormal_days_amounts_by_ecgi.csv", index=False)
        evidence_rows = []
        if not dataset.empty:
            for _, erow in ecgi_summary.iterrows():
                ecgi = str(erow.get("ECGI", ""))
                ev = dataset[dataset["ECGI"].astype(str) == ecgi].copy()
                if ev.empty:
                    continue
                ev["__sort_flag"] = safe_numeric(ev.get("ABNORMAL_FEATURE_FLAG", 0))
                ev = ev.sort_values(["__sort_flag", "ANOMALY_RISK_SCORE"], ascending=[False, False]).head(10)
                feature_lines = []
                for _, fr in ev.iterrows():
                    amount = str(fr.get("ABNORMAL_AMOUNT_PRESENTABLE", "") or "")
                    loc = str(fr.get("LOCATION_DISTANCE_PRESENTABLE", "") or "")
                    if loc and loc not in amount:
                        amount = (amount + "; " if amount else "") + loc
                    feature_lines.append(
                        f"{fr.get('FEATURE','')} [{fr.get('PRIMARY_ANOMALY_CLUSTER','')}] risk={safe_float(fr.get('ANOMALY_RISK_SCORE',0)):.1f}; "
                        f"days={fr.get('ABNORMAL_DAYS_PRESENTABLE','')}; amount={short_value(amount, 220)}; "
                        f"latest={short_value(fr.get('LATEST_SOURCE_VALUE',''),80)}; prev={short_value(fr.get('PREVIOUS_NONLATEST_SOURCE_VALUE',''),80)}; "
                        f"agreement={fr.get('MODEL_SIGNATURE_AGREEMENT','')}"
                    )
                evidence_rows.append({
                    "INCIDENT_RANK": erow.get("INCIDENT_RANK", ""),
                    "ECGI": erow.get("ECGI", ""),
                    "ECGI_LABEL": erow.get("ECGI_LABEL", ""),
                    "PRIMARY_ANOMALY_CLUSTER": erow.get("PRIMARY_ANOMALY_CLUSTER", ""),
                    "PRIMARY_ABNORMAL_FEATURE": erow.get("PRIMARY_ABNORMAL_FEATURE", ""),
                    "ECGI_ANOMALY_RISK_SCORE": erow.get("ECGI_ANOMALY_RISK_SCORE", ""),
                    "ABNORMAL_DAYS_AND_AMOUNTS": erow.get("ABNORMAL_DAYS_AND_AMOUNTS", ""),
                    "LOCATION_DISTANCE_PRESENTABLE": erow.get("LOCATION_DISTANCE_PRESENTABLE", ""),
                    "ECGI_EVIDENCE_DETAIL": " | ".join(feature_lines),
                    "ECGI_EVIDENCE_MD": "\n".join(f"- {x}" for x in feature_lines),
                    "RECOMMENDED_ACTION": erow.get("RECOMMENDED_ACTION", ""),
                })
        pd.DataFrame(evidence_rows).to_csv(out_dir / "cesmlc_v71_ecgi_evidence_details.csv", index=False)
    else:
        pd.DataFrame().to_csv(out_dir / "cesmlc_v71_clustered_ecgi_incident_summary_all.csv", index=False)
        pd.DataFrame().to_csv(out_dir / "cesmlc_v71_clustered_ecgi_incident_summary_top.csv", index=False)
        pd.DataFrame().to_csv(out_dir / "cesmlc_v71_final_report_top100.csv", index=False)
        pd.DataFrame().to_csv(out_dir / "cesmlc_v71_abnormal_days_amounts_by_ecgi.csv", index=False)
        pd.DataFrame().to_csv(out_dir / "cesmlc_v71_ecgi_evidence_details.csv", index=False)

    if not dataset.empty:
        feature_summary = dataset.groupby(["PRIMARY_ANOMALY_CLUSTER", "PRIMARY_ABNORMAL_FEATURE"], dropna=False).agg(
            ROW_COUNT=("ECGI", "size"),
            ABNORMAL_ROW_COUNT=("ABNORMAL_FEATURE_FLAG", "sum"),
            UNIQUE_ECGI=("ECGI", "nunique"),
            AVG_RISK=("ANOMALY_RISK_SCORE", "mean"),
            MAX_RISK=("ANOMALY_RISK_SCORE", "max"),
            ABNORMAL_DAYS_TOTAL=("ABNORMAL_DAYS_COUNT", "sum"),
        ).reset_index().sort_values(["ABNORMAL_ROW_COUNT", "MAX_RISK"], ascending=False)
        feature_summary.to_csv(out_dir / "cesmlc_v71_cluster_feature_summary.csv", index=False)

        if "DATA_SOURCE_COMPATIBILITY" in dataset.columns:
            compat_summary = dataset.groupby(["PRIMARY_ANOMALY_CLUSTER", "DATA_SOURCE_COMPATIBILITY"], dropna=False).agg(
                ROW_COUNT=("ECGI", "size"), UNIQUE_ECGI=("ECGI", "nunique"), AVG_RISK=("ANOMALY_RISK_SCORE", "mean")
            ).reset_index().sort_values(["PRIMARY_ANOMALY_CLUSTER", "ROW_COUNT"], ascending=[True, False])
            compat_summary.to_csv(out_dir / "cesmlc_v71_data_source_compatibility_summary.csv", index=False)

    manual_template = build_manual_review_template(dataset, args.manual_review_top_n, args.manual_review_random_n, args.random_state)
    manual_template.to_csv(out_dir / "cesmlc_v71_manual_review_label_template.csv", index=False)

    top_pairs = dataset[(dataset.get("ABNORMAL_FEATURE_FLAG", 0) == 1)].sort_values("ANOMALY_RISK_SCORE", ascending=False)[["ECGI", "FEATURE", "PRIMARY_ANOMALY_CLUSTER", "ANOMALY_RISK_SCORE"]].head(args.evidence_top_n)
    if not changes.empty and not top_pairs.empty:
        ev = changes.merge(top_pairs, on=["ECGI", "FEATURE"], how="inner")
        ev["ECGI_LABEL"] = ev["ECGI"].map(excel_safe_ecgi)
        ev.to_csv(out_dir / "cesmlc_v71_source_change_events_top.csv", index=False)
    else:
