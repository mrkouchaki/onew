def elapsed_text() -> str:
    seconds = int(time.time() - RUN_START_TIME)
    h, rem = divmod(seconds, 3600)
    m, s = divmod(rem, 60)
    return f"{h:02d}:{m:02d}:{s:02d}"


def log(message: str, indent: int = 0) -> None:
    print(f"[{time.strftime('%H:%M:%S')} | +{elapsed_text()}] {'  '*max(0, indent)}{message}", flush=True)


def header(title: str) -> None:
    print("\n" + "=" * 100, flush=True)
    log(title)
    print("=" * 100, flush=True)


def clean_col_name(c: object) -> str:
    return str(c).strip().strip('"').upper()


def safe_numeric(series: Any, default: float = 0.0) -> pd.Series:
    if not isinstance(series, pd.Series):
        series = pd.Series(series)
    return pd.to_numeric(series, errors="coerce").replace([np.inf, -np.inf], np.nan).fillna(default)


def percentile_rank(series: pd.Series) -> pd.Series:
    s = safe_numeric(series)
    if len(s) == 0:
        return s
    if s.nunique(dropna=False) <= 1:
        return pd.Series(np.ones(len(s)) * 50.0, index=s.index)
    return s.rank(method="average", pct=True) * 100.0


def short_value(v: object, max_len: int = 80) -> str:
    if pd.isna(v):
        return "<missing>"
    s = str(v)
    return s if len(s) <= max_len else s[: max_len - 3] + "..."


def sanitize_label(x: object) -> str:
    return str(x or "").strip().upper()


def load_artifact(path: Path) -> Dict[str, Any]:
    if not path.exists():
        raise FileNotFoundError(f"Model artifact not found: {path}")
    with path.open("rb") as f:
        artifact = pickle.load(f)
    required = {"model", "features", "backend"}
    missing = [k for k in required if k not in artifact]
    if missing:
        raise ValueError(f"Model artifact missing required keys: {missing}")
    return artifact


def build_or_load_features(args: argparse.Namespace, out_dir: Path) -> Tuple[pd.DataFrame, Dict[str, Any]]:
    if args.engineered_features:
        p = Path(args.engineered_features).expanduser()
        if not p.exists():
            raise FileNotFoundError(f"Engineered features file not found: {p}")
        log(f"Loading existing engineered features: {p}")
        df = pd.read_csv(p, low_memory=False)
        df.columns = [clean_col_name(c) for c in df.columns]
        return df, {"engineered_features_input": str(p), "engineered_feature_rows": int(len(df))}
    if not args.input:
        raise ValueError("Either --input or --engineered-features is required.")
    script_dir = Path(__file__).resolve().parent
    if str(script_dir) not in sys.path:
        sys.path.insert(0, str(script_dir))
    from v9_feature_engineering import build_feature_table  # type: ignore
    # During inference, reference mode is still none here; RCA reference enrichment happens after ML scoring.
    setattr(args, "reference_mode", "none")
    feature_out = out_dir / "feature_engineering"
    df, info = build_feature_table(Path(args.input).expanduser(), feature_out, args)
    df.to_csv(feature_out / "cesmlc_v9_engineered_features_for_inference.csv", index=False)
    return df, info


def prepare_X(df: pd.DataFrame, features: List[str], categorical_features: List[str]) -> pd.DataFrame:
    X = df.copy()
    for c in features:
        if c not in X.columns:
            X[c] = np.nan
    X = X[features].copy()
    for c in categorical_features:
        if c in X.columns:
            X[c] = X[c].fillna("__MISSING__").astype(str)
    for c in features:
        if c not in set(categorical_features):
            X[c] = pd.to_numeric(X[c], errors="coerce")
    return X


def predict_dataframe(artifact: Dict[str, Any], df: pd.DataFrame) -> pd.DataFrame:
    model = artifact["model"]
    features = [clean_col_name(c) for c in artifact.get("features", [])]
    categorical = [clean_col_name(c) for c in artifact.get("categorical_features", [])]
    backend = str(artifact.get("backend", "")).lower()
    X = prepare_X(df, features, categorical)
    pred = np.asarray(model.predict(X)).reshape(-1)
    pred = np.array([sanitize_label(x) for x in pred])
    classes = [sanitize_label(x) for x in artifact.get("classes", [])]
    if not classes:
        if hasattr(model, "classes_"):
            classes = [sanitize_label(x) for x in model.classes_]
        elif hasattr(model, "named_steps") and hasattr(model.named_steps.get("model"), "classes_"):
            classes = [sanitize_label(x) for x in model.named_steps["model"].classes_]
    proba = None
    try:
        proba = model.predict_proba(X)
    except Exception:
        proba = None
    out = pd.DataFrame({"MODEL_PREDICTED_LABEL": pred})
    if proba is not None and classes:
        for i, cls in enumerate(classes):
            if i < proba.shape[1]:
                out[f"PRED_PROBA_{cls}"] = proba[:, i]
        prob_idx = [i for i, cls in enumerate(classes) if cls in PROBLEM_LABELS]
        out["ML_PROBLEM_PROBABILITY"] = proba[:, prob_idx].sum(axis=1) if prob_idx else 0.0
        out["MODEL_CONFIDENCE"] = proba.max(axis=1)
    else:
        out["ML_PROBLEM_PROBABILITY"] = out["MODEL_PREDICTED_LABEL"].isin(PROBLEM_LABELS).astype(float)
        out["MODEL_CONFIDENCE"] = 1.0
    return out


def add_temporal_score(scored: pd.DataFrame) -> pd.DataFrame:
    out = scored.copy()
    n = len(out)
    def num(col: str, default: float = 0.0) -> pd.Series:
        return safe_numeric(out[col], default) if col in out.columns else pd.Series(np.ones(n) * default, index=out.index)
    score = pd.Series(np.zeros(n), index=out.index, dtype=float)
    score += np.minimum(20.0, 1.8 * num("SOURCE_CHANGE_DAYS_COUNT"))
    score += np.minimum(14.0, 0.9 * num("SOURCE_CHANGE_COUNT"))
    score += np.minimum(12.0, 3.0 * np.maximum(num("DISTINCT_SOURCE_VALUES_30D") - 1, 0))
    score += 12.0 * (num("LATEST_SOURCE_INVALID_RANGE_FLAG") > 0).astype(int)
    score += 8.0 * (num("LATEST_SOURCE_IS_DEFAULT_FLAG") > 0).astype(int)
    score += np.minimum(10.0, 3.0 * num("SOURCE_A_B_A_REVERT_COUNT"))
    score += np.minimum(10.0, 3.0 * num("SOURCE_REVERSE_TRANSITION_COUNT"))
    score += np.minimum(8.0, 2.0 * num("SOURCE_SAME_DAY_CONFLICT_DAYS"))
    score += np.minimum(8.0, 0.5 * num("FEATURE_CRITICALITY_WEIGHT", 5.0))
    score -= np.minimum(12.0, 35.0 * num("MAX_CANDIDATE_BULK_CHANGE_RATIO"))
    out["TEMPORAL_OPERATIONAL_SCORE"] = score.clip(lower=0)
    out["TEMPORAL_OPERATIONAL_PERCENTILE"] = percentile_rank(out["TEMPORAL_OPERATIONAL_SCORE"])
    out["ML_FINAL_PROBLEM_SCORE"] = (
        100.0 * safe_numeric(out.get("ML_PROBLEM_PROBABILITY", 0), 0)
        + 0.35 * safe_numeric(out["TEMPORAL_OPERATIONAL_SCORE"], 0)
        + 0.15 * safe_numeric(out["TEMPORAL_OPERATIONAL_PERCENTILE"], 0)
    )
    return out



def apply_prediction_sanity_gate(scored: pd.DataFrame, args: argparse.Namespace) -> pd.DataFrame:
    """Reject class predictions that contradict the temporal evidence.

    This protects inference when an older weak-supervised artifact learned overly broad
    seed rules. It does not create labels; it only prevents impossible/unsupported
    class names from entering the abnormal report.
    """
    out = scored.copy()
    label = out.get("MODEL_PREDICTED_LABEL", pd.Series([""] * len(out), index=out.index)).astype(str).map(sanitize_label)
    change_count = safe_numeric(out.get("SOURCE_CHANGE_COUNT", 0), 0)
    change_days = safe_numeric(out.get("SOURCE_CHANGE_DAYS_COUNT", 0), 0)
    distinct_vals = safe_numeric(out.get("DISTINCT_SOURCE_VALUES_30D", 0), 0)
    mode_share = safe_numeric(out.get("MODE_SOURCE_VALUE_SHARE_PERCENT", 100), 100)
    aba = safe_numeric(out.get("SOURCE_A_B_A_REVERT_COUNT", 0), 0)
    reverse = safe_numeric(out.get("SOURCE_REVERSE_TRANSITION_COUNT", 0), 0)
    latest_default = safe_numeric(out.get("LATEST_SOURCE_IS_DEFAULT_FLAG", 0), 0)
    prev_default = safe_numeric(out.get("PREVIOUS_NONLATEST_SOURCE_IS_DEFAULT_FLAG", 0), 0)
    latest_days = safe_numeric(out.get("LATEST_SOURCE_VALUE_DAYS", 0), 0)
    bulk = safe_numeric(out.get("MAX_CANDIDATE_BULK_CHANGE_RATIO", 0), 0)
    multi = safe_numeric(out.get("MAX_MULTI_FIELD_SAME_DAY_CHANGE_COUNT", 0), 0)
    invalid = safe_numeric(out.get("LATEST_SOURCE_INVALID_RANGE_FLAG", 0), 0)
    conflict = safe_numeric(out.get("SOURCE_SAME_DAY_CONFLICT_DAYS", 0), 0)
    delta_abs = safe_numeric(out.get("VALUE_DELTA_LATEST_PREVIOUS", 0), 0).abs()

    pass_gate = pd.Series(True, index=out.index)
    reason = pd.Series("", index=out.index, dtype="object")

    real_mask = label.eq("REAL_BACK_AND_FORTH_INSTABILITY")
    real_ok = (
        ((aba >= int(args.sanity_min_aba_for_backforth)) | (reverse >= int(args.sanity_min_reverses_for_backforth)))
        & (change_count >= int(args.sanity_backforth_min_change_count))
        & (change_days >= int(args.sanity_backforth_min_change_days))
        & (distinct_vals <= int(args.sanity_backforth_max_distinct_values))
    )
    bad = real_mask & ~real_ok
    pass_gate.loc[bad] = False
    reason.loc[bad] = "REJECT_REAL_BACK_FORTH_NO_TRUE_REVERSE_OR_ABA"

    high_mask = label.eq("HIGH_FREQUENCY_DIFFERENT_VALUES")
    high_ok = (
        (change_days >= int(args.sanity_high_frequency_days))
        & (distinct_vals >= int(args.sanity_high_frequency_distinct_values))
        & (mode_share < float(args.sanity_high_frequency_max_mode_share))
    )
    bad = high_mask & ~high_ok
    pass_gate.loc[bad] = False
    reason.loc[bad] = "REJECT_HIGH_FREQUENCY_INSUFFICIENT_CHANGE_DAYS_OR_DISTINCT_VALUES"

    fallback_mask = label.isin(["FLUCTUATING_FALLBACK_TO_DEFAULT", "LONG_TERM_FALLBACK_TO_DEFAULT"])
    fallback_ok = (
        (latest_default == 1)
        & (latest_days >= int(args.sanity_default_min_days))
        & ((prev_default == 0) | (change_count >= 1))
    )
    bad = fallback_mask & ~fallback_ok
    pass_gate.loc[bad] = False
    reason.loc[bad] = "REJECT_FALLBACK_NO_LATEST_DEFAULT_EVIDENCE"

    rare_mask = label.eq("RARE_UNCOMMON_CHANGES")
    rare_ok = (
        bool(args.enable_rare_inference_gate)
        & (change_count >= int(args.sanity_rare_min_change_count))
        & (change_days >= int(args.sanity_rare_min_change_days))
        & (change_days <= int(args.sanity_rare_max_change_days))
        & (bulk <= float(args.sanity_rare_max_bulk_change_ratio))
        & (multi <= int(args.sanity_rare_max_multi_field_same_day_count))
        & ((invalid > 0) | (conflict > 0) | (delta_abs >= float(args.sanity_rare_min_abs_delta)))
    )
    bad = rare_mask & ~rare_ok
    pass_gate.loc[bad] = False
    reason.loc[bad] = "REJECT_RARE_UNCOMMON_WEAK_OR_ONE_TIME_CHANGE"

    out["SANITY_GATE_PASS"] = pass_gate.astype(int)
    out["SANITY_GATE_REJECT_REASON"] = reason
    return out

def abnormal_feature_filter(scored: pd.DataFrame, args: argparse.Namespace) -> pd.Series:
    pred_problem = scored["MODEL_PREDICTED_LABEL"].astype(str).map(sanitize_label).isin(PROBLEM_LABELS)
    prob_ok = safe_numeric(scored.get("ML_PROBLEM_PROBABILITY", 0), 0) >= float(args.problem_prob_threshold)
    score_ok = safe_numeric(scored.get("ML_FINAL_PROBLEM_SCORE", 0), 0) >= float(args.final_score_threshold)
    conf_ok = safe_numeric(scored.get("MODEL_CONFIDENCE", 0), 0) >= float(args.min_model_confidence)
    if args.gate_mode == "strict":
        return pred_problem & prob_ok & score_ok & conf_ok
    if args.gate_mode == "review":
        return (pred_problem & conf_ok) | prob_ok | score_ok
    # balanced default: predicted problem plus confidence and one strong severity condition.
    return pred_problem & conf_ok & (prob_ok | score_ok)


def join_unique(values: Iterable[Any], max_items: int = 20) -> str:
    out: List[str] = []
    for v in values:
        s = str(v)
        if s and s.lower() != "nan" and s not in out:
            out.append(s)
        if len(out) >= max_items:
            break
    return ";".join(out)


def recommend_next_check(r: pd.Series) -> str:
    label = str(r.get("PRIMARY_ANOMALY_CLUSTER", "")).upper()
    feature = str(r.get("PRIMARY_ABNORMAL_FEATURE", ""))
    compat = str(r.get("DATA_SOURCE_COMPATIBILITY", "NOT_CHECKED"))
    if "FALLBACK" in label:
        return f"Check {feature} fallback against RAN references, planned activity/COW/site rebuild, and upstream feed defaulting. Reference compatibility={compat}."
    if label == "REAL_BACK_AND_FORTH_INSTABILITY":
        return f"Trace {feature} across source load jobs and automation history; look for competing overwrites or reversions."
    if label == "HIGH_FREQUENCY_DIFFERENT_VALUES":
        return f"Trace {feature} source feed joins/imports; verify whether frequent changes match planned network work."
    if label == "RARE_UNCOMMON_CHANGES":
        return f"Use RCA/reference/ticket checks for {feature}; verify planned activity and whether value exists in RAN source-of-truth."
    return f"Review {feature} temporal evidence and run RCA checks before action."


def build_ecgi_summary(abnormal_features: pd.DataFrame) -> pd.DataFrame:
    if abnormal_features.empty:
        return pd.DataFrame()
    af = abnormal_features.copy().sort_values(["ECGI", "ML_FINAL_PROBLEM_SCORE"], ascending=[True, False])
    top = af.groupby("ECGI", as_index=False).head(1).copy().rename(columns={
        "FEATURE": "PRIMARY_ABNORMAL_FEATURE",
        "MODEL_PREDICTED_LABEL": "PRIMARY_ANOMALY_CLUSTER",
        "MODEL_CONFIDENCE": "PRIMARY_MODEL_CONFIDENCE",
        "ML_PROBLEM_PROBABILITY": "PRIMARY_ML_PROBLEM_PROBABILITY",
        "ML_FINAL_PROBLEM_SCORE": "PRIMARY_ML_FINAL_PROBLEM_SCORE",
    })
    agg = af.groupby("ECGI", as_index=False).agg(
        ABNORMAL_FEATURE_COUNT=("FEATURE", "nunique"),
        ABNORMAL_FEATURE_ROW_COUNT=("FEATURE", "size"),
        ECGI_ML_FINAL_PROBLEM_SCORE=("ML_FINAL_PROBLEM_SCORE", "max"),
        ECGI_AVG_ML_PROBLEM_PROBABILITY=("ML_PROBLEM_PROBABILITY", "mean"),
        ECGI_MAX_ML_PROBLEM_PROBABILITY=("ML_PROBLEM_PROBABILITY", "max"),
        ECGI_AVG_MODEL_CONFIDENCE=("MODEL_CONFIDENCE", "mean"),
        SOURCE_CHANGE_DAYS_COUNT_TOTAL=("SOURCE_CHANGE_DAYS_COUNT", "sum") if "SOURCE_CHANGE_DAYS_COUNT" in af.columns else ("FEATURE", "size"),
        SOURCE_CHANGE_COUNT_TOTAL=("SOURCE_CHANGE_COUNT", "sum") if "SOURCE_CHANGE_COUNT" in af.columns else ("FEATURE", "size"),
        MAX_ABNORMAL_DAYS_SINGLE_FEATURE=("SOURCE_CHANGE_DAYS_COUNT", "max") if "SOURCE_CHANGE_DAYS_COUNT" in af.columns else ("FEATURE", "size"),
        DISTINCT_PROBLEM_CLUSTERS=("MODEL_PREDICTED_LABEL", pd.Series.nunique),
    )
    feat_list = af.groupby("ECGI").apply(lambda d: join_unique(d.sort_values("ML_FINAL_PROBLEM_SCORE", ascending=False)["FEATURE"].tolist(), 30)).rename("ABNORMAL_FEATURES").reset_index()
    detail = af.groupby("ECGI").apply(lambda d: " | ".join(
        f"{r.FEATURE}:{r.MODEL_PREDICTED_LABEL}:score={float(r.ML_FINAL_PROBLEM_SCORE):.1f}:p={float(r.ML_PROBLEM_PROBABILITY):.2f}:days={int(getattr(r, 'SOURCE_CHANGE_DAYS_COUNT', 0) or 0)}:latest={short_value(getattr(r, 'LATEST_SOURCE_VALUE_RAW', ''), 35)}"
        for r in d.sort_values("ML_FINAL_PROBLEM_SCORE", ascending=False).head(8).itertuples()
    )).rename("TOP_FEATURE_DETAILS_WITH_DAYS").reset_index()
    keep_cols = ["ECGI", "ECGI_LABEL", "REGION", "MARKETCLUSTER", "MARKET", "SUBMARKET", "SERVER_ID", "PRIMARY_ANOMALY_CLUSTER", "PRIMARY_ABNORMAL_FEATURE", "PRIMARY_MODEL_CONFIDENCE", "PRIMARY_ML_PROBLEM_PROBABILITY", "PRIMARY_ML_FINAL_PROBLEM_SCORE", "LATEST_SOURCE_VALUE_RAW", "PREVIOUS_NONLATEST_SOURCE_VALUE_RAW", "SOURCE_CHANGE_DAYS_COUNT", "SOURCE_CHANGE_COUNT", "DISTINCT_SOURCE_VALUES_30D", "LATEST_SOURCE_CHANGE_TEXT", "SOURCE_FIRST_CHANGE_DATE", "SOURCE_LAST_CHANGE_DATE", "DAYS_SINCE_LAST_SOURCE_CHANGE", "DATA_SOURCE_COMPATIBILITY", "REFERENCE_SOURCE_NAME", "REFERENCE_COLUMN", "REFERENCE_VALUE_RAW"]
    ecgi = agg.merge(top[[c for c in keep_cols if c in top.columns]], on="ECGI", how="left")
    ecgi = ecgi.merge(feat_list, on="ECGI", how="left").merge(detail, on="ECGI", how="left")
    ecgi["ECGI_RANKING_SCORE"] = safe_numeric(ecgi["ECGI_ML_FINAL_PROBLEM_SCORE"], 0) + 5.0 * np.maximum(safe_numeric(ecgi["ABNORMAL_FEATURE_COUNT"], 0) - 1, 0) + 10.0 * (safe_numeric(ecgi["DISTINCT_PROBLEM_CLUSTERS"], 0) > 1).astype(int)
    ecgi["ECGI_PROBLEM_PERCENTILE"] = percentile_rank(ecgi["ECGI_RANKING_SCORE"])
    ecgi["RECOMMENDED_NEXT_CHECK"] = ecgi.apply(recommend_next_check, axis=1)
    ecgi = ecgi.sort_values("ECGI_RANKING_SCORE", ascending=False).reset_index(drop=True)
    ecgi.insert(0, "ECGI_PROBLEM_RANK", np.arange(1, len(ecgi)+1))
    return ecgi


def enrich_reference_rca(abnormal_features: pd.DataFrame, args: argparse.Namespace) -> pd.DataFrame:
    if abnormal_features.empty:
        return abnormal_features
    if not (args.reference_source_dir or args.atoll_master_4g or args.ericsson_5g_master_data or args.cssng_data_addition or args.atoll_cells5g):
        return abnormal_features
    script_dir = Path(__file__).resolve().parent
    if str(script_dir) not in sys.path:
        sys.path.insert(0, str(script_dir))
    for mod_name in ["v82_feature_engineering", "v821_feature_engineering", "v821_fixed_feature_engineering", "v81_feature_engineering"]:
        try:
            mod = __import__(mod_name, fromlist=["attach_reference_compatibility", "load_feature_rules"])
            rules = mod.load_feature_rules(getattr(args, "defaults_json", None)) if hasattr(mod, "load_feature_rules") else {}
            setattr(args, "disable_reference_compatibility", False)
            log(f"Applying post-model RCA/reference enrichment using {mod_name}", indent=1)
            out = mod.attach_reference_compatibility(abnormal_features, rules, args)
            out.columns = [clean_col_name(c) for c in out.columns]
            return out
        except Exception as exc:
            last = exc
            continue
    log(f"Warning: RCA/reference enrichment failed; continuing without it. Last error: {last}", indent=1)
    return abnormal_features


def write_jsonl(df: pd.DataFrame, path: Path, max_rows: int) -> None:
    with path.open("w", encoding="utf-8") as f:
        for _, r in df.head(max_rows).iterrows():
            obj = {str(k): (None if pd.isna(v) else v) for k, v in r.to_dict().items()}
            f.write(json.dumps(obj, default=str) + "\n")


