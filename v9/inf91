    if not abnormal.empty:
        counts=abnormal["MODEL_PREDICTED_LABEL"].value_counts().head(12)
        fig,ax=plt.subplots(figsize=(8,8)); ax.pie(counts.values, labels=counts.index, autopct="%1.1f%%", startangle=90); ax.set_title("Abnormal feature cluster composition"); save(fig,"05_abnormal_cluster_composition_pie.png","Abnormal feature cluster composition")
        if "FEATURE" in abnormal.columns:
            pivot=pd.crosstab(abnormal["FEATURE"], abnormal["MODEL_PREDICTED_LABEL"])
            pivot=pivot.loc[pivot.sum(axis=1).sort_values(ascending=False).head(25).index]
            if pivot.size:
                fig,ax=plt.subplots(figsize=(max(9,.7*pivot.shape[1]+6),max(6,.35*pivot.shape[0]+3))); im=ax.imshow(pivot.values,aspect="auto"); ax.set_title("Feature x abnormal cluster heatmap"); ax.set_xticks(np.arange(pivot.shape[1])); ax.set_yticks(np.arange(pivot.shape[0])); ax.set_xticklabels(pivot.columns,rotation=45,ha="right",fontsize=8); ax.set_yticklabels(pivot.index,fontsize=8); fig.colorbar(im,ax=ax,label="Rows"); save(fig,"06_feature_by_abnormal_cluster_heatmap.png","Feature by abnormal cluster heatmap")
        if {"SOURCE_CHANGE_DAYS_COUNT","ML_FINAL_PROBLEM_SCORE"}.issubset(abnormal.columns):
            samp=abnormal.sample(n=min(len(abnormal),50000), random_state=42) if len(abnormal)>50000 else abnormal
            fig,ax=plt.subplots(figsize=(9,7)); sc=ax.scatter(safe_numeric(samp["SOURCE_CHANGE_DAYS_COUNT"],0),safe_numeric(samp["ML_FINAL_PROBLEM_SCORE"],0),s=8,alpha=.35,c=safe_numeric(samp.get("ML_PROBLEM_PROBABILITY",0),0)); fig.colorbar(sc,ax=ax,label="ML_PROBLEM_PROBABILITY"); ax.set_title("Abnormal days vs final score"); ax.set_xlabel("SOURCE_CHANGE_DAYS_COUNT"); ax.set_ylabel("ML_FINAL_PROBLEM_SCORE"); ax.grid(True,alpha=.3); save(fig,"07_abnormal_days_vs_score.png","Abnormal days vs final score")
    if "ML_PROBLEM_PROBABILITY" in scored.columns and "ECGI" in scored.columns:
        vals=safe_numeric(scored["ML_PROBLEM_PROBABILITY"],0)
        thr=[]
        for t in np.linspace(0,1,101):
            m=vals>=t
            thr.append({"THRESHOLD":float(t),"FEATURE_ROWS":int(m.sum()),"ECGIS":int(scored.loc[m,"ECGI"].nunique())})
        thrdf=pd.DataFrame(thr); thrdf.to_csv(out_dir/"cesmlc_v9_inference_probability_threshold_volume.csv",index=False)
        fig,ax=plt.subplots(figsize=(10,6)); ax.plot(thrdf["THRESHOLD"],thrdf["FEATURE_ROWS"],label="Feature rows"); ax.plot(thrdf["THRESHOLD"],thrdf["ECGIS"],label="ECGIs"); ax.set_title("Operational volume by probability threshold"); ax.set_xlabel("ML_PROBLEM_PROBABILITY threshold"); ax.set_ylabel("Count"); ax.legend(); ax.grid(True,alpha=.3); save(fig,"08_probability_threshold_volume_curve.png","Operational volume by probability threshold")
    plot_index=pd.DataFrame(rows); plot_index.to_csv(out_dir/"cesmlc_v9_inference_plot_index.csv",index=False); return plot_index


def write_report(out_dir: Path, artifact: Dict[str, Any], feature_info: Dict[str, Any], scored: pd.DataFrame, abnormal: pd.DataFrame, ecgi: pd.DataFrame, grouped_top: pd.DataFrame, plot_index: pd.DataFrame, args: argparse.Namespace) -> None:
    lines=[]
    lines.append("# CESMLC V9 Daily ML Inference Report")
    lines.append("")
    lines.append(f"Inference script version: `{SCRIPT_VERSION}`")
    lines.append(f"Model artifact version: `{artifact.get('script_version','')}`")
    lines.append(f"Backend: `{artifact.get('backend','')}`")
    lines.append("")
    lines.append("## Run summary")
    lines.append(f"- Total ECGI-feature rows scored: **{len(scored):,}**")
    lines.append(f"- Abnormal feature rows after gate: **{len(abnormal):,}**")
    lines.append(f"- Abnormal ECGIs after gate: **{len(ecgi):,}**")
    lines.append(f"- Gate mode: `{args.gate_mode}`")
    lines.append(f"- Problem probability threshold: `{args.problem_prob_threshold}`")
    lines.append(f"- Final score threshold: `{args.final_score_threshold}`")
    lines.append(f"- Minimum confidence threshold: `{args.min_model_confidence}`")
    lines.append(f"- Report top N: `{args.report_top_n}`, per-cluster top N: `{args.per_cluster_top_n}`")
    lines.append("")
    if feature_info:
        lines.append("## Feature-building context")
        for k in ["window_start_date","window_end_date","candidate_mode","selected_candidate_ecgis","engineered_feature_rows","feature_count","engineered_features_input"]:
            if k in feature_info: lines.append(f"- {k}: `{feature_info.get(k)}`")
        lines.append("")
    if not abnormal.empty:
        lines.append("## Abnormal cluster distribution")
        for label,count in abnormal["MODEL_PREDICTED_LABEL"].value_counts().items():
            lines.append(f"- **{label}**: {int(count):,}")
        lines.append("")
    if not grouped_top.empty:
        lines.append("## Grouped top ECGIs for review")
        for cluster, d in grouped_top.groupby("PRIMARY_ANOMALY_CLUSTER", sort=False):
            lines.append(f"### {cluster}")
            for _,r in d.iterrows():
                lines.append(
                    f"- rank={r.get('ECGI_PROBLEM_RANK','')} | ECGI={r.get('ECGI','')} | server={r.get('SERVER_ID','')} | market={r.get('MARKET','')} | "
                    f"primary_feature={r.get('PRIMARY_ABNORMAL_FEATURE','')} | abnormal_days={r.get('MAX_ABNORMAL_DAYS_SINGLE_FEATURE','')} | "
                    f"change_events={r.get('SOURCE_CHANGE_COUNT_TOTAL','')} | features={r.get('ABNORMAL_FEATURES','')} | "
                    f"score={float(r.get('ECGI_RANKING_SCORE',0) or 0):.1f} | p={float(r.get('PRIMARY_ML_PROBLEM_PROBABILITY',0) or 0):.3f} | "
                    f"next={r.get('RECOMMENDED_NEXT_CHECK','')}"
                )
            lines.append("")
    if plot_index is not None and not plot_index.empty:
        lines.append("## Plots")
        for _,r in plot_index.head(30).iterrows():
            lines.append(f"- `{r.get('PLOT_FILE','')}` â {r.get('DESCRIPTION','')}")
    (out_dir/"cesmlc_v9_inference_report.md").write_text("\n".join(lines), encoding="utf-8")


def run_inference(args: argparse.Namespace) -> None:
    out_dir=Path(args.out_dir).expanduser(); out_dir.mkdir(parents=True, exist_ok=True)
    header("CESMLC V9 DAILY ML INFERENCE")
    artifact=load_artifact(Path(args.model_artifact).expanduser())
    log(f"Loaded artifact backend={artifact.get('backend')} features={len(artifact.get('features', [])):,}", indent=1)
    features_df, feature_info = build_or_load_features(args,out_dir)
    pred = predict_dataframe(artifact, features_df)
    scored = pd.concat([features_df.reset_index(drop=True), pred.reset_index(drop=True)], axis=1)
    scored = add_temporal_score(scored).sort_values("ML_FINAL_PROBLEM_SCORE", ascending=False).reset_index(drop=True)
    if not args.no_sanity_gate:
        scored = apply_prediction_sanity_gate(scored, args)
    else:
        scored["SANITY_GATE_PASS"] = 1
        scored["SANITY_GATE_REJECT_REASON"] = ""
    scored.insert(0,"ML_SCORE_RANK",np.arange(1,len(scored)+1))
    scored.to_csv(out_dir/"cesmlc_v9_inference_scores_all.csv",index=False)
    scored.head(args.top_n).to_csv(out_dir/f"cesmlc_v9_inference_scores_top{args.top_n}.csv",index=False)
    mask = abnormal_feature_filter(scored,args) & (safe_numeric(scored.get("SANITY_GATE_PASS", 1), 1).astype(int) == 1)
    abnormal = scored[mask].copy().sort_values("ML_FINAL_PROBLEM_SCORE", ascending=False).reset_index(drop=True)
    if abnormal.empty and args.fallback_to_top_problems:
        fallback = scored[scored["MODEL_PREDICTED_LABEL"].isin(PROBLEM_LABELS)].copy()
        if not fallback.empty:
            log("Gate produced zero rows; fallback_to_top_problems enabled, selecting top predicted-problem rows by score.", indent=1)
            abnormal = fallback.head(int(args.fallback_problem_feature_rows)).copy().reset_index(drop=True)
    if not abnormal.empty:
        abnormal = enrich_reference_rca(abnormal,args)
        abnormal = abnormal.sort_values("ML_FINAL_PROBLEM_SCORE", ascending=False).reset_index(drop=True)
        abnormal.insert(0,"ABNORMAL_FEATURE_RANK",np.arange(1,len(abnormal)+1))
    abnormal.to_csv(out_dir/"cesmlc_v9_inference_abnormal_features_all.csv",index=False)
    abnormal.head(args.top_n).to_csv(out_dir/f"cesmlc_v9_inference_abnormal_features_top{args.top_n}.csv",index=False)
    ecgi = build_ecgi_summary(abnormal)
    ecgi.to_csv(out_dir/"cesmlc_v9_inference_abnormal_ecgi_summary_all.csv",index=False)
    ecgi.head(args.top_n).to_csv(out_dir/f"cesmlc_v9_inference_abnormal_ecgi_summary_top{args.top_n}.csv",index=False)
    grouped=[]
    if not ecgi.empty:
        for cluster,d in ecgi.groupby("PRIMARY_ANOMALY_CLUSTER", sort=False):
            grouped.append(d.sort_values("ECGI_RANKING_SCORE", ascending=False).head(int(args.per_cluster_top_n)))
    grouped_top = pd.concat(grouped, ignore_index=True, sort=False).sort_values(["PRIMARY_ANOMALY_CLUSTER","ECGI_RANKING_SCORE"], ascending=[True,False]).head(int(args.report_top_n)) if grouped else pd.DataFrame()
    grouped_top.to_csv(out_dir/"cesmlc_v9_inference_abnormal_ecgi_summary_grouped_top.csv",index=False)
    write_jsonl(abnormal, out_dir/"cesmlc_v9_inference_agent_feature_payload.jsonl", int(args.agent_payload_max_rows))
    write_jsonl(ecgi, out_dir/"cesmlc_v9_inference_agent_ecgi_payload.jsonl", int(args.agent_payload_max_rows))
    plot_index=create_plots(out_dir, scored, abnormal, ecgi, args)
    write_report(out_dir, artifact, feature_info, scored, abnormal, ecgi, grouped_top, plot_index, args)
    summary={"script_version":SCRIPT_VERSION,"artifact_backend":artifact.get("backend"),"scored_feature_rows":len(scored),"abnormal_feature_rows":len(abnormal),"abnormal_ecgis":len(ecgi),"gate_mode":args.gate_mode,"problem_prob_threshold":args.problem_prob_threshold,"final_score_threshold":args.final_score_threshold,"min_model_confidence":args.min_model_confidence,"created_at":time.strftime("%Y-%m-%d %H:%M:%S")}
    pd.DataFrame([summary]).to_csv(out_dir/"cesmlc_v9_inference_run_summary.csv",index=False)
    (out_dir/"cesmlc_v9_inference_run_config.json").write_text(json.dumps(vars(args), indent=2, default=str), encoding="utf-8")
    header("DONE")
    log(f"Scored feature rows: {len(scored):,}")
    log(f"Abnormal feature rows after gate: {len(abnormal):,}")
    log(f"Abnormal ECGIs after gate: {len(ecgi):,}")
    log(f"Open report: {out_dir/'cesmlc_v9_inference_report.md'}")
    log(f"Open grouped top: {out_dir/'cesmlc_v9_inference_abnormal_ecgi_summary_grouped_top.csv'}")


def parse_args() -> argparse.Namespace:
    p=argparse.ArgumentParser(description="CESMLC V9 daily inference with post-model RCA/reference enrichment.")
    src=p.add_mutually_exclusive_group(required=True)
    src.add_argument("--input", default=None, type=str, help="Raw ENMT/CESMLC CSV input.")
    src.add_argument("--engineered-features", default=None, type=str, help="Existing engineered feature CSV.")
    p.add_argument("--model-artifact", required=True, type=str)
    p.add_argument("--out-dir", required=True, type=str)
    # Raw feature-engineering pass-through.
    p.add_argument("--days", default=30, type=int)
    p.add_argument("--end-date", default=None, type=str)
    p.add_argument("--server-id", default=None, type=str)
    p.add_argument("--candidate-mode", default="db_mismatch_only", choices=["db_mismatch_only","all_latest_ecgis","db_mismatch_plus_normal_sample"])
    p.add_argument("--normal-sample-size", default=0, type=int)
    p.add_argument("--max-candidate-ecgis", default=0, type=int)
    p.add_argument("--include-features", default=",".join(DEFAULT_FEATURES), type=str)
    p.add_argument("--exclude-features", default=None, type=str)
    p.add_argument("--defaults-json", default=None, type=str)
    p.add_argument("--enable-db-features", action="store_true")
    p.add_argument("--reference-source-dir", default=None, type=str)
    p.add_argument("--atoll-master-4g", default=None, type=str)
    p.add_argument("--ericsson-5g-master-data", default=None, type=str)
    p.add_argument("--cssng-data-addition", default=None, type=str)
    p.add_argument("--atoll-cells5g", default=None, type=str)
    p.add_argument("--reference-mapping-json", default=None, type=str)
    p.add_argument("--disable-reference-compatibility", action="store_true")
    p.add_argument("--reference-numeric-tolerance", default=0.00005, type=float)
    p.add_argument("--latlon-decimals", default=5, type=int)
    p.add_argument("--feature-batch-size", default=1, type=int)
    p.add_argument("--threads", default=1, type=int)
    p.add_argument("--memory-limit", default="6GB", type=str)
    p.add_argument("--duckdb-file", default=None, type=str)
    p.add_argument("--duckdb-temp-dir", default=None, type=str)
    p.add_argument("--keep-duckdb", action="store_true")
    p.add_argument("--random-state", default=42, type=int)
    # Gate/reporting.
    p.add_argument("--gate-mode", default="balanced", choices=["balanced","strict","review"])
    p.add_argument("--no-sanity-gate", action="store_true", help="Disable temporal sanity rejection of impossible class predictions.")
    p.add_argument("--sanity-min-reverses-for-backforth", default=1, type=int)
    p.add_argument("--sanity-min-aba-for-backforth", default=1, type=int)
    p.add_argument("--sanity-backforth-min-change-count", default=2, type=int)
    p.add_argument("--sanity-backforth-min-change-days", default=2, type=int)
    p.add_argument("--sanity-backforth-max-distinct-values", default=3, type=int)
    p.add_argument("--sanity-high-frequency-days", default=5, type=int)
    p.add_argument("--sanity-high-frequency-distinct-values", default=3, type=int)
    p.add_argument("--sanity-high-frequency-max-mode-share", default=85.0, type=float)
    p.add_argument("--sanity-default-min-days", default=2, type=int)
    p.add_argument("--enable-rare-inference-gate", action="store_true", help="Allow RARE_UNCOMMON_CHANGES into report only if strict rare evidence passes. Default off.")
    p.add_argument("--sanity-rare-min-change-count", default=2, type=int)
    p.add_argument("--sanity-rare-min-change-days", default=2, type=int)
    p.add_argument("--sanity-rare-max-change-days", default=3, type=int)
    p.add_argument("--sanity-rare-max-bulk-change-ratio", default=0.01, type=float)
    p.add_argument("--sanity-rare-max-multi-field-same-day-count", default=1, type=int)
    p.add_argument("--sanity-rare-min-abs-delta", default=50.0, type=float)
    p.add_argument("--problem-prob-threshold", default=0.90, type=float)
    p.add_argument("--final-score-threshold", default=95.0, type=float)
    p.add_argument("--min-model-confidence", default=0.70, type=float)
    p.add_argument("--top-n", default=500, type=int)
    p.add_argument("--report-top-n", default=100, type=int)
    p.add_argument("--per-cluster-top-n", default=20, type=int)
    p.add_argument("--fallback-to-top-problems", action="store_true", default=True)
    p.add_argument("--no-fallback-to-top-problems", action="store_false", dest="fallback_to_top_problems")
    p.add_argument("--fallback-problem-feature-rows", default=5000, type=int)
    p.add_argument("--agent-payload-max-rows", default=100000, type=int)
    p.add_argument("--no-plots", action="store_true")
    return p.parse_args()


def main() -> int:
    args=parse_args(); run_inference(args); return 0


if __name__ == "__main__":
    raise SystemExit(main())
