def main() -> int:
    args = parse_args()
    out_dir = Path(args.out_dir).expanduser(); out_dir.mkdir(parents=True, exist_ok=True)
    header("CESMLC V9 TRAINING DATASET BUILDER")
    features_df, feature_report = build_or_load_features(args, out_dir)
    dataset = add_seed_labels(features_df, args)
    dataset = merge_manual_labels(dataset, args.manual_labels)
    balanced, balance_report = (None, None)
    if args.write_balanced_training_dataset:
        balanced, balance_report = build_balanced_training_dataset(dataset, args)
    write_outputs(out_dir, dataset, feature_report, balanced, balance_report, args)
    header("DONE")
    log(f"Total runtime: {elapsed_text()}")
    log(f"Open first: {out_dir / 'cesmlc_v9_training_weak_label_review_report.md'}")
    log(f"Train using: {out_dir / 'cesmlc_v9_balanced_model_ready_training_dataset.csv'}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())