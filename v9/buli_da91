    log(f"Output: {out_dir}", indent=1)


def build_or_load_features(args: argparse.Namespace, out_dir: Path) -> Tuple[pd.DataFrame, Dict[str, Any]]:
    if args.engineered_features:
        p = Path(args.engineered_features).expanduser()
        if not p.exists():
            raise FileNotFoundError(f"Engineered features file not found: {p}")
        log(f"Loading existing engineered features: {p}")
        df = pd.read_csv(p, low_memory=False)
        df.columns = [clean_col_name(c) for c in df.columns]
        return df, {"engineered_features_input": str(p), "engineered_feature_rows": int(len(df))}
    if not args.input:
        raise ValueError("Either --input or --engineered-features is required.")
    script_dir = Path(__file__).resolve().parent
    if str(script_dir) not in sys.path:
        sys.path.insert(0, str(script_dir))
    module_names = ["v9_feature_engineering", "v82_feature_engineering", "v821_feature_engineering", "v821_fixed_feature_engineering", "v81_feature_engineering"]
    last_exc: Optional[Exception] = None
    for mod_name in module_names:
        try:
            mod = __import__(mod_name, fromlist=["build_feature_table"])
            log(f"Raw input mode selected: using {mod_name}.build_feature_table(...)", indent=1)
            features_df, feature_report = mod.build_feature_table(Path(args.input).expanduser(), out_dir / "feature_engineering", args)
            features_df.to_csv(out_dir / "cesmlc_v9_engineered_features_used_for_training.csv", index=False)
            return features_df, feature_report
        except Exception as exc:
            last_exc = exc
            continue
    raise RuntimeError("Raw input mode requires v9_feature_engineering.py or a compatible V8/V8.2 feature-engineering file in the same folder.") from last_exc


def parse_args() -> argparse.Namespace:
    p = argparse.ArgumentParser(description="CESMLC V9 reference-safe training dataset builder.")
    src = p.add_mutually_exclusive_group(required=True)
    src.add_argument("--input", default=None, type=str, help="Raw ENMT/CESMLC CSV input.")
    src.add_argument("--engineered-features", default=None, type=str, help="Existing engineered feature CSV.")
    p.add_argument("--out-dir", required=True, type=str)
    p.add_argument("--manual-labels", default=None, type=str)

    # Pass-through raw feature engineering args.
    p.add_argument("--days", default=30, type=int)
